{
  "apiVersion": "ocsv3.cloudring.io/v1alpha1",
  "kind": "ConnectorPackage",
  "metadata": {
    "name": "hpc-module-package",
    "displayName": "HPC Module Package",
    "owner": "hpc-module-team",
    "version": "v0.1.0"
  },
  "service": {
    "apiVersion": "ocsv3.cloudring.io/v1alpha1",
    "kind": "ServiceConnector",
    "metadata": {
      "name": "hpc-module",
      "displayName": "HPC Module",
      "owner": "hpc-module-team",
      "version": "v0.1.0"
    },
    "spec": {
      "capabilities": [
        {
          "class": "hpc",
          "name": "hpc-reservation",
          "description": "Optional HPC reservation and workload-class contract exposed through OCSv3 metadata."
        }
      ],
      "dependencies": [
        {
          "id": "kubernetes-1-35-window",
          "capabilityClass": "kubernetes",
          "role": "upstream Kubernetes API target",
          "portability": "ocs-portable-kubernetes-1.35-patch-window"
        },
        {
          "id": "cilium-1-19-window",
          "capabilityClass": "network-policy",
          "role": "portable dataplane policy contract",
          "portability": "ocs-portable-cilium-1.19-compatible"
        },
        {
          "id": "flux-2-window",
          "capabilityClass": "gitops",
          "role": "module delivery contract",
          "portability": "ocs-portable-flux-2-compatible"
        },
        {
          "id": "slurm-26-05-optional-window",
          "capabilityClass": "slurm",
          "role": "optional scheduler backend",
          "portability": "ocs-portable-slurm-26.05-window"
        },
        {
          "id": "kueue-queue-window",
          "capabilityClass": "scheduler",
          "role": "Kubernetes-native admission backend",
          "portability": "ocs-portable-kueue-scheduler-window"
        },
        {
          "id": "policy-engine-window",
          "capabilityClass": "policy",
          "role": "quota and admission policy",
          "portability": "ocs-portable-policy-engine-contract"
        },
        {
          "id": "secret-manager-window",
          "capabilityClass": "secret-manager",
          "role": "referenced credentials only",
          "portability": "ocs-portable-secret-reference-contract"
        }
      ],
      "lifecycle": [
        {
          "name": "provision",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "metadata.uid"
        },
        {
          "name": "enable",
          "verb": "Enable",
          "idempotent": true,
          "idempotencyKey": "module.request.id"
        },
        {
          "name": "disable",
          "verb": "Disable",
          "idempotent": true,
          "idempotencyKey": "module.request.id"
        },
        {
          "name": "export",
          "verb": "Export",
          "idempotent": true,
          "idempotencyKey": "export.request.id"
        },
        {
          "name": "delete",
          "verb": "Delete",
          "idempotent": true,
          "idempotencyKey": "delete.request.id",
          "rollbackRef": "lifecycle.rollback"
        },
        {
          "name": "backup",
          "verb": "Backup",
          "idempotent": true,
          "idempotencyKey": "backup.request.id"
        },
        {
          "name": "restore",
          "verb": "Restore",
          "idempotent": true,
          "idempotencyKey": "restore.request.id"
        },
        {
          "name": "retry",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "retry.request.id",
          "rollbackRef": "lifecycle.rollback"
        },
        {
          "name": "rollback",
          "verb": "Rollback",
          "idempotent": true,
          "idempotencyKey": "rollback.request.id"
        }
      ],
      "automation": [
        {
          "name": "publish-hpc-reservation-contract",
          "description": "Publish HPC reservation metadata after compatibility and rollback review.",
          "actionRef": "lifecycle.enable"
        },
        {
          "name": "disable-hpc-module",
          "description": "Return HPC to disabled or not-installed state without foundation impact.",
          "actionRef": "lifecycle.disable"
        }
      ],
      "usageMeters": [
        {
          "name": "hpc_reservation_hour",
          "unit": "reservation-hour",
          "aggregation": "sum"
        }
      ],
      "billing": {
        "connectorRef": "hpc-module-billing",
        "meters": [
          {
            "name": "hpc_reservation_hour",
            "unit": "reservation-hour",
            "aggregation": "sum"
          }
        ]
      },
      "portalModules": [
        {
          "name": "hpc-overview",
          "slot": "service.detail",
          "route": "/services/hpc",
          "apiRef": "service.api.hpc.reservations",
          "hostRef": "ui.hpc.host",
          "mountRef": "mount.hpc.overview",
          "permissions": [
            "hpc.read",
            "hpc.write"
          ]
        }
      ],
      "ui": {
        "embedRef": "ui.hpc.bundle",
        "contextSchemaRef": "schemas/hpc-ui-context.v1alpha1.json",
        "hostAuthority": [
          "navigation",
          "identity",
          "policy",
          "support"
        ],
        "extensionActions": [
          "hpc.module.enable",
          "hpc.module.disable"
        ],
        "moduleHost": {
          "host": "cloudring-provider-portal",
          "runtime": "module-federation",
          "mountRef": "mount.hpc.overview",
          "versionRange": ">=0.1.0 <1.0.0",
          "integrityRef": "evidence.hpc.ui.integrity",
          "sandbox": "tenant-iam-context",
          "allowedEvents": [
            "hpc.module.enable.requested",
            "hpc.module.disable.requested"
          ],
          "requiredContext": [
            "tenant",
            "project",
            "iam.subject",
            "entitlements"
          ]
        },
        "evidence": [
          {
            "name": "ui-integrity",
            "type": "integrity-evidence",
            "ref": "evidence.hpc.ui.integrity"
          }
        ]
      },
      "analyticsEvents": [
        {
          "name": "hpc.module.state.changed",
          "trigger": "portal-module-action",
          "subject": "tenant.project.hpc-module",
          "properties": [
            "tenantId",
            "projectId",
            "state",
            "result"
          ],
          "evidenceRef": "evidence.hpc.analytics.state"
        }
      ],
      "kubernetesBindings": [
        {
          "group": "hpc.cloudring.io",
          "version": "v1alpha1",
          "kind": "HPCReservation",
          "plural": "hpcreservations",
          "scope": "Namespaced",
          "crdRef": "crd.hpcreservations.hpc.cloudring",
          "statusPath": "status.conditions",
          "condition": "Ready"
        }
      ],
      "gatewayRoutes": [
        {
          "name": "hpc-api",
          "parentRef": "gateway-api.parent.platform-services",
          "hostnames": [
            "hpc.service-api.contract"
          ],
          "rules": [
            "tenant-hpc-api"
          ],
          "evidenceRef": "evidence.hpc.gateway-route"
        }
      ],
      "secrets": {
        "workloadIdentityRef": "workloadidentity.hpc-controller",
        "secretRefs": [
          {
            "name": "hpc-scheduler-secret-reference",
            "ref": "secretref.hpc.scheduler",
            "purpose": "scheduler access by reference",
            "rotation": "operator-initiated"
          }
        ]
      },
      "policies": [
        {
          "name": "hpc-entitlement",
          "class": "authorization",
          "decisionRef": "policy.hpc.entitlement",
          "evidenceRef": "evidence.hpc.policy.entitlement"
        }
      ],
      "dataLifecycle": {
        "export": {
          "actionRef": "lifecycle.export",
          "format": "ocs-hpc-module-receipts",
          "evidenceRef": "evidence.hpc.export"
        },
        "delete": {
          "actionRef": "lifecycle.delete",
          "format": "ocs-hpc-delete-receipt",
          "evidenceRef": "evidence.hpc.delete"
        }
      },
      "states": [
        {
          "name": "not-installed",
          "reason": "HPC module is optional and absent from foundation-only deployments",
          "userVisible": true,
          "evidenceRef": "evidence.hpc.not-installed",
          "remediation": "install only after foundation, scheduler, policy, and rollback evidence pass"
        },
        {
          "name": "disabled",
          "reason": "HPC module is installed but disabled by provider policy",
          "userVisible": true,
          "evidenceRef": "evidence.hpc.disabled",
          "remediation": "enable through OCS lifecycle after compatibility review"
        },
        {
          "name": "degraded",
          "reason": "scheduler, queue, or network dependency is unavailable",
          "userVisible": true,
          "evidenceRef": "evidence.hpc.degraded",
          "remediation": "keep workload admission closed until dependency evidence recovers"
        },
        {
          "name": "blocked",
          "reason": "compatibility, entitlement, backup, or rollback evidence is missing",
          "userVisible": true,
          "evidenceRef": "evidence.hpc.blocked",
          "remediation": "clear the missing gate before publishing HPC reservations"
        },
        {
          "name": "ready",
          "reason": "controller ready",
          "userVisible": true,
          "evidenceRef": "evidence.hpc.ready",
          "remediation": "continue normal operation"
        },
        {
          "name": "retryable",
          "reason": "transient dependency failure",
          "userVisible": true,
          "evidenceRef": "evidence.hpc.retryable",
          "remediation": "retry with the same idempotency key"
        },
        {
          "name": "denied",
          "reason": "policy denied",
          "userVisible": true,
          "evidenceRef": "evidence.hpc.denied",
          "remediation": "request entitlement or policy change"
        }
      ],
      "support": {
        "owner": "hpc-module-team",
        "escalation": "platform-support",
        "diagnostics": [
          "reservation-status",
          "scheduler-version-window",
          "queue-health-summary"
        ],
        "docsRef": "cloudring_core/modules/hpc/README.md",
        "evidence": [
          {
            "name": "support-diagnostics",
            "type": "support-evidence",
            "ref": "evidence.hpc.support-diagnostics"
          }
        ]
      },
      "evidenceBundles": [
        {
          "name": "hpc-module-evidence",
          "owner": "hpc-module-team",
          "claim": "HPC ownership, compatibility windows, disabled state, not-installed state, and OCS module surfaces are declared as metadata",
          "freshness": "review-before-publication",
          "redaction": "tenant-safe-receipts-only",
          "evidence": [
            {
              "name": "compatibility-bom",
              "type": "bom-window",
              "ref": "xCloudRING.compatibilityBOM"
            }
          ],
          "nonClaims": [
            "does not claim live HPC installation",
            "does not make HPC a foundation prerequisite"
          ],
          "reviewPath": "reviews.hpc.module"
        }
      ]
    }
  },
  "billing": {
    "apiVersion": "ocsv3.cloudring.io/v1alpha1",
    "kind": "BillingConnector",
    "metadata": {
      "name": "hpc-module-billing",
      "displayName": "HPC Module Billing",
      "owner": "hpc-module-team",
      "version": "v0.1.0"
    },
    "meters": [
      {
        "name": "hpc_reservation_hour",
        "unit": "reservation-hour",
        "aggregation": "sum"
      }
    ],
    "costMeters": [
      {
        "name": "hpc_reservation_hour_cost",
        "currency": "USD",
        "unitPrice": "0.00-example",
        "meterRef": "hpc_reservation_hour",
        "evidenceRef": "evidence.hpc.cost-meter"
      }
    ],
    "events": [
      {
        "name": "hpc-reservation-hour-recorded",
        "meter": "hpc_reservation_hour",
        "idempotent": true,
        "idempotencyKey": "usageEvent.id",
        "entitlementRef": "catalog.plan.optional",
        "attribution": "tenant.project.subscription",
        "replayPolicy": "dedupe-by-idempotency-key"
      }
    ]
  },
  "catalog": {
    "serviceClass": "hpc",
    "visibility": "tenant",
    "portability": "ocs-portable-hpc-module-contract",
    "plans": [
      {
        "name": "optional",
        "displayName": "Optional HPC",
        "billingMode": "metered",
        "quotaRef": "quota.hpc.optional"
      }
    ]
  },
  "configuration": {
    "schemaRef": "schemas/hpc.v1alpha1.json",
    "version": "v1alpha1"
  },
  "readiness": [
    {
      "name": "hpc-not-installed-ready",
      "type": "module-state",
      "target": "states.not-installed",
      "condition": "OptionalNotInstalled",
      "evidenceRef": "evidence.hpc.not-installed"
    },
    {
      "name": "hpc-disabled-until-foundation",
      "type": "foundation-gate",
      "target": "xCloudRING.foundationPrerequisite",
      "condition": "False",
      "evidenceRef": "evidence.hpc.disabled"
    }
  ],
  "tenantAccess": {
    "scope": "project",
    "entitlementRef": "catalog.plan.optional",
    "entitlements": [
      {
        "name": "optional-plan",
        "ref": "catalog.plan.optional",
        "scope": "project"
      }
    ],
    "permissions": [
      "hpc.read",
      "hpc.write",
      "hpc.support"
    ]
  },
  "durability": {
    "stateClass": "control-plane-metadata",
    "dataClasses": [
      "hpc-reservation-intent",
      "queue-receipts",
      "usage-events"
    ],
    "backupPolicyRef": "backup.module.optional",
    "recoveryObjective": "restore-test-required-before-production",
    "recoveryEvidence": [
      {
        "name": "state-export",
        "type": "runbook-evidence",
        "ref": "evidence.hpc.export"
      }
    ]
  },
  "distribution": {
    "deploymentProfiles": [
      "optional-module",
      "provider-managed"
    ],
    "channels": [
      "service-store",
      "enterprise-marketplace"
    ],
    "infrastructureTargets": [
      "upstream-kubernetes"
    ],
    "updatePolicyRef": "updates.hpc.compatibility-reviewed"
  },
  "federation": {
    "modes": [
      "standalone",
      "connected"
    ],
    "messageBusRef": "federation.bus.hpc.events",
    "crossProviderScenarios": [
      "hpc-queue-handoff",
      "support-handoff"
    ],
    "portabilityPolicyRef": "policy.hpc.ocs-portable-hpc-module"
  },
  "commercial": {
    "roles": [
      "vendor",
      "provider",
      "reseller"
    ],
    "revenueModel": "metered-hpc-reservation-usage",
    "licenseRef": "license.hpc.optional-module",
    "expiryBehavior": "service-stays-not-installed-or-disabled-until-provider-enables",
    "supportRef": "support.hpc.provider-handoff",
    "serviceProvenance": "module-owned-service-surface",
    "responsibilityMatrixRef": "responsibility.hpc.module-provider-and-runtime-dependency",
    "continuityPlanRef": "continuity.hpc.disable-export"
  },
  "xCloudRING": {
    "ownership": "optional-ocs-module",
    "foundationPrerequisite": false,
    "defaultState": "not-installed",
    "disabledStates": [
      "not-installed",
      "disabled",
      "blocked"
    ],
    "compatibilityBOM": [
      {
        "component": "Kubernetes",
        "window": "1.35.x",
        "required": true
      },
      {
        "component": "Cilium",
        "window": "1.19.x",
        "required": true
      },
      {
        "component": "Flux",
        "window": "2.x compatible with Kubernetes 1.35",
        "required": true
      },
      {
        "component": "Slurm",
        "window": "26.05.x when Slurm backend is enabled",
        "required": false
      },
      {
        "component": "Kueue scheduler",
        "window": "Kubernetes 1.35 compatible fair-sharing profile",
        "required": false
      },
      {
        "component": "policy engine",
        "window": "fail-closed admission policy compatible with OCS lifecycle gates",
        "required": true
      },
      {
        "component": "secret manager",
        "window": "secret-reference-only integration compatible with workload identity",
        "required": true
      }
    ],
    "nonClaims": [
      "no live HPC installation readiness",
      "no foundation-only dependency"
    ]
  }
}
