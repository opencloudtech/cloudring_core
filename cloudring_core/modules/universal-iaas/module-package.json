{
  "apiVersion": "ocsv3.cloudring.io/v1alpha1",
  "kind": "ConnectorPackage",
  "metadata": {
    "name": "universal-iaas-module",
    "displayName": "Universal IaaS Module",
    "owner": "compute-module-team",
    "version": "v0.1.0"
  },
  "service": {
    "apiVersion": "ocsv3.cloudring.io/v1alpha1",
    "kind": "ServiceConnector",
    "metadata": {
      "name": "universal-iaas",
      "displayName": "Universal IaaS",
      "owner": "compute-module-team",
      "version": "v0.1.0"
    },
    "spec": {
      "capabilities": [
        {
          "class": "universal-iaas",
          "name": "iaas-workload",
          "description": "Tenant-scoped compute, image, network attachment, and volume lifecycle surfaced through OCSv3."
        }
      ],
      "dependencies": [
        {
          "id": "kubevirt-runtime-contract",
          "capabilityClass": "virtualization-runtime",
          "role": "optional virtualization runtime dependency",
          "portability": "ocs-portable-kubernetes-crd-contract",
          "implementationRef": "dependency.kubevirt.virtualization.contract"
        },
        {
          "id": "cni-network-contract",
          "capabilityClass": "tenant-network",
          "role": "portable network attachment dependency",
          "portability": "ocs-portable-network-attachment-contract"
        }
      ],
      "lifecycle": [
        {
          "name": "provision",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "metadata.uid",
          "rollbackRef": "lifecycle.rollback"
        },
        {
          "name": "scale",
          "verb": "Scale",
          "idempotent": true,
          "idempotencyKey": "operation.id",
          "rollbackRef": "lifecycle.rollback"
        },
        {
          "name": "backup",
          "verb": "Backup",
          "idempotent": true,
          "idempotencyKey": "backup.request.id"
        },
        {
          "name": "restore",
          "verb": "Restore",
          "idempotent": true,
          "idempotencyKey": "restore.request.id",
          "rollbackRef": "lifecycle.rollback"
        },
        {
          "name": "export",
          "verb": "Export",
          "idempotent": true,
          "idempotencyKey": "export.request.id"
        },
        {
          "name": "delete",
          "verb": "Delete",
          "idempotent": true,
          "idempotencyKey": "delete.request.id",
          "rollbackRef": "lifecycle.restore"
        },
        {
          "name": "retry",
          "verb": "Retry",
          "idempotent": true,
          "idempotencyKey": "retry.request.id",
          "rollbackRef": "lifecycle.rollback"
        },
        {
          "name": "rollback",
          "verb": "Rollback",
          "idempotent": true,
          "idempotencyKey": "rollback.request.id"
        }
      ],
      "automation": [
        {
          "name": "reconcile-iaas-workload",
          "description": "Reconcile the tenant workload claim through the module controller API contract.",
          "actionRef": "lifecycle.provision"
        },
        {
          "name": "backup-iaas-workload",
          "description": "Capture portable workload metadata, volume references, and restore evidence.",
          "actionRef": "lifecycle.backup"
        },
        {
          "name": "retry-iaas-workload",
          "description": "Replay a denied or degraded request only after policy, quota, and dependency state are rechecked.",
          "actionRef": "lifecycle.retry"
        },
        {
          "name": "rollback-iaas-workload",
          "description": "Restore the previous declared workload state when a lifecycle mutation fails.",
          "actionRef": "lifecycle.rollback"
        }
      ],
      "usageMeters": [
        {
          "name": "vcpu_seconds",
          "unit": "vcpu-second",
          "aggregation": "sum"
        },
        {
          "name": "memory_gib_seconds",
          "unit": "gib-second",
          "aggregation": "sum"
        },
        {
          "name": "block_storage_gib_seconds",
          "unit": "gib-second",
          "aggregation": "sum"
        },
        {
          "name": "network_egress_gib",
          "unit": "gib",
          "aggregation": "sum"
        }
      ],
      "billing": {
        "connectorRef": "universal-iaas-billing",
        "meters": [
          {
            "name": "vcpu_seconds",
            "unit": "vcpu-second",
            "aggregation": "sum"
          },
          {
            "name": "memory_gib_seconds",
            "unit": "gib-second",
            "aggregation": "sum"
          },
          {
            "name": "block_storage_gib_seconds",
            "unit": "gib-second",
            "aggregation": "sum"
          },
          {
            "name": "network_egress_gib",
            "unit": "gib",
            "aggregation": "sum"
          }
        ]
      },
      "portalModules": [
        {
          "name": "universal-iaas-overview",
          "slot": "service.detail",
          "route": "/services/universal-iaas/workloads",
          "apiRef": "service.api.universal-iaas.workloads",
          "hostRef": "ui.universal-iaas.host",
          "mountRef": "mount.universal-iaas.overview",
          "permissions": [
            "universal-iaas.read"
          ]
        },
        {
          "name": "universal-iaas-operations",
          "slot": "service.operations",
          "route": "/services/universal-iaas/operations",
          "apiRef": "service.api.universal-iaas.operations",
          "hostRef": "ui.universal-iaas.host",
          "mountRef": "mount.universal-iaas.operations",
          "permissions": [
            "universal-iaas.write",
            "universal-iaas.support"
          ]
        }
      ],
      "ui": {
        "embedRef": "ui.universal-iaas.bundle",
        "contextSchemaRef": "schemas/universal-iaas-ui-context.v1alpha1.json",
        "hostAuthority": [
          "navigation",
          "identity",
          "policy",
          "billing",
          "support"
        ],
        "extensionActions": [
          "iaas.provision",
          "iaas.scale",
          "iaas.backup",
          "iaas.restore",
          "iaas.export",
          "iaas.delete",
          "iaas.retry",
          "iaas.rollback"
        ],
        "moduleHost": {
          "host": "cloudring-provider-portal",
          "runtime": "module-federation",
          "mountRef": "mount.universal-iaas.overview",
          "versionRange": ">=0.1.0 <1.0.0",
          "integrityRef": "evidence.universal-iaas.ui.integrity",
          "sandbox": "tenant-iam-context",
          "allowedEvents": [
            "iaas.provision.requested",
            "iaas.backup.requested",
            "iaas.restore.requested",
            "iaas.delete.requested",
            "iaas.retry.requested"
          ],
          "requiredContext": [
            "tenant",
            "project",
            "iam.subject",
            "locale",
            "theme",
            "entitlements"
          ]
        },
        "evidence": [
          {
            "name": "ui-host-shell-certification",
            "type": "certification-evidence",
            "ref": "evidence.universal-iaas.ui.host-shell"
          },
          {
            "name": "ui-integrity",
            "type": "integrity-evidence",
            "ref": "evidence.universal-iaas.ui.integrity"
          }
        ]
      },
      "analyticsEvents": [
        {
          "name": "universal-iaas.workload.lifecycle.submitted",
          "trigger": "portal-module-action",
          "subject": "tenant.project.iaas-workload",
          "properties": [
            "tenantId",
            "projectId",
            "operation",
            "plan",
            "region",
            "result"
          ],
          "evidenceRef": "evidence.universal-iaas.analytics.lifecycle"
        },
        {
          "name": "universal-iaas.workload.state.changed",
          "trigger": "controller-condition-transition",
          "subject": "tenant.project.iaas-workload",
          "properties": [
            "tenantId",
            "projectId",
            "state",
            "reason",
            "retryable"
          ],
          "evidenceRef": "evidence.universal-iaas.analytics.state"
        }
      ],
      "kubernetesBindings": [
        {
          "group": "compute.cloudring.io",
          "version": "v1alpha1",
          "kind": "IaaSWorkload",
          "plural": "iaasworkloads",
          "scope": "Namespaced",
          "crdRef": "crd.iaasworkloads.compute.cloudring",
          "statusPath": "status.conditions",
          "condition": "Ready"
        }
      ],
      "gatewayRoutes": [
        {
          "name": "universal-iaas-controller-api",
          "parentRef": "gateway.platform.service-api",
          "hostnames": [
            "universal-iaas.services.example.com"
          ],
          "rules": [
            "tenant-scoped-workload-read",
            "tenant-scoped-workload-mutate",
            "operation-status-read"
          ],
          "evidenceRef": "evidence.universal-iaas.controller-api"
        }
      ],
      "secrets": {
        "workloadIdentityRef": "workloadidentity.universal-iaas-controller",
        "secretRefs": [
          {
            "name": "image-pull-reference",
            "ref": "secretref.universal-iaas.image-access",
            "purpose": "portable image access reference",
            "rotation": "operator-initiated"
          },
          {
            "name": "backup-target-reference",
            "ref": "secretref.universal-iaas.backup-target",
            "purpose": "backup target access reference",
            "rotation": "operator-initiated"
          }
        ]
      },
      "policies": [
        {
          "name": "tenant-iaas-entitlement",
          "class": "authorization",
          "decisionRef": "policy.universal-iaas.entitlement",
          "evidenceRef": "evidence.universal-iaas.policy.entitlement"
        },
        {
          "name": "tenant-iaas-placement",
          "class": "placement",
          "decisionRef": "policy.universal-iaas.placement",
          "evidenceRef": "evidence.universal-iaas.policy.placement"
        },
        {
          "name": "tenant-iaas-durability",
          "class": "durability",
          "decisionRef": "policy.universal-iaas.durability",
          "evidenceRef": "evidence.universal-iaas.policy.durability"
        }
      ],
      "dataLifecycle": {
        "export": {
          "actionRef": "lifecycle.export",
          "format": "ocs-universal-iaas-portable-archive",
          "evidenceRef": "evidence.universal-iaas.export"
        },
        "delete": {
          "actionRef": "lifecycle.delete",
          "format": "ocs-universal-iaas-delete-receipt",
          "evidenceRef": "evidence.universal-iaas.delete"
        }
      },
      "states": [
        {
          "name": "denied",
          "reason": "authorization, entitlement, quota, or policy decision rejects the request",
          "userVisible": true,
          "evidenceRef": "evidence.universal-iaas.denied",
          "remediation": "resolve entitlement, quota, or policy blockers before retry"
        },
        {
          "name": "degraded",
          "reason": "capacity, network attachment, storage, or virtualization dependency is unavailable",
          "userVisible": true,
          "evidenceRef": "evidence.universal-iaas.degraded",
          "remediation": "retry after dependency recovery or export workload state"
        },
        {
          "name": "retry",
          "reason": "transient dependency or controller reconciliation error can be replayed safely",
          "userVisible": true,
          "evidenceRef": "evidence.universal-iaas.retry",
          "remediation": "rerun lifecycle.retry with the original idempotency key"
        },
        {
          "name": "blocked",
          "reason": "non-retryable policy, durability, or dependency prerequisite is missing",
          "userVisible": true,
          "evidenceRef": "evidence.universal-iaas.blocked",
          "remediation": "operator review must clear the prerequisite before mutation resumes"
        },
        {
          "name": "ready",
          "reason": "controller ready",
          "userVisible": true,
          "evidenceRef": "evidence.universal-iaas.ready",
          "remediation": "continue normal operation"
        },
        {
          "name": "retryable",
          "reason": "transient dependency failure",
          "userVisible": true,
          "evidenceRef": "evidence.universal-iaas.retryable",
          "remediation": "retry with the same idempotency key"
        }
      ],
      "support": {
        "owner": "compute-module-team",
        "escalation": "platform-support",
        "diagnostics": [
          "iaas-workload-status",
          "iaas-operation-log",
          "billing-meter-replay",
          "backup-restore-receipt",
          "dependency-condition-summary"
        ],
        "docsRef": "cloudring_core/modules/universal-iaas/README.md",
        "evidence": [
          {
            "name": "support-diagnostics",
            "type": "support-evidence",
            "ref": "evidence.universal-iaas.support-diagnostics"
          },
          {
            "name": "controller-api-contract",
            "type": "contract-evidence",
            "ref": "evidence.universal-iaas.controller-api"
          }
        ]
      },
      "evidenceBundles": [
        {
          "name": "universal-iaas-controller-api",
          "owner": "compute-module-team",
          "claim": "controller API, Kubernetes binding, gateway route, and portal module references are declared for OCSv3 validation",
          "freshness": "review-before-publication",
          "redaction": "support-safe-summary-only",
          "evidence": [
            {
              "name": "controller-api-contract",
              "type": "contract-evidence",
              "ref": "evidence.universal-iaas.controller-api"
            }
          ],
          "nonClaims": [
            "does not claim production readiness",
            "does not make KubeVirt a platform core dependency"
          ],
          "reviewPath": "reviews.universal-iaas.controller-api"
        },
        {
          "name": "universal-iaas-durability",
          "owner": "compute-module-team",
          "claim": "backup, restore, rollback, delete, export, denied, degraded, and retry evidence references are linked",
          "freshness": "review-before-publication",
          "redaction": "tenant-safe-receipts-only",
          "evidence": [
            {
              "name": "restore-drill",
              "type": "runbook-evidence",
              "ref": "evidence.universal-iaas.restore"
            },
            {
              "name": "rollback-receipt",
              "type": "runbook-evidence",
              "ref": "evidence.universal-iaas.rollback"
            }
          ],
          "nonClaims": [
            "does not claim live backup success",
            "does not publish tenant workload data"
          ],
          "reviewPath": "reviews.universal-iaas.durability"
        },
        {
          "name": "universal-iaas-billing-support",
          "owner": "compute-module-team",
          "claim": "billing meters, support diagnostics, and usage replay contracts are declared",
          "freshness": "review-before-publication",
          "redaction": "aggregate-usage-only",
          "evidence": [
            {
              "name": "billing-meter-review",
              "type": "billing-evidence",
              "ref": "evidence.universal-iaas.billing"
            },
            {
              "name": "support-diagnostics",
              "type": "support-evidence",
              "ref": "evidence.universal-iaas.support-diagnostics"
            }
          ],
          "nonClaims": [
            "does not set real prices",
            "does not include provider-specific cost records"
          ],
          "reviewPath": "reviews.universal-iaas.billing-support"
        }
      ]
    }
  },
  "billing": {
    "apiVersion": "ocsv3.cloudring.io/v1alpha1",
    "kind": "BillingConnector",
    "metadata": {
      "name": "universal-iaas-billing",
      "displayName": "Universal IaaS Billing",
      "owner": "compute-module-team",
      "version": "v0.1.0"
    },
    "meters": [
      {
        "name": "vcpu_seconds",
        "unit": "vcpu-second",
        "aggregation": "sum"
      },
      {
        "name": "memory_gib_seconds",
        "unit": "gib-second",
        "aggregation": "sum"
      },
      {
        "name": "block_storage_gib_seconds",
        "unit": "gib-second",
        "aggregation": "sum"
      },
      {
        "name": "network_egress_gib",
        "unit": "gib",
        "aggregation": "sum"
      }
    ],
    "costMeters": [
      {
        "name": "vcpu_hour",
        "currency": "USD",
        "unitPrice": "0.00-example",
        "meterRef": "vcpu_seconds",
        "evidenceRef": "evidence.universal-iaas.cost-meter.vcpu"
      },
      {
        "name": "memory_gib_hour",
        "currency": "USD",
        "unitPrice": "0.00-example",
        "meterRef": "memory_gib_seconds",
        "evidenceRef": "evidence.universal-iaas.cost-meter.memory"
      },
      {
        "name": "block_storage_gib_hour",
        "currency": "USD",
        "unitPrice": "0.00-example",
        "meterRef": "block_storage_gib_seconds",
        "evidenceRef": "evidence.universal-iaas.cost-meter.storage"
      },
      {
        "name": "network_egress_gib",
        "currency": "USD",
        "unitPrice": "0.00-example",
        "meterRef": "network_egress_gib",
        "evidenceRef": "evidence.universal-iaas.cost-meter.network"
      }
    ],
    "events": [
      {
        "name": "compute-usage-recorded",
        "meter": "vcpu_seconds",
        "idempotent": true,
        "idempotencyKey": "usageEvent.id",
        "entitlementRef": "catalog.plan.standard",
        "attribution": "tenant.project.subscription",
        "replayPolicy": "dedupe-by-idempotency-key"
      },
      {
        "name": "memory-usage-recorded",
        "meter": "memory_gib_seconds",
        "idempotent": true,
        "idempotencyKey": "usageEvent.id",
        "entitlementRef": "catalog.plan.standard",
        "attribution": "tenant.project.subscription",
        "replayPolicy": "dedupe-by-idempotency-key"
      },
      {
        "name": "storage-usage-recorded",
        "meter": "block_storage_gib_seconds",
        "idempotent": true,
        "idempotencyKey": "usageEvent.id",
        "entitlementRef": "catalog.plan.standard",
        "attribution": "tenant.project.subscription",
        "replayPolicy": "dedupe-by-idempotency-key"
      },
      {
        "name": "network-egress-recorded",
        "meter": "network_egress_gib",
        "idempotent": true,
        "idempotencyKey": "usageEvent.id",
        "entitlementRef": "catalog.plan.standard",
        "attribution": "tenant.project.subscription",
        "replayPolicy": "dedupe-by-idempotency-key"
      }
    ]
  },
  "catalog": {
    "serviceClass": "universal-iaas",
    "visibility": "tenant",
    "portability": "ocs-portable-workload-export-import",
    "plans": [
      {
        "name": "standard",
        "displayName": "Standard Universal IaaS",
        "billingMode": "metered",
        "quotaRef": "quota.universal-iaas.standard"
      }
    ]
  },
  "configuration": {
    "schemaRef": "schemas/universal-iaas.v1alpha1.json",
    "version": "v1alpha1"
  },
  "readiness": [
    {
      "name": "controller-ready",
      "type": "kubernetes-condition",
      "target": "IaaSWorkload.status.conditions",
      "condition": "Ready",
      "evidenceRef": "support.diagnostics.iaas-workload-status"
    },
    {
      "name": "billing-replay-ready",
      "type": "usage-meter-replay",
      "target": "BillingConnector.events",
      "condition": "IdempotentReplayReady",
      "evidenceRef": "evidence.universal-iaas.billing-replay"
    },
    {
      "name": "backup-restore-ready",
      "type": "durability-drill",
      "target": "durability.recoveryEvidence",
      "condition": "RestoreEvidenceLinked",
      "evidenceRef": "evidence.universal-iaas.restore"
    }
  ],
  "tenantAccess": {
    "scope": "project",
    "entitlementRef": "catalog.plan.standard",
    "entitlements": [
      {
        "name": "standard-plan",
        "ref": "catalog.plan.standard",
        "scope": "project"
      }
    ],
    "permissions": [
      "universal-iaas.read",
      "universal-iaas.write",
      "universal-iaas.backup",
      "universal-iaas.restore",
      "universal-iaas.export",
      "universal-iaas.delete",
      "universal-iaas.support"
    ]
  },
  "durability": {
    "stateClass": "stateful",
    "dataClasses": [
      "tenant-workload-metadata",
      "tenant-image-references",
      "tenant-volume-references",
      "operation-receipts",
      "usage-events"
    ],
    "backupPolicyRef": "backup.universal-iaas.standard",
    "recoveryObjective": "restore-test-required-before-production",
    "recoveryEvidence": [
      {
        "name": "backup-receipt",
        "type": "runbook-evidence",
        "ref": "evidence.universal-iaas.backup"
      },
      {
        "name": "restore-drill",
        "type": "runbook-evidence",
        "ref": "evidence.universal-iaas.restore"
      },
      {
        "name": "rollback-receipt",
        "type": "runbook-evidence",
        "ref": "evidence.universal-iaas.rollback"
      }
    ]
  },
  "distribution": {
    "deploymentProfiles": [
      "provider-managed",
      "dedicated-cell",
      "edge-zone"
    ],
    "channels": [
      "service-store",
      "enterprise-marketplace"
    ],
    "infrastructureTargets": [
      "kubernetes",
      "private-cloud",
      "bare-metal",
      "edge"
    ],
    "updatePolicyRef": "updates.universal-iaas.compatibility-reviewed"
  },
  "federation": {
    "modes": [
      "standalone",
      "connected",
      "federated"
    ],
    "messageBusRef": "federation.bus.universal-iaas.events",
    "crossProviderScenarios": [
      "workload-export-import",
      "backup-replication",
      "support-handoff",
      "billing-replay"
    ],
    "portabilityPolicyRef": "policy.universal-iaas.ocs-portable-workload-export-import"
  },
  "commercial": {
    "roles": [
      "vendor",
      "provider",
      "reseller"
    ],
    "revenueModel": "metered-compute-storage-network-with-marketplace-share",
    "licenseRef": "license.universal-iaas.marketplace-module",
    "expiryBehavior": "service-keeps-running-updates-stop-except-critical-fixes",
    "supportRef": "support.universal-iaas.provider-handoff",
    "serviceProvenance": "module-owned-service-surface",
    "responsibilityMatrixRef": "responsibility.universal-iaas.module-provider-and-runtime-dependency",
    "continuityPlanRef": "continuity.universal-iaas.backup-restore-export"
  }
}
