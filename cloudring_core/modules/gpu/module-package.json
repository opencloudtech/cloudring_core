{
  "apiVersion": "ocsv3.cloudring.io/v1alpha1",
  "kind": "ConnectorPackage",
  "metadata": {
    "name": "gpu-module-package",
    "displayName": "GPU Module Package",
    "owner": "gpu-module-team",
    "version": "v0.1.0"
  },
  "service": {
    "apiVersion": "ocsv3.cloudring.io/v1alpha1",
    "kind": "ServiceConnector",
    "metadata": {
      "name": "gpu-module",
      "displayName": "GPU Module",
      "owner": "gpu-module-team",
      "version": "v0.1.0"
    },
    "spec": {
      "capabilities": [
        {
          "class": "gpu",
          "name": "gpu-pool",
          "description": "Optional GPU pool, partitioning, observability, and billing contract exposed through OCSv3 metadata."
        }
      ],
      "dependencies": [
        {
          "id": "kubernetes-1-35-window",
          "capabilityClass": "kubernetes",
          "role": "upstream Kubernetes API target",
          "portability": "ocs-portable-kubernetes-1.35-patch-window"
        },
        {
          "id": "cilium-1-19-window",
          "capabilityClass": "network-policy",
          "role": "portable dataplane policy contract",
          "portability": "ocs-portable-cilium-1.19-compatible"
        },
        {
          "id": "nvidia-gpu-operator-26-3-window",
          "capabilityClass": "gpu-operator",
          "role": "optional accelerator operator contract",
          "portability": "ocs-portable-gpu-operator-version-window"
        },
        {
          "id": "nvidia-network-operator-26-4-window",
          "capabilityClass": "network-operator",
          "role": "optional RDMA fabric operator contract",
          "portability": "ocs-portable-network-operator-version-window"
        },
        {
          "id": "kubevirt-1-8-optional-window",
          "capabilityClass": "virtualization",
          "role": "optional passthrough VM dependency",
          "portability": "ocs-portable-kubevirt-version-window"
        },
        {
          "id": "policy-engine-window",
          "capabilityClass": "policy",
          "role": "admission and quota policy",
          "portability": "ocs-portable-policy-engine-contract"
        },
        {
          "id": "secret-manager-window",
          "capabilityClass": "secret-manager",
          "role": "referenced credentials only",
          "portability": "ocs-portable-secret-reference-contract"
        }
      ],
      "lifecycle": [
        {
          "name": "provision",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "metadata.uid"
        },
        {
          "name": "enable",
          "verb": "Enable",
          "idempotent": true,
          "idempotencyKey": "module.request.id"
        },
        {
          "name": "disable",
          "verb": "Disable",
          "idempotent": true,
          "idempotencyKey": "module.request.id"
        },
        {
          "name": "export",
          "verb": "Export",
          "idempotent": true,
          "idempotencyKey": "export.request.id"
        },
        {
          "name": "delete",
          "verb": "Delete",
          "idempotent": true,
          "idempotencyKey": "delete.request.id",
          "rollbackRef": "lifecycle.rollback"
        },
        {
          "name": "backup",
          "verb": "Backup",
          "idempotent": true,
          "idempotencyKey": "backup.request.id"
        },
        {
          "name": "restore",
          "verb": "Restore",
          "idempotent": true,
          "idempotencyKey": "restore.request.id"
        },
        {
          "name": "retry",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "retry.request.id",
          "rollbackRef": "lifecycle.rollback"
        },
        {
          "name": "rollback",
          "verb": "Rollback",
          "idempotent": true,
          "idempotencyKey": "rollback.request.id"
        }
      ],
      "automation": [
        {
          "name": "publish-gpu-pool-contract",
          "description": "Publish GPU pool metadata only after compatibility and evidence gates pass.",
          "actionRef": "lifecycle.enable"
        },
        {
          "name": "disable-gpu-module",
          "description": "Return the module to a first-class disabled or not-installed state.",
          "actionRef": "lifecycle.disable"
        }
      ],
      "usageMeters": [
        {
          "name": "gpu_allocated_hour",
          "unit": "gpu-hour",
          "aggregation": "sum"
        }
      ],
      "billing": {
        "connectorRef": "gpu-module-billing",
        "meters": [
          {
            "name": "gpu_allocated_hour",
            "unit": "gpu-hour",
            "aggregation": "sum"
          }
        ]
      },
      "portalModules": [
        {
          "name": "gpu-overview",
          "slot": "service.detail",
          "route": "/services/gpu",
          "apiRef": "service.api.gpu.pools",
          "hostRef": "ui.gpu.host",
          "mountRef": "mount.gpu.overview",
          "permissions": [
            "gpu.read",
            "gpu.write"
          ]
        }
      ],
      "ui": {
        "embedRef": "ui.gpu.bundle",
        "contextSchemaRef": "schemas/gpu-ui-context.v1alpha1.json",
        "hostAuthority": [
          "navigation",
          "identity",
          "policy",
          "support"
        ],
        "extensionActions": [
          "gpu.module.enable",
          "gpu.module.disable"
        ],
        "moduleHost": {
          "host": "cloudring-provider-portal",
          "runtime": "module-federation",
          "mountRef": "mount.gpu.overview",
          "versionRange": ">=0.1.0 <1.0.0",
          "integrityRef": "evidence.gpu.ui.integrity",
          "sandbox": "tenant-iam-context",
          "allowedEvents": [
            "gpu.module.enable.requested",
            "gpu.module.disable.requested"
          ],
          "requiredContext": [
            "tenant",
            "project",
            "iam.subject",
            "entitlements"
          ]
        },
        "evidence": [
          {
            "name": "ui-integrity",
            "type": "integrity-evidence",
            "ref": "evidence.gpu.ui.integrity"
          }
        ]
      },
      "analyticsEvents": [
        {
          "name": "gpu.module.state.changed",
          "trigger": "portal-module-action",
          "subject": "tenant.project.gpu-module",
          "properties": [
            "tenantId",
            "projectId",
            "state",
            "result"
          ],
          "evidenceRef": "evidence.gpu.analytics.state"
        }
      ],
      "kubernetesBindings": [
        {
          "group": "accelerator.cloudring.io",
          "version": "v1alpha1",
          "kind": "GPUPool",
          "plural": "gpupools",
          "scope": "Namespaced",
          "crdRef": "crd.gpupools.accelerator.cloudring",
          "statusPath": "status.conditions",
          "condition": "Ready"
        }
      ],
      "gatewayRoutes": [
        {
          "name": "gpu-api",
          "parentRef": "gateway-api.parent.platform-services",
          "hostnames": [
            "gpu.service-api.contract"
          ],
          "rules": [
            "tenant-gpu-api"
          ],
          "evidenceRef": "evidence.gpu.gateway-route"
        }
      ],
      "secrets": {
        "workloadIdentityRef": "workloadidentity.gpu-controller",
        "secretRefs": [
          {
            "name": "gpu-operator-secret-reference",
            "ref": "secretref.gpu.operator",
            "purpose": "operator credentials by reference",
            "rotation": "operator-initiated"
          }
        ]
      },
      "policies": [
        {
          "name": "gpu-entitlement",
          "class": "authorization",
          "decisionRef": "policy.gpu.entitlement",
          "evidenceRef": "evidence.gpu.policy.entitlement"
        }
      ],
      "dataLifecycle": {
        "export": {
          "actionRef": "lifecycle.export",
          "format": "ocs-gpu-module-receipts",
          "evidenceRef": "evidence.gpu.export"
        },
        "delete": {
          "actionRef": "lifecycle.delete",
          "format": "ocs-gpu-delete-receipt",
          "evidenceRef": "evidence.gpu.delete"
        }
      },
      "states": [
        {
          "name": "not-installed",
          "reason": "GPU module is optional and absent from foundation-only deployments",
          "userVisible": true,
          "evidenceRef": "evidence.gpu.not-installed",
          "remediation": "install only after foundation, hardware, policy, and rollback evidence pass"
        },
        {
          "name": "disabled",
          "reason": "GPU module is installed but disabled by provider policy",
          "userVisible": true,
          "evidenceRef": "evidence.gpu.disabled",
          "remediation": "enable through OCS lifecycle after compatibility review"
        },
        {
          "name": "degraded",
          "reason": "GPU operator, metrics, or fabric dependency is unavailable",
          "userVisible": true,
          "evidenceRef": "evidence.gpu.degraded",
          "remediation": "keep scheduling closed until dependency evidence recovers"
        },
        {
          "name": "blocked",
          "reason": "compatibility, entitlement, backup, or rollback evidence is missing",
          "userVisible": true,
          "evidenceRef": "evidence.gpu.blocked",
          "remediation": "clear the missing gate before publishing GPU capacity"
        },
        {
          "name": "ready",
          "reason": "controller ready",
          "userVisible": true,
          "evidenceRef": "evidence.gpu.ready",
          "remediation": "continue normal operation"
        },
        {
          "name": "retryable",
          "reason": "transient dependency failure",
          "userVisible": true,
          "evidenceRef": "evidence.gpu.retryable",
          "remediation": "retry with the same idempotency key"
        },
        {
          "name": "denied",
          "reason": "policy denied",
          "userVisible": true,
          "evidenceRef": "evidence.gpu.denied",
          "remediation": "request entitlement or policy change"
        }
      ],
      "support": {
        "owner": "gpu-module-team",
        "escalation": "platform-support",
        "diagnostics": [
          "gpu-pool-status",
          "operator-version-window",
          "dcgm-health-summary"
        ],
        "docsRef": "cloudring_core/modules/gpu/README.md",
        "evidence": [
          {
            "name": "support-diagnostics",
            "type": "support-evidence",
            "ref": "evidence.gpu.support-diagnostics"
          }
        ]
      },
      "evidenceBundles": [
        {
          "name": "gpu-module-evidence",
          "owner": "gpu-module-team",
          "claim": "GPU ownership, compatibility windows, disabled state, not-installed state, and OCS module surfaces are declared as metadata",
          "freshness": "review-before-publication",
          "redaction": "tenant-safe-receipts-only",
          "evidence": [
            {
              "name": "compatibility-bom",
              "type": "bom-window",
              "ref": "xCloudRING.compatibilityBOM"
            }
          ],
          "nonClaims": [
            "does not claim live GPU installation",
            "does not make GPU a foundation prerequisite"
          ],
          "reviewPath": "reviews.gpu.module"
        }
      ]
    }
  },
  "billing": {
    "apiVersion": "ocsv3.cloudring.io/v1alpha1",
    "kind": "BillingConnector",
    "metadata": {
      "name": "gpu-module-billing",
      "displayName": "GPU Module Billing",
      "owner": "gpu-module-team",
      "version": "v0.1.0"
    },
    "meters": [
      {
        "name": "gpu_allocated_hour",
        "unit": "gpu-hour",
        "aggregation": "sum"
      }
    ],
    "costMeters": [
      {
        "name": "gpu_allocated_hour_cost",
        "currency": "USD",
        "unitPrice": "0.00-example",
        "meterRef": "gpu_allocated_hour",
        "evidenceRef": "evidence.gpu.cost-meter"
      }
    ],
    "events": [
      {
        "name": "gpu-allocated-hour-recorded",
        "meter": "gpu_allocated_hour",
        "idempotent": true,
        "idempotencyKey": "usageEvent.id",
        "entitlementRef": "catalog.plan.optional",
        "attribution": "tenant.project.subscription",
        "replayPolicy": "dedupe-by-idempotency-key"
      }
    ]
  },
  "catalog": {
    "serviceClass": "gpu",
    "visibility": "tenant",
    "portability": "ocs-portable-gpu-module-contract",
    "plans": [
      {
        "name": "optional",
        "displayName": "Optional GPU",
        "billingMode": "metered",
        "quotaRef": "quota.gpu.optional"
      }
    ]
  },
  "configuration": {
    "schemaRef": "schemas/gpu.v1alpha1.json",
    "version": "v1alpha1"
  },
  "readiness": [
    {
      "name": "gpu-not-installed-ready",
      "type": "module-state",
      "target": "states.not-installed",
      "condition": "OptionalNotInstalled",
      "evidenceRef": "evidence.gpu.not-installed"
    },
    {
      "name": "gpu-disabled-until-foundation",
      "type": "foundation-gate",
      "target": "xCloudRING.foundationPrerequisite",
      "condition": "False",
      "evidenceRef": "evidence.gpu.disabled"
    }
  ],
  "tenantAccess": {
    "scope": "project",
    "entitlementRef": "catalog.plan.optional",
    "entitlements": [
      {
        "name": "optional-plan",
        "ref": "catalog.plan.optional",
        "scope": "project"
      }
    ],
    "permissions": [
      "gpu.read",
      "gpu.write",
      "gpu.support"
    ]
  },
  "durability": {
    "stateClass": "control-plane-metadata",
    "dataClasses": [
      "gpu-pool-intent",
      "quota-receipts",
      "usage-events"
    ],
    "backupPolicyRef": "backup.module.optional",
    "recoveryObjective": "restore-test-required-before-production",
    "recoveryEvidence": [
      {
        "name": "state-export",
        "type": "runbook-evidence",
        "ref": "evidence.gpu.export"
      }
    ]
  },
  "distribution": {
    "deploymentProfiles": [
      "optional-module",
      "provider-managed"
    ],
    "channels": [
      "service-store",
      "enterprise-marketplace"
    ],
    "infrastructureTargets": [
      "upstream-kubernetes"
    ],
    "updatePolicyRef": "updates.gpu.compatibility-reviewed"
  },
  "federation": {
    "modes": [
      "standalone",
      "connected"
    ],
    "messageBusRef": "federation.bus.gpu.events",
    "crossProviderScenarios": [
      "gpu-capacity-handoff",
      "support-handoff"
    ],
    "portabilityPolicyRef": "policy.gpu.ocs-portable-gpu-module"
  },
  "commercial": {
    "roles": [
      "vendor",
      "provider",
      "reseller"
    ],
    "revenueModel": "metered-gpu-usage",
    "licenseRef": "license.gpu.optional-module",
    "expiryBehavior": "service-stays-not-installed-or-disabled-until-provider-enables",
    "supportRef": "support.gpu.provider-handoff",
    "serviceProvenance": "module-owned-service-surface",
    "responsibilityMatrixRef": "responsibility.gpu.module-provider-and-runtime-dependency",
    "continuityPlanRef": "continuity.gpu.disable-export"
  },
  "xCloudRING": {
    "ownership": "optional-ocs-module",
    "foundationPrerequisite": false,
    "defaultState": "not-installed",
    "disabledStates": [
      "not-installed",
      "disabled",
      "blocked"
    ],
    "compatibilityBOM": [
      {
        "component": "Kubernetes",
        "window": "1.35.x",
        "required": true
      },
      {
        "component": "Cilium",
        "window": "1.19.x",
        "required": true
      },
      {
        "component": "Flux",
        "window": "2.x compatible with Kubernetes 1.35",
        "required": true
      },
      {
        "component": "KubeVirt",
        "window": "v1.8.x when GPU VMs are enabled",
        "required": false
      },
      {
        "component": "NVIDIA GPU Operator",
        "window": "v26.3.x",
        "required": false
      },
      {
        "component": "NVIDIA Network Operator",
        "window": "26.4.x when RDMA is enabled",
        "required": false
      },
      {
        "component": "policy engine",
        "window": "fail-closed admission policy compatible with OCS lifecycle gates",
        "required": true
      },
      {
        "component": "secret manager",
        "window": "secret-reference-only integration compatible with workload identity",
        "required": true
      }
    ],
    "nonClaims": [
      "no live GPU installation readiness",
      "no foundation-only dependency"
    ]
  }
}
