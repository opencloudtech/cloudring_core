{
  "apiVersion": "ocsv3.cloudring.io/v1alpha1",
  "kind": "ConnectorPackage",
  "metadata": {
    "name": "slurm-module-package",
    "displayName": "Slurm Module Package",
    "owner": "slurm-module-team",
    "version": "v0.1.0"
  },
  "service": {
    "apiVersion": "ocsv3.cloudring.io/v1alpha1",
    "kind": "ServiceConnector",
    "metadata": {
      "name": "slurm-module",
      "displayName": "Slurm Module",
      "owner": "slurm-module-team",
      "version": "v0.1.0"
    },
    "spec": {
      "capabilities": [
        {
          "class": "slurm",
          "name": "slurm-partition",
          "description": "Optional Slurm partition, account, QOS, and accounting contract exposed through OCSv3 metadata."
        }
      ],
      "dependencies": [
        {
          "id": "slurm-26-05-window",
          "capabilityClass": "slurm-runtime",
          "role": "optional scheduler runtime",
          "portability": "ocs-portable-slurm-26.05-window"
        },
        {
          "id": "kubernetes-1-35-window",
          "capabilityClass": "kubernetes",
          "role": "upstream Kubernetes API target for module control",
          "portability": "ocs-portable-kubernetes-1.35-patch-window"
        },
        {
          "id": "flux-2-window",
          "capabilityClass": "gitops",
          "role": "module delivery contract",
          "portability": "ocs-portable-flux-2-compatible"
        },
        {
          "id": "policy-engine-window",
          "capabilityClass": "policy",
          "role": "account and QOS admission policy",
          "portability": "ocs-portable-policy-engine-contract"
        },
        {
          "id": "secret-manager-window",
          "capabilityClass": "secret-manager",
          "role": "referenced credentials only",
          "portability": "ocs-portable-secret-reference-contract"
        }
      ],
      "lifecycle": [
        {
          "name": "provision",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "metadata.uid"
        },
        {
          "name": "enable",
          "verb": "Enable",
          "idempotent": true,
          "idempotencyKey": "module.request.id"
        },
        {
          "name": "disable",
          "verb": "Disable",
          "idempotent": true,
          "idempotencyKey": "module.request.id"
        },
        {
          "name": "export",
          "verb": "Export",
          "idempotent": true,
          "idempotencyKey": "export.request.id"
        },
        {
          "name": "delete",
          "verb": "Delete",
          "idempotent": true,
          "idempotencyKey": "delete.request.id",
          "rollbackRef": "lifecycle.rollback"
        },
        {
          "name": "backup",
          "verb": "Backup",
          "idempotent": true,
          "idempotencyKey": "backup.request.id"
        },
        {
          "name": "restore",
          "verb": "Restore",
          "idempotent": true,
          "idempotencyKey": "restore.request.id"
        },
        {
          "name": "retry",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "retry.request.id",
          "rollbackRef": "lifecycle.rollback"
        },
        {
          "name": "rollback",
          "verb": "Rollback",
          "idempotent": true,
          "idempotencyKey": "rollback.request.id"
        }
      ],
      "automation": [
        {
          "name": "publish-slurm-partition-contract",
          "description": "Publish Slurm partition metadata after compatibility and rollback review.",
          "actionRef": "lifecycle.enable"
        },
        {
          "name": "disable-slurm-module",
          "description": "Return Slurm to disabled or not-installed state without foundation impact.",
          "actionRef": "lifecycle.disable"
        }
      ],
      "usageMeters": [
        {
          "name": "slurm_partition_hour",
          "unit": "partition-hour",
          "aggregation": "sum"
        }
      ],
      "billing": {
        "connectorRef": "slurm-module-billing",
        "meters": [
          {
            "name": "slurm_partition_hour",
            "unit": "partition-hour",
            "aggregation": "sum"
          }
        ]
      },
      "portalModules": [
        {
          "name": "slurm-overview",
          "slot": "service.detail",
          "route": "/services/slurm",
          "apiRef": "service.api.slurm.partitions",
          "hostRef": "ui.slurm.host",
          "mountRef": "mount.slurm.overview",
          "permissions": [
            "slurm.read",
            "slurm.write"
          ]
        }
      ],
      "ui": {
        "embedRef": "ui.slurm.bundle",
        "contextSchemaRef": "schemas/slurm-ui-context.v1alpha1.json",
        "hostAuthority": [
          "navigation",
          "identity",
          "policy",
          "support"
        ],
        "extensionActions": [
          "slurm.module.enable",
          "slurm.module.disable"
        ],
        "moduleHost": {
          "host": "cloudring-provider-portal",
          "runtime": "module-federation",
          "mountRef": "mount.slurm.overview",
          "versionRange": ">=0.1.0 <1.0.0",
          "integrityRef": "evidence.slurm.ui.integrity",
          "sandbox": "tenant-iam-context",
          "allowedEvents": [
            "slurm.module.enable.requested",
            "slurm.module.disable.requested"
          ],
          "requiredContext": [
            "tenant",
            "project",
            "iam.subject",
            "entitlements"
          ]
        },
        "evidence": [
          {
            "name": "ui-integrity",
            "type": "integrity-evidence",
            "ref": "evidence.slurm.ui.integrity"
          }
        ]
      },
      "analyticsEvents": [
        {
          "name": "slurm.module.state.changed",
          "trigger": "portal-module-action",
          "subject": "tenant.project.slurm-module",
          "properties": [
            "tenantId",
            "projectId",
            "state",
            "result"
          ],
          "evidenceRef": "evidence.slurm.analytics.state"
        }
      ],
      "kubernetesBindings": [
        {
          "group": "slurm.cloudring.io",
          "version": "v1alpha1",
          "kind": "SlurmPartition",
          "plural": "slurmpartitions",
          "scope": "Namespaced",
          "crdRef": "crd.slurmpartitions.slurm.cloudring",
          "statusPath": "status.conditions",
          "condition": "Ready"
        }
      ],
      "gatewayRoutes": [
        {
          "name": "slurm-api",
          "parentRef": "gateway-api.parent.platform-services",
          "hostnames": [
            "slurm.service-api.contract"
          ],
          "rules": [
            "tenant-slurm-api"
          ],
          "evidenceRef": "evidence.slurm.gateway-route"
        }
      ],
      "secrets": {
        "workloadIdentityRef": "workloadidentity.slurm-controller",
        "secretRefs": [
          {
            "name": "slurm-accounting-secret-reference",
            "ref": "secretref.slurm.accounting",
            "purpose": "accounting access by reference",
            "rotation": "operator-initiated"
          }
        ]
      },
      "policies": [
        {
          "name": "slurm-entitlement",
          "class": "authorization",
          "decisionRef": "policy.slurm.entitlement",
          "evidenceRef": "evidence.slurm.policy.entitlement"
        }
      ],
      "dataLifecycle": {
        "export": {
          "actionRef": "lifecycle.export",
          "format": "ocs-slurm-module-receipts",
          "evidenceRef": "evidence.slurm.export"
        },
        "delete": {
          "actionRef": "lifecycle.delete",
          "format": "ocs-slurm-delete-receipt",
          "evidenceRef": "evidence.slurm.delete"
        }
      },
      "states": [
        {
          "name": "not-installed",
          "reason": "Slurm module is optional and absent from foundation-only deployments",
          "userVisible": true,
          "evidenceRef": "evidence.slurm.not-installed",
          "remediation": "install only after foundation, account, QOS, backup, and rollback evidence pass"
        },
        {
          "name": "disabled",
          "reason": "Slurm module is installed but disabled by provider policy",
          "userVisible": true,
          "evidenceRef": "evidence.slurm.disabled",
          "remediation": "enable through OCS lifecycle after compatibility review"
        },
        {
          "name": "degraded",
          "reason": "Slurm controller, accounting, or policy dependency is unavailable",
          "userVisible": true,
          "evidenceRef": "evidence.slurm.degraded",
          "remediation": "keep partition admission closed until dependency evidence recovers"
        },
        {
          "name": "blocked",
          "reason": "compatibility, entitlement, backup, or rollback evidence is missing",
          "userVisible": true,
          "evidenceRef": "evidence.slurm.blocked",
          "remediation": "clear the missing gate before publishing Slurm partitions"
        },
        {
          "name": "ready",
          "reason": "controller ready",
          "userVisible": true,
          "evidenceRef": "evidence.slurm.ready",
          "remediation": "continue normal operation"
        },
        {
          "name": "retryable",
          "reason": "transient dependency failure",
          "userVisible": true,
          "evidenceRef": "evidence.slurm.retryable",
          "remediation": "retry with the same idempotency key"
        },
        {
          "name": "denied",
          "reason": "policy denied",
          "userVisible": true,
          "evidenceRef": "evidence.slurm.denied",
          "remediation": "request entitlement or policy change"
        }
      ],
      "support": {
        "owner": "slurm-module-team",
        "escalation": "platform-support",
        "diagnostics": [
          "partition-status",
          "accounting-status",
          "qos-policy-summary"
        ],
        "docsRef": "cloudring_core/modules/slurm/README.md",
        "evidence": [
          {
            "name": "support-diagnostics",
            "type": "support-evidence",
            "ref": "evidence.slurm.support-diagnostics"
          }
        ]
      },
      "evidenceBundles": [
        {
          "name": "slurm-module-evidence",
          "owner": "slurm-module-team",
          "claim": "Slurm ownership, compatibility windows, disabled state, not-installed state, and OCS module surfaces are declared as metadata",
          "freshness": "review-before-publication",
          "redaction": "tenant-safe-receipts-only",
          "evidence": [
            {
              "name": "compatibility-bom",
              "type": "bom-window",
              "ref": "xCloudRING.compatibilityBOM"
            }
          ],
          "nonClaims": [
            "does not claim live Slurm installation",
            "does not make Slurm a foundation prerequisite"
          ],
          "reviewPath": "reviews.slurm.module"
        }
      ]
    }
  },
  "billing": {
    "apiVersion": "ocsv3.cloudring.io/v1alpha1",
    "kind": "BillingConnector",
    "metadata": {
      "name": "slurm-module-billing",
      "displayName": "Slurm Module Billing",
      "owner": "slurm-module-team",
      "version": "v0.1.0"
    },
    "meters": [
      {
        "name": "slurm_partition_hour",
        "unit": "partition-hour",
        "aggregation": "sum"
      }
    ],
    "costMeters": [
      {
        "name": "slurm_partition_hour_cost",
        "currency": "USD",
        "unitPrice": "0.00-example",
        "meterRef": "slurm_partition_hour",
        "evidenceRef": "evidence.slurm.cost-meter"
      }
    ],
    "events": [
      {
        "name": "slurm-partition-hour-recorded",
        "meter": "slurm_partition_hour",
        "idempotent": true,
        "idempotencyKey": "usageEvent.id",
        "entitlementRef": "catalog.plan.optional",
        "attribution": "tenant.project.subscription",
        "replayPolicy": "dedupe-by-idempotency-key"
      }
    ]
  },
  "catalog": {
    "serviceClass": "slurm",
    "visibility": "tenant",
    "portability": "ocs-portable-slurm-module-contract",
    "plans": [
      {
        "name": "optional",
        "displayName": "Optional Slurm",
        "billingMode": "metered",
        "quotaRef": "quota.slurm.optional"
      }
    ]
  },
  "configuration": {
    "schemaRef": "schemas/slurm.v1alpha1.json",
    "version": "v1alpha1"
  },
  "readiness": [
    {
      "name": "slurm-not-installed-ready",
      "type": "module-state",
      "target": "states.not-installed",
      "condition": "OptionalNotInstalled",
      "evidenceRef": "evidence.slurm.not-installed"
    },
    {
      "name": "slurm-disabled-until-foundation",
      "type": "foundation-gate",
      "target": "xCloudRING.foundationPrerequisite",
      "condition": "False",
      "evidenceRef": "evidence.slurm.disabled"
    }
  ],
  "tenantAccess": {
    "scope": "project",
    "entitlementRef": "catalog.plan.optional",
    "entitlements": [
      {
        "name": "optional-plan",
        "ref": "catalog.plan.optional",
        "scope": "project"
      }
    ],
    "permissions": [
      "slurm.read",
      "slurm.write",
      "slurm.support"
    ]
  },
  "durability": {
    "stateClass": "control-plane-metadata",
    "dataClasses": [
      "slurm-partition-intent",
      "accounting-receipts",
      "usage-events"
    ],
    "backupPolicyRef": "backup.module.optional",
    "recoveryObjective": "restore-test-required-before-production",
    "recoveryEvidence": [
      {
        "name": "state-export",
        "type": "runbook-evidence",
        "ref": "evidence.slurm.export"
      }
    ]
  },
  "distribution": {
    "deploymentProfiles": [
      "optional-module",
      "provider-managed"
    ],
    "channels": [
      "service-store",
      "enterprise-marketplace"
    ],
    "infrastructureTargets": [
      "upstream-kubernetes"
    ],
    "updatePolicyRef": "updates.slurm.compatibility-reviewed"
  },
  "federation": {
    "modes": [
      "standalone",
      "connected"
    ],
    "messageBusRef": "federation.bus.slurm.events",
    "crossProviderScenarios": [
      "slurm-accounting-handoff",
      "support-handoff"
    ],
    "portabilityPolicyRef": "policy.slurm.ocs-portable-slurm-module"
  },
  "commercial": {
    "roles": [
      "vendor",
      "provider",
      "reseller"
    ],
    "revenueModel": "metered-slurm-partition-usage",
    "licenseRef": "license.slurm.optional-module",
    "expiryBehavior": "service-stays-not-installed-or-disabled-until-provider-enables",
    "supportRef": "support.slurm.provider-handoff",
    "serviceProvenance": "module-owned-service-surface",
    "responsibilityMatrixRef": "responsibility.slurm.module-provider-and-runtime-dependency",
    "continuityPlanRef": "continuity.slurm.disable-export"
  },
  "xCloudRING": {
    "ownership": "optional-ocs-module",
    "foundationPrerequisite": false,
    "defaultState": "not-installed",
    "disabledStates": [
      "not-installed",
      "disabled",
      "blocked"
    ],
    "compatibilityBOM": [
      {
        "component": "Slurm",
        "window": "26.05.x",
        "required": false
      },
      {
        "component": "Kubernetes",
        "window": "1.35.x for OCS control surfaces",
        "required": true
      },
      {
        "component": "Flux",
        "window": "2.x compatible with Kubernetes 1.35",
        "required": true
      },
      {
        "component": "policy engine",
        "window": "fail-closed account and QOS policy compatible with OCS lifecycle gates",
        "required": true
      },
      {
        "component": "secret manager",
        "window": "secret-reference-only integration compatible with workload identity",
        "required": true
      }
    ],
    "nonClaims": [
      "no live Slurm installation readiness",
      "no foundation-only dependency"
    ]
  }
}
