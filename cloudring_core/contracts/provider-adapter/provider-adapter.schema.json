{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "provider-adapter.schema.json",
  "title": "CloudRING Core Provider Adapter Contract",
  "type": "object",
  "required": [
    "schemaVersion",
    "adapterId",
    "displayName",
    "syntheticOnly",
    "capabilities",
    "inventoryClasses",
    "preflightClasses",
    "planClasses",
    "evidenceClasses",
    "sourceSafety"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "cloudring.provider-adapter/v1"
    },
    "adapterId": {
      "type": "string",
      "pattern": "^synthetic-[a-z0-9-]+$"
    },
    "displayName": {
      "type": "string",
      "minLength": 3
    },
    "syntheticOnly": {
      "type": "boolean",
      "const": true
    },
    "capabilities": {
      "type": "array",
      "items": {
        "enum": [
          "inventory",
          "preflight",
          "plan",
          "evidence"
        ]
      },
      "minItems": 4,
      "uniqueItems": true
    },
    "inventoryClasses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/classDeclaration"
      }
    },
    "preflightClasses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/classDeclaration"
      }
    },
    "planClasses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/classDeclaration"
      }
    },
    "evidenceClasses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/classDeclaration"
      }
    },
    "sourceSafety": {
      "type": "object",
      "required": [
        "syntheticFixture",
        "containsProviderImplementation",
        "containsRealInventory",
        "containsDeploymentValues"
      ],
      "additionalProperties": false,
      "properties": {
        "syntheticFixture": {
          "type": "boolean",
          "const": true
        },
        "containsProviderImplementation": {
          "type": "boolean",
          "const": false
        },
        "containsRealInventory": {
          "type": "boolean",
          "const": false
        },
        "containsDeploymentValues": {
          "type": "boolean",
          "const": false
        }
      }
    }
  },
  "$defs": {
    "classDeclaration": {
      "type": "object",
      "required": [
        "class",
        "description",
        "requiredFields",
        "sample"
      ],
      "additionalProperties": false,
      "properties": {
        "class": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "description": {
          "type": "string",
          "minLength": 10
        },
        "requiredFields": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-zA-Z0-9]*$"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "sample": {
          "type": "object"
        }
      }
    }
  }
}
