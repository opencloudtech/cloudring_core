{
  "apiVersion": "ocsv3.cloudring.io/v1alpha1",
  "kind": "ConnectorPackage",
  "metadata": {
    "name": "network-module-package",
    "displayName": "Network Module Package",
    "owner": "network-module-team",
    "version": "v0.1.0"
  },
  "service": {
    "apiVersion": "ocsv3.cloudring.io/v1alpha1",
    "kind": "ServiceConnector",
    "metadata": {
      "name": "network-module",
      "displayName": "Network Module",
      "owner": "network-module-team",
      "version": "v0.1.0"
    },
    "spec": {
      "executionProfile": "local",
      "productAPI": {
        "ref": "service.api.network.v1alpha1",
        "version": "v1alpha1",
        "protocol": "https-json"
      },
      "capabilities": [
        {
          "class": "network",
          "name": "tenant-network",
          "description": "Tenant-scoped virtual network, route, ingress, and policy lifecycle"
        },
        {
          "class": "gateway-api",
          "name": "portable-gateway-route",
          "description": "Gateway API parent and route contracts without single-provider load balancer bindings"
        },
        {
          "class": "cilium-network-policy",
          "name": "cilium-policy-class",
          "description": "Cilium network policy dependency class expressed as a portable Kubernetes CNI policy contract"
        }
      ],
      "dependencies": [
        {
          "id": "gateway-api",
          "capabilityClass": "gateway-api",
          "role": "north-south-routing",
          "portability": "gateway-api-standard-contract",
          "productAPIRef": "service.api.gateway-api.v1",
          "versionRange": ">=1.0.0,<2.0.0",
          "compatibilityPolicyRef": "policy.compatibility.gateway-api"
        },
        {
          "id": "cilium-policy",
          "capabilityClass": "cilium-network-policy",
          "role": "east-west-policy",
          "portability": "kubernetes-cni-policy-contract",
          "productAPIRef": "service.api.cilium-network-policy.v1",
          "versionRange": ">=1.0.0,<2.0.0",
          "compatibilityPolicyRef": "policy.compatibility.cilium-network-policy"
        }
      ],
      "lifecycle": [
        {
          "name": "provision",
          "applicability": "supported",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "metadata.uid"
        },
        {
          "name": "hold",
          "applicability": "not_applicable",
          "reason": "tenant network resources remain active until deprovisioned"
        },
        {
          "name": "resume",
          "applicability": "not_applicable",
          "reason": "hold is not supported for tenant network resources"
        },
        {
          "name": "resize",
          "applicability": "not_applicable",
          "reason": "network capacity follows quota and policy configuration"
        },
        {
          "name": "updatePolicy",
          "applicability": "supported",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "policy.generation",
          "rollbackRef": "support.restoreLastAcceptedPolicy"
        },
        {
          "name": "export",
          "applicability": "supported",
          "verb": "Export",
          "idempotent": true,
          "idempotencyKey": "export.request.id"
        },
        {
          "name": "deprovision",
          "applicability": "supported",
          "verb": "Delete",
          "idempotent": true,
          "idempotencyKey": "delete.request.id",
          "rollbackRef": "lifecycle.rollback"
        },
        {
          "name": "backup",
          "applicability": "supported",
          "verb": "Backup",
          "idempotent": true,
          "idempotencyKey": "backup.request.id"
        },
        {
          "name": "restore",
          "applicability": "supported",
          "verb": "Restore",
          "idempotent": true,
          "idempotencyKey": "restore.request.id"
        },
        {
          "name": "retry",
          "applicability": "supported",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "retry.request.id",
          "rollbackRef": "lifecycle.rollback"
        },
        {
          "name": "rollback",
          "applicability": "supported",
          "verb": "Rollback",
          "idempotent": true,
          "idempotencyKey": "rollback.request.id"
        }
      ],
      "automation": [
        {
          "name": "apply-network",
          "description": "Apply tenant network and Gateway API route intent through the module connector",
          "actionRef": "lifecycle.provision"
        },
        {
          "name": "apply-policy",
          "description": "Apply Cilium-compatible tenant policy intent through the module connector",
          "actionRef": "lifecycle.updatePolicy"
        }
      ],
      "usageMeters": [
        {
          "name": "network_route_hours",
          "unit": "route-hour",
          "aggregation": "sum"
        },
        {
          "name": "policy_rule_hours",
          "unit": "rule-hour",
          "aggregation": "sum"
        }
      ],
      "billing": {
        "applicability": "supported",
        "connectorRef": "network-module-billing",
        "meters": [
          {
            "name": "network_route_hours",
            "unit": "route-hour",
            "aggregation": "sum"
          },
          {
            "name": "policy_rule_hours",
            "unit": "rule-hour",
            "aggregation": "sum"
          }
        ]
      },
      "portalModules": [
        {
          "name": "network-overview",
          "slot": "service.detail",
          "route": "/services/network",
          "apiRef": "service.api.network.routes",
          "hostRef": "ui.network.host",
          "mountRef": "mount.network.overview",
          "permissions": [
            "network.read",
            "network.write"
          ]
        }
      ],
      "ui": {
        "embedRef": "ui.network.bundle",
        "contextSchemaRef": "schemas/network-ui-context.v1alpha1.json",
        "hostAuthority": [
          "navigation",
          "identity",
          "policy"
        ],
        "extensionActions": [
          "network.create",
          "network.policy.update",
          "network.delete"
        ],
        "moduleHost": {
          "host": "cloudring-provider-portal",
          "runtime": "module-federation",
          "mountRef": "mount.network.overview",
          "versionRange": ">=0.1.0 <1.0.0",
          "signatureRef": "evidence.network.ui.signature",
          "integrityRef": "evidence.network.ui.integrity",
          "sandbox": "tenant-iam-context",
          "allowedEvents": [
            "network.create.requested",
            "network.policy.update.requested",
            "network.delete.requested"
          ],
          "requiredContext": [
            "tenant",
            "project",
            "iam.subject",
            "locale",
            "theme"
          ]
        },
        "evidence": [
          {
            "name": "ui-host-shell-certification",
            "type": "certification-evidence",
            "ref": "evidence.network.ui.host-shell"
          }
        ]
      },
      "analyticsEvents": [
        {
          "name": "network.route.apply.submitted",
          "trigger": "portal-module-action",
          "subject": "tenant.project.network-order",
          "properties": [
            "tenantId",
            "projectId",
            "plan",
            "routeKind",
            "result"
          ],
          "evidenceRef": "evidence.network.analytics"
        }
      ],
      "kubernetesBindings": [
        {
          "group": "networking.cloudring.io",
          "version": "v1alpha1",
          "kind": "TenantNetwork",
          "plural": "tenantnetworks",
          "scope": "Namespaced",
          "crdRef": "crd.tenantnetworks.networking.cloudring.io",
          "statusPath": "status.conditions",
          "condition": "Ready"
        },
        {
          "group": "gateway.networking.k8s.io",
          "version": "v1",
          "kind": "HTTPRoute",
          "plural": "httproutes",
          "scope": "Namespaced",
          "crdRef": "crd.httproutes.gateway.networking.k8s.io",
          "statusPath": "status.parents.conditions",
          "condition": "Accepted"
        }
      ],
      "gatewayRoutes": [
        {
          "name": "network-api",
          "parentRef": "gateway-api.parent.platform-services",
          "hostnames": [
            "network.services.example"
          ],
          "rules": [
            "tenant-network-api"
          ],
          "evidenceRef": "evidence.network.gateway-route"
        }
      ],
      "secrets": {
        "workloadIdentityRef": "workloadidentity.network-controller",
        "secretRefs": [
          {
            "name": "controller-identity-reference",
            "ref": "identityref.network.controller",
            "purpose": "module controller authentication",
            "rotation": "workload-identity-managed"
          }
        ]
      },
      "policies": [
        {
          "name": "tenant-network-isolation",
          "class": "tenant-isolation",
          "decisionRef": "policy.network.tenant-isolation",
          "evidenceRef": "evidence.network.policy"
        }
      ],
      "dataLifecycle": {
        "export": {
          "actionRef": "lifecycle.export",
          "format": "ocs-network-topology-archive",
          "evidenceRef": "evidence.network.export"
        },
        "delete": {
          "actionRef": "lifecycle.deprovision",
          "format": "tenant-network-delete-receipt",
          "evidenceRef": "evidence.network.delete"
        }
      },
      "states": [
        {
          "name": "degraded",
          "reason": "gateway or CNI policy capability is unavailable",
          "userVisible": true,
          "evidenceRef": "evidence.network.degraded",
          "remediation": "retry after dependency recovery or remove affected route intent"
        },
        {
          "name": "denied",
          "reason": "IAM or tenant policy denies the requested network operation",
          "userVisible": true,
          "evidenceRef": "evidence.network.denied",
          "remediation": "resolve entitlement or policy before retry"
        },
        {
          "name": "blocked",
          "reason": "policy denial or missing entitlement blocks reconciliation",
          "userVisible": true,
          "evidenceRef": "evidence.network.blocked",
          "remediation": "resolve policy or entitlement before retry"
        },
        {
          "name": "ready",
          "reason": "controller ready",
          "userVisible": true,
          "evidenceRef": "evidence.network.ready",
          "remediation": "continue normal operation"
        },
        {
          "name": "retryable",
          "reason": "transient dependency failure",
          "userVisible": true,
          "evidenceRef": "evidence.network.retryable",
          "remediation": "retry with the same idempotency key"
        }
      ],
      "support": {
        "owner": "network-module-team",
        "escalation": "provider-support",
        "diagnostics": [
          "network-status",
          "gateway-route-status",
          "policy-status"
        ],
        "docsRef": "docs/modules/network.md",
        "evidence": [
          {
            "name": "support-diagnostics",
            "type": "support-evidence",
            "ref": "evidence.network.support-diagnostics"
          }
        ]
      },
      "evidenceBundles": [
        {
          "name": "network-module-evidence",
          "owner": "network-module-team",
          "claim": "network UI, billing, support, readiness, durability, degraded, and denied states are declared through OCSv3 metadata",
          "freshness": "review-before-publication",
          "redaction": "support-safe-summary-only",
          "evidence": [
            {
              "name": "support-diagnostics",
              "type": "support-evidence",
              "ref": "evidence.network.support-diagnostics"
            }
          ],
          "nonClaims": [
            "does not claim live deployment readiness",
            "does not bind to a single-provider load balancer"
          ],
          "reviewPath": "support.owner.review"
        }
      ]
    }
  },
  "billing": {
    "apiVersion": "ocsv3.cloudring.io/v1alpha1",
    "kind": "BillingConnector",
    "metadata": {
      "name": "network-module-billing",
      "displayName": "Network Module Billing",
      "owner": "network-module-team",
      "version": "v0.1.0"
    },
    "meters": [
      {
        "name": "network_route_hours",
        "unit": "route-hour",
        "aggregation": "sum"
      },
      {
        "name": "policy_rule_hours",
        "unit": "rule-hour",
        "aggregation": "sum"
      }
    ],
    "costMeters": [
      {
        "name": "network_route_month",
        "currency": "USD",
        "unitPrice": "0.00-example",
        "meterRef": "network_route_hours",
        "evidenceRef": "evidence.network.route-cost-meter"
      },
      {
        "name": "network_policy_rule_month",
        "currency": "USD",
        "unitPrice": "0.00-example",
        "meterRef": "policy_rule_hours",
        "evidenceRef": "evidence.network.policy-cost-meter"
      }
    ],
    "events": [
      {
        "name": "network-route-usage-recorded",
        "meter": "network_route_hours",
        "idempotent": true,
        "idempotencyKey": "usageEvent.id",
        "entitlementRef": "catalog.plan.standard",
        "attribution": "tenant.project.subscription",
        "replayPolicy": "dedupe-by-idempotency-key"
      },
      {
        "name": "network-policy-usage-recorded",
        "meter": "policy_rule_hours",
        "idempotent": true,
        "idempotencyKey": "usageEvent.id",
        "entitlementRef": "catalog.plan.standard",
        "attribution": "tenant.project.subscription",
        "replayPolicy": "dedupe-by-idempotency-key"
      }
    ]
  },
  "catalog": {
    "serviceClass": "network",
    "visibility": "tenant",
    "portability": "gateway-api-and-cni-policy-contract",
    "plans": [
      {
        "name": "standard",
        "displayName": "Standard Network",
        "billingMode": "metered",
        "quotaRef": "quota.network.standard"
      }
    ]
  },
  "configuration": {
    "schemaRef": "schemas/network.v1alpha1.json",
    "version": "v1alpha1"
  },
  "readiness": [
    {
      "name": "network-controller-ready",
      "type": "kubernetes-condition",
      "target": "TenantNetwork.status.conditions",
      "condition": "Ready",
      "evidenceRef": "support.diagnostics.network-status"
    },
    {
      "name": "gateway-route-accepted",
      "type": "gateway-api-condition",
      "target": "HTTPRoute.status.parents.conditions",
      "condition": "Accepted",
      "evidenceRef": "support.diagnostics.gateway-route-status"
    }
  ],
  "tenantAccess": {
    "scope": "project",
    "entitlementRef": "catalog.plan.standard",
    "entitlements": [
      {
        "name": "standard-plan",
        "ref": "catalog.plan.standard",
        "scope": "project"
      }
    ],
    "permissions": [
      "network.read",
      "network.write"
    ]
  },
  "durability": {
    "stateClass": "declarative-state",
    "dataClasses": [
      "tenant-network-intent",
      "gateway-route-intent",
      "policy-intent",
      "usage-events"
    ],
    "backupPolicyRef": "backup.network.intent-standard",
    "recoveryObjective": "restore-test-required-before-production",
    "recoveryEvidence": [
      {
        "name": "network-intent-restore-drill",
        "type": "runbook-evidence",
        "ref": "evidence.network.restore"
      }
    ]
  },
  "distribution": {
    "deploymentProfiles": [
      "self-hosted",
      "provider-managed",
      "edge-zone"
    ],
    "channels": [
      "open-source",
      "enterprise-marketplace"
    ],
    "infrastructureTargets": [
      "kubernetes",
      "private-cloud",
      "public-cloud",
      "edge"
    ],
    "updatePolicyRef": "updates.network.compatibility-reviewed"
  },
  "federation": {
    "applicability": "supported",
    "modes": [
      "standalone",
      "connected",
      "federated"
    ],
    "messageBusRef": "federation.bus.ocsv3.events",
    "crossProviderScenarios": [
      "route-migration",
      "policy-portability",
      "support-handoff"
    ],
    "portabilityPolicyRef": "policy.network.no-provider-lock-in"
  },
  "commercial": {
    "applicability": "supported",
    "roles": [
      "vendor",
      "provider",
      "reseller"
    ],
    "revenueModel": "metered-usage-with-revenue-share",
    "licenseRef": "license.network.enterprise-marketplace",
    "expiryBehavior": "service-keeps-running-updates-stop-except-critical-fixes",
    "supportRef": "support.network.provider-handoff",
    "serviceProvenance": "first-party-provider-managed",
    "responsibilityMatrixRef": "responsibility.network.provider-and-partner",
    "continuityPlanRef": "continuity.network.intent-restorable"
  }
}
