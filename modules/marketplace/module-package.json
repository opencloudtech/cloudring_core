{
  "apiVersion": "ocsv3.cloudring.io/v1alpha1",
  "kind": "ConnectorPackage",
  "metadata": {
    "name": "marketplace-module-package",
    "displayName": "Marketplace Module Package",
    "owner": "marketplace-module-team",
    "version": "v0.1.0"
  },
  "service": {
    "apiVersion": "ocsv3.cloudring.io/v1alpha1",
    "kind": "ServiceConnector",
    "metadata": {
      "name": "marketplace-module",
      "displayName": "Marketplace Module",
      "owner": "marketplace-module-team",
      "version": "v0.1.0"
    },
    "spec": {
      "capabilities": [
        {
          "class": "marketplace",
          "name": "module-listing",
          "description": "Catalog listing, entitlement, order handoff, settlement receipt, export, and delete workflow contract."
        }
      ],
      "dependencies": [
        {
          "id": "marketplace-storefront-adapter-contract",
          "capabilityClass": "marketplace-storefront",
          "role": "portable storefront and fulfillment adapter",
          "portability": "ocs-portable-marketplace-storefront-contract"
        }
      ],
      "lifecycle": [
        {
          "name": "provision",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "metadata.uid"
        },
        {
          "name": "publish",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "listing.version.id"
        },
        {
          "name": "order",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "order.request.id"
        },
        {
          "name": "settle",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "settlement.run.id"
        },
        {
          "name": "export",
          "verb": "Export",
          "idempotent": true,
          "idempotencyKey": "export.request.id"
        },
        {
          "name": "delete",
          "verb": "Delete",
          "idempotent": true,
          "idempotencyKey": "delete.request.id",
          "rollbackRef": "lifecycle.rollback"
        },
        {
          "name": "backup",
          "verb": "Backup",
          "idempotent": true,
          "idempotencyKey": "backup.request.id"
        },
        {
          "name": "restore",
          "verb": "Restore",
          "idempotent": true,
          "idempotencyKey": "restore.request.id"
        },
        {
          "name": "retry",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "retry.request.id",
          "rollbackRef": "lifecycle.rollback"
        },
        {
          "name": "rollback",
          "verb": "Rollback",
          "idempotent": true,
          "idempotencyKey": "rollback.request.id"
        }
      ],
      "automation": [
        {
          "name": "publish-listing",
          "description": "Publish reviewed listing metadata through the marketplace contract.",
          "actionRef": "lifecycle.publish"
        },
        {
          "name": "record-order",
          "description": "Record a portable order handoff and entitlement receipt.",
          "actionRef": "lifecycle.order"
        },
        {
          "name": "settle-revenue-share",
          "description": "Record settlement evidence without external payment implementation coupling.",
          "actionRef": "lifecycle.settle"
        }
      ],
      "usageMeters": [
        {
          "name": "listing_hours",
          "unit": "listing-hour",
          "aggregation": "sum"
        },
        {
          "name": "order_events",
          "unit": "order-event",
          "aggregation": "sum"
        }
      ],
      "billing": {
        "connectorRef": "marketplace-module-billing",
        "meters": [
          {
            "name": "listing_hours",
            "unit": "listing-hour",
            "aggregation": "sum"
          },
          {
            "name": "order_events",
            "unit": "order-event",
            "aggregation": "sum"
          }
        ]
      },
      "portalModules": [
        {
          "name": "marketplace-overview",
          "slot": "service.detail",
          "route": "/services/marketplace",
          "apiRef": "service.api.marketplace.listings",
          "hostRef": "ui.marketplace.host",
          "mountRef": "mount.marketplace.overview",
          "permissions": [
            "marketplace.read",
            "marketplace.write"
          ]
        }
      ],
      "ui": {
        "embedRef": "ui.marketplace.bundle",
        "contextSchemaRef": "schemas/marketplace-ui-context.v1alpha1.json",
        "hostAuthority": [
          "navigation",
          "identity",
          "policy",
          "billing",
          "support"
        ],
        "extensionActions": [
          "marketplace.listing.publish",
          "marketplace.order.record",
          "marketplace.settlement.record",
          "marketplace.export",
          "marketplace.delete"
        ],
        "moduleHost": {
          "host": "cloudring-provider-portal",
          "runtime": "module-federation",
          "mountRef": "mount.marketplace.overview",
          "versionRange": ">=0.1.0 <1.0.0",
          "integrityRef": "evidence.marketplace.ui.integrity",
          "sandbox": "tenant-iam-context",
          "allowedEvents": [
            "marketplace.listing.publish.requested",
            "marketplace.order.record.requested",
            "marketplace.settlement.record.requested",
            "marketplace.export.requested",
            "marketplace.delete.requested"
          ],
          "requiredContext": [
            "tenant",
            "project",
            "iam.subject",
            "entitlements"
          ]
        },
        "evidence": [
          {
            "name": "ui-integrity",
            "type": "integrity-evidence",
            "ref": "evidence.marketplace.ui.integrity"
          }
        ]
      },
      "analyticsEvents": [
        {
          "name": "marketplace.listing.action.submitted",
          "trigger": "portal-module-action",
          "subject": "tenant.project.marketplace-listing",
          "properties": [
            "tenantId",
            "projectId",
            "operation",
            "result"
          ],
          "evidenceRef": "evidence.marketplace.analytics.listing"
        }
      ],
      "kubernetesBindings": [
        {
          "group": "marketplace.cloudring.io",
          "version": "v1alpha1",
          "kind": "MarketplaceListing",
          "plural": "marketplacelistings",
          "scope": "Namespaced",
          "crdRef": "crd.marketplacelistings.marketplace.cloudring",
          "statusPath": "status.conditions",
          "condition": "Ready"
        }
      ],
      "gatewayRoutes": [
        {
          "name": "marketplace-api",
          "parentRef": "gateway-api.parent.platform-services",
          "hostnames": [
            "marketplace.service-api.contract"
          ],
          "rules": [
            "tenant-marketplace-api"
          ],
          "evidenceRef": "evidence.marketplace.gateway-route"
        }
      ],
      "secrets": {
        "workloadIdentityRef": "workloadidentity.marketplace-controller",
        "secretRefs": [
          {
            "name": "storefront-adapter-reference",
            "ref": "secretref.marketplace.storefront-account",
            "purpose": "storefront adapter access by reference",
            "rotation": "operator-initiated"
          }
        ]
      },
      "policies": [
        {
          "name": "tenant-marketplace-entitlement",
          "class": "authorization",
          "decisionRef": "policy.marketplace.entitlement",
          "evidenceRef": "evidence.marketplace.policy.entitlement"
        }
      ],
      "dataLifecycle": {
        "export": {
          "actionRef": "lifecycle.export",
          "format": "ocs-marketplace-listing-export",
          "evidenceRef": "evidence.marketplace.export"
        },
        "delete": {
          "actionRef": "lifecycle.delete",
          "format": "tenant-marketplace-delete-receipt",
          "evidenceRef": "evidence.marketplace.delete"
        }
      },
      "states": [
        {
          "name": "degraded",
          "reason": "marketplace storefront adapter is unavailable",
          "userVisible": true,
          "evidenceRef": "evidence.marketplace.degraded",
          "remediation": "queue listing or order receipt and retry after adapter recovery"
        },
        {
          "name": "blocked",
          "reason": "listing review, entitlement, or settlement evidence is missing",
          "userVisible": true,
          "evidenceRef": "evidence.marketplace.blocked",
          "remediation": "complete review and evidence linkage before publication or settlement resumes"
        },
        {
          "name": "ready",
          "reason": "controller ready",
          "userVisible": true,
          "evidenceRef": "evidence.marketplace.ready",
          "remediation": "continue normal operation"
        },
        {
          "name": "retryable",
          "reason": "transient dependency failure",
          "userVisible": true,
          "evidenceRef": "evidence.marketplace.retryable",
          "remediation": "retry with the same idempotency key"
        },
        {
          "name": "denied",
          "reason": "policy denied",
          "userVisible": true,
          "evidenceRef": "evidence.marketplace.denied",
          "remediation": "request entitlement or policy change"
        }
      ],
      "support": {
        "owner": "marketplace-module-team",
        "escalation": "platform-support",
        "diagnostics": [
          "listing-status",
          "order-handoff-summary",
          "settlement-receipt-summary"
        ],
        "docsRef": "modules/marketplace/README.md",
        "evidence": [
          {
            "name": "support-diagnostics",
            "type": "support-evidence",
            "ref": "evidence.marketplace.support-diagnostics"
          }
        ]
      },
      "evidenceBundles": [
        {
          "name": "marketplace-module-evidence",
          "owner": "marketplace-module-team",
          "claim": "listing publication, order handoff, entitlement, settlement, support diagnostics, and billing meters are declared as OCSv3 contract metadata",
          "freshness": "review-before-publication",
          "redaction": "commercial-summary-only",
          "evidence": [
            {
              "name": "settlement-review",
              "type": "billing-evidence",
              "ref": "evidence.marketplace.settlement-review"
            }
          ],
          "nonClaims": [
            "does not collect payments",
            "does not include storefront account credentials"
          ],
          "reviewPath": "reviews.marketplace.module"
        }
      ]
    }
  },
  "billing": {
    "apiVersion": "ocsv3.cloudring.io/v1alpha1",
    "kind": "BillingConnector",
    "metadata": {
      "name": "marketplace-module-billing",
      "displayName": "Marketplace Module Billing",
      "owner": "marketplace-module-team",
      "version": "v0.1.0"
    },
    "meters": [
      {
        "name": "listing_hours",
        "unit": "listing-hour",
        "aggregation": "sum"
      },
      {
        "name": "order_events",
        "unit": "order-event",
        "aggregation": "sum"
      }
    ],
    "costMeters": [
      {
        "name": "listing_hour",
        "currency": "USD",
        "unitPrice": "0.00-example",
        "meterRef": "listing_hours",
        "evidenceRef": "evidence.marketplace.cost-meter.listing"
      },
      {
        "name": "order_event",
        "currency": "USD",
        "unitPrice": "0.00-example",
        "meterRef": "order_events",
        "evidenceRef": "evidence.marketplace.cost-meter.order"
      }
    ],
    "events": [
      {
        "name": "listing-hour-recorded",
        "meter": "listing_hours",
        "idempotent": true,
        "idempotencyKey": "usageEvent.id",
        "entitlementRef": "catalog.plan.standard",
        "attribution": "tenant.project.subscription",
        "replayPolicy": "dedupe-by-idempotency-key"
      },
      {
        "name": "order-event-recorded",
        "meter": "order_events",
        "idempotent": true,
        "idempotencyKey": "usageEvent.id",
        "entitlementRef": "catalog.plan.standard",
        "attribution": "tenant.project.subscription",
        "replayPolicy": "dedupe-by-idempotency-key"
      }
    ]
  },
  "catalog": {
    "serviceClass": "marketplace",
    "visibility": "tenant",
    "portability": "ocs-portable-marketplace-contract",
    "plans": [
      {
        "name": "standard",
        "displayName": "Standard Marketplace",
        "billingMode": "metered",
        "quotaRef": "quota.marketplace.standard"
      }
    ]
  },
  "configuration": {
    "schemaRef": "schemas/marketplace.v1alpha1.json",
    "version": "v1alpha1"
  },
  "readiness": [
    {
      "name": "marketplace-listing-ready",
      "type": "kubernetes-condition",
      "target": "MarketplaceListing.status.conditions",
      "condition": "Ready",
      "evidenceRef": "support.diagnostics.listing-status"
    },
    {
      "name": "settlement-evidence-linked",
      "type": "billing-evidence",
      "target": "service.spec.evidenceBundles",
      "condition": "SettlementEvidenceLinked",
      "evidenceRef": "evidence.marketplace.settlement-review"
    }
  ],
  "tenantAccess": {
    "scope": "project",
    "entitlementRef": "catalog.plan.standard",
    "entitlements": [
      {
        "name": "standard-plan",
        "ref": "catalog.plan.standard",
        "scope": "project"
      }
    ],
    "permissions": [
      "marketplace.read",
      "marketplace.write",
      "marketplace.support"
    ]
  },
  "durability": {
    "stateClass": "event-sourced",
    "dataClasses": [
      "marketplace-listing-intent",
      "order-handoff-receipts",
      "settlement-receipts",
      "usage-events"
    ],
    "backupPolicyRef": "backup.marketplace.receipts",
    "recoveryObjective": "marketplace-receipt-replay-required-before-production",
    "recoveryEvidence": [
      {
        "name": "marketplace-receipt-replay",
        "type": "runbook-evidence",
        "ref": "evidence.marketplace.receipt-replay"
      }
    ]
  },
  "distribution": {
    "deploymentProfiles": [
      "provider-managed",
      "dedicated-cell"
    ],
    "channels": [
      "service-store",
      "enterprise-marketplace"
    ],
    "infrastructureTargets": [
      "kubernetes",
      "private-cloud",
      "edge"
    ],
    "updatePolicyRef": "updates.marketplace.compatibility-reviewed"
  },
  "federation": {
    "modes": [
      "standalone",
      "connected",
      "federated"
    ],
    "messageBusRef": "federation.bus.marketplace.events",
    "crossProviderScenarios": [
      "listing-portability",
      "order-handoff",
      "settlement-review"
    ],
    "portabilityPolicyRef": "policy.marketplace.ocs-portable-storefront-handoff"
  },
  "commercial": {
    "roles": [
      "vendor",
      "provider",
      "reseller"
    ],
    "revenueModel": "metered-listing-and-order-events-with-revenue-share",
    "licenseRef": "license.marketplace.marketplace-module",
    "expiryBehavior": "service-keeps-running-updates-stop-except-critical-fixes",
    "supportRef": "support.marketplace.provider-handoff",
    "serviceProvenance": "module-owned-service-surface",
    "responsibilityMatrixRef": "responsibility.marketplace.module-provider-storefront-and-reseller",
    "continuityPlanRef": "continuity.marketplace.listing-order-settlement-export"
  }
}
