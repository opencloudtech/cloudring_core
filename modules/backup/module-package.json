{
  "apiVersion": "ocsv3.cloudring.io/v1alpha1",
  "kind": "ConnectorPackage",
  "metadata": {
    "name": "backup-module-package",
    "displayName": "Backup Module Package",
    "owner": "backup-module-team",
    "version": "v0.1.0"
  },
  "service": {
    "apiVersion": "ocsv3.cloudring.io/v1alpha1",
    "kind": "ServiceConnector",
    "metadata": {
      "name": "backup-module",
      "displayName": "Backup Module",
      "owner": "backup-module-team",
      "version": "v0.1.0"
    },
    "spec": {
      "executionProfile": "local",
      "productAPI": {
        "ref": "service.api.backup.v1alpha1",
        "version": "v1alpha1",
        "protocol": "https-json"
      },
      "capabilities": [
        {
          "class": "backup",
          "name": "tenant-backup",
          "description": "Tenant-scoped backup policy, snapshot request, restore, export, and delete workflow contract."
        }
      ],
      "dependencies": [
        {
          "id": "durability-target-contract",
          "capabilityClass": "durability-target",
          "role": "portable backup target",
          "portability": "ocs-portable-durability-target-contract",
          "productAPIRef": "service.api.durability-target.v1",
          "versionRange": ">=1.0.0,<2.0.0",
          "compatibilityPolicyRef": "policy.compatibility.durability-target"
        }
      ],
      "lifecycle": [
        {
          "name": "provision",
          "applicability": "supported",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "metadata.uid"
        },
        {
          "name": "hold",
          "applicability": "not_applicable",
          "reason": "backup policy remains active until deprovisioned"
        },
        {
          "name": "resume",
          "applicability": "not_applicable",
          "reason": "hold is not supported for backup policy resources"
        },
        {
          "name": "resize",
          "applicability": "not_applicable",
          "reason": "protected capacity follows policy and service-plan configuration"
        },
        {
          "name": "configure",
          "applicability": "supported",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "metadata.uid"
        },
        {
          "name": "backup",
          "applicability": "supported",
          "verb": "Backup",
          "idempotent": true,
          "idempotencyKey": "backup.request.id"
        },
        {
          "name": "restore",
          "applicability": "supported",
          "verb": "Restore",
          "idempotent": true,
          "idempotencyKey": "restore.request.id"
        },
        {
          "name": "export",
          "applicability": "supported",
          "verb": "Export",
          "idempotent": true,
          "idempotencyKey": "export.request.id"
        },
        {
          "name": "deprovision",
          "applicability": "supported",
          "verb": "Delete",
          "idempotent": true,
          "idempotencyKey": "delete.request.id",
          "rollbackRef": "lifecycle.rollback"
        },
        {
          "name": "retry",
          "applicability": "supported",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "retry.request.id",
          "rollbackRef": "lifecycle.rollback"
        },
        {
          "name": "rollback",
          "applicability": "supported",
          "verb": "Rollback",
          "idempotent": true,
          "idempotencyKey": "rollback.request.id"
        }
      ],
      "automation": [
        {
          "name": "apply-backup-policy",
          "description": "Apply tenant backup policy intent through the module connector.",
          "actionRef": "lifecycle.configure"
        },
        {
          "name": "run-backup",
          "description": "Record a backup receipt without embedding target credentials.",
          "actionRef": "lifecycle.backup"
        },
        {
          "name": "run-restore",
          "description": "Restore from a referenced receipt and emit reviewable restore evidence.",
          "actionRef": "lifecycle.restore"
        }
      ],
      "usageMeters": [
        {
          "name": "protected_gib_hours",
          "unit": "gib-hour",
          "aggregation": "sum"
        },
        {
          "name": "backup_job_count",
          "unit": "job",
          "aggregation": "sum"
        }
      ],
      "billing": {
        "applicability": "supported",
        "connectorRef": "backup-module-billing",
        "meters": [
          {
            "name": "protected_gib_hours",
            "unit": "gib-hour",
            "aggregation": "sum"
          },
          {
            "name": "backup_job_count",
            "unit": "job",
            "aggregation": "sum"
          }
        ]
      },
      "portalModules": [
        {
          "name": "backup-overview",
          "slot": "service.detail",
          "route": "/services/backup",
          "apiRef": "service.api.backup.policies",
          "hostRef": "ui.backup.host",
          "mountRef": "mount.backup.overview",
          "permissions": [
            "backup.read",
            "backup.write"
          ]
        }
      ],
      "ui": {
        "embedRef": "ui.backup.bundle",
        "contextSchemaRef": "schemas/backup-ui-context.v1alpha1.json",
        "hostAuthority": [
          "navigation",
          "identity",
          "policy",
          "support"
        ],
        "extensionActions": [
          "backup.policy.apply",
          "backup.run",
          "backup.restore",
          "backup.delete"
        ],
        "moduleHost": {
          "host": "cloudring-provider-portal",
          "runtime": "module-federation",
          "mountRef": "mount.backup.overview",
          "versionRange": ">=0.1.0 <1.0.0",
          "signatureRef": "evidence.backup.ui.signature",
          "integrityRef": "evidence.backup.ui.integrity",
          "sandbox": "tenant-iam-context",
          "allowedEvents": [
            "backup.policy.apply.requested",
            "backup.run.requested",
            "backup.restore.requested",
            "backup.delete.requested"
          ],
          "requiredContext": [
            "tenant",
            "project",
            "iam.subject",
            "entitlements"
          ]
        },
        "evidence": [
          {
            "name": "ui-integrity",
            "type": "integrity-evidence",
            "ref": "evidence.backup.ui.integrity"
          }
        ]
      },
      "analyticsEvents": [
        {
          "name": "backup.lifecycle.submitted",
          "trigger": "portal-module-action",
          "subject": "tenant.project.backup-policy",
          "properties": [
            "tenantId",
            "projectId",
            "operation",
            "result"
          ],
          "evidenceRef": "evidence.backup.analytics.lifecycle"
        }
      ],
      "kubernetesBindings": [
        {
          "group": "backup.cloudring.io",
          "version": "v1alpha1",
          "kind": "BackupPolicy",
          "plural": "backuppolicies",
          "scope": "Namespaced",
          "crdRef": "crd.backuppolicies.backup.cloudring",
          "statusPath": "status.conditions",
          "condition": "Ready"
        }
      ],
      "gatewayRoutes": [
        {
          "name": "backup-api",
          "parentRef": "gateway-api.parent.platform-services",
          "hostnames": [
            "backup.service-api.contract"
          ],
          "rules": [
            "tenant-backup-api"
          ],
          "evidenceRef": "evidence.backup.gateway-route"
        }
      ],
      "secrets": {
        "workloadIdentityRef": "workloadidentity.backup-controller",
        "secretRefs": [
          {
            "name": "backup-target-reference",
            "ref": "secretref.backup.target-access",
            "purpose": "backup target access by reference",
            "rotation": "operator-initiated"
          }
        ]
      },
      "policies": [
        {
          "name": "tenant-backup-entitlement",
          "class": "authorization",
          "decisionRef": "policy.backup.entitlement",
          "evidenceRef": "evidence.backup.policy.entitlement"
        }
      ],
      "dataLifecycle": {
        "export": {
          "actionRef": "lifecycle.export",
          "format": "ocs-backup-receipt-archive",
          "evidenceRef": "evidence.backup.export"
        },
        "delete": {
          "actionRef": "lifecycle.deprovision",
          "format": "tenant-backup-delete-receipt",
          "evidenceRef": "evidence.backup.delete"
        }
      },
      "states": [
        {
          "name": "degraded",
          "reason": "backup target capability is unavailable",
          "userVisible": true,
          "evidenceRef": "evidence.backup.degraded",
          "remediation": "retry after target capability recovery or export receipts"
        },
        {
          "name": "blocked",
          "reason": "restore evidence, entitlement, or target reference is missing",
          "userVisible": true,
          "evidenceRef": "evidence.backup.blocked",
          "remediation": "clear the missing prerequisite before mutation resumes"
        },
        {
          "name": "ready",
          "reason": "controller ready",
          "userVisible": true,
          "evidenceRef": "evidence.backup.ready",
          "remediation": "continue normal operation"
        },
        {
          "name": "retryable",
          "reason": "transient dependency failure",
          "userVisible": true,
          "evidenceRef": "evidence.backup.retryable",
          "remediation": "retry with the same idempotency key"
        },
        {
          "name": "denied",
          "reason": "policy denied",
          "userVisible": true,
          "evidenceRef": "evidence.backup.denied",
          "remediation": "request entitlement or policy change"
        }
      ],
      "support": {
        "owner": "backup-module-team",
        "escalation": "platform-support",
        "diagnostics": [
          "backup-policy-status",
          "backup-receipt-summary",
          "restore-receipt-summary"
        ],
        "docsRef": "modules/backup/README.md",
        "evidence": [
          {
            "name": "support-diagnostics",
            "type": "support-evidence",
            "ref": "evidence.backup.support-diagnostics"
          }
        ]
      },
      "evidenceBundles": [
        {
          "name": "backup-module-evidence",
          "owner": "backup-module-team",
          "claim": "backup policy, restore workflow, support diagnostics, billing meters, and durability receipts are declared as OCSv3 contract metadata",
          "freshness": "review-before-publication",
          "redaction": "tenant-safe-receipts-only",
          "evidence": [
            {
              "name": "restore-drill",
              "type": "runbook-evidence",
              "ref": "evidence.backup.restore"
            }
          ],
          "nonClaims": [
            "does not claim live backup success",
            "does not include target credentials"
          ],
          "reviewPath": "reviews.backup.module"
        }
      ]
    }
  },
  "billing": {
    "apiVersion": "ocsv3.cloudring.io/v1alpha1",
    "kind": "BillingConnector",
    "metadata": {
      "name": "backup-module-billing",
      "displayName": "Backup Module Billing",
      "owner": "backup-module-team",
      "version": "v0.1.0"
    },
    "meters": [
      {
        "name": "protected_gib_hours",
        "unit": "gib-hour",
        "aggregation": "sum"
      },
      {
        "name": "backup_job_count",
        "unit": "job",
        "aggregation": "sum"
      }
    ],
    "costMeters": [
      {
        "name": "protected_gib_month",
        "currency": "USD",
        "unitPrice": "0.00-example",
        "meterRef": "protected_gib_hours",
        "evidenceRef": "evidence.backup.cost-meter.protected-gib"
      },
      {
        "name": "backup_job",
        "currency": "USD",
        "unitPrice": "0.00-example",
        "meterRef": "backup_job_count",
        "evidenceRef": "evidence.backup.cost-meter.job"
      }
    ],
    "events": [
      {
        "name": "protected-capacity-recorded",
        "meter": "protected_gib_hours",
        "idempotent": true,
        "idempotencyKey": "usageEvent.id",
        "entitlementRef": "catalog.plan.standard",
        "attribution": "tenant.project.subscription",
        "replayPolicy": "dedupe-by-idempotency-key"
      },
      {
        "name": "backup-job-recorded",
        "meter": "backup_job_count",
        "idempotent": true,
        "idempotencyKey": "usageEvent.id",
        "entitlementRef": "catalog.plan.standard",
        "attribution": "tenant.project.subscription",
        "replayPolicy": "dedupe-by-idempotency-key"
      }
    ]
  },
  "catalog": {
    "serviceClass": "backup",
    "visibility": "tenant",
    "portability": "ocs-portable-backup-restore-contract",
    "plans": [
      {
        "name": "standard",
        "displayName": "Standard Backup",
        "billingMode": "metered",
        "quotaRef": "quota.backup.standard"
      }
    ]
  },
  "configuration": {
    "schemaRef": "schemas/backup.v1alpha1.json",
    "version": "v1alpha1"
  },
  "readiness": [
    {
      "name": "backup-policy-ready",
      "type": "kubernetes-condition",
      "target": "BackupPolicy.status.conditions",
      "condition": "Ready",
      "evidenceRef": "support.diagnostics.backup-policy-status"
    },
    {
      "name": "restore-evidence-linked",
      "type": "durability-drill",
      "target": "durability.recoveryEvidence",
      "condition": "RestoreEvidenceLinked",
      "evidenceRef": "evidence.backup.restore"
    }
  ],
  "tenantAccess": {
    "scope": "project",
    "entitlementRef": "catalog.plan.standard",
    "entitlements": [
      {
        "name": "standard-plan",
        "ref": "catalog.plan.standard",
        "scope": "project"
      }
    ],
    "permissions": [
      "backup.read",
      "backup.write",
      "backup.restore",
      "backup.support"
    ]
  },
  "durability": {
    "stateClass": "stateful",
    "dataClasses": [
      "backup-policy-intent",
      "backup-receipts",
      "restore-receipts",
      "usage-events"
    ],
    "backupPolicyRef": "backup.module.standard",
    "recoveryObjective": "restore-test-required-before-production",
    "recoveryEvidence": [
      {
        "name": "backup-receipt",
        "type": "runbook-evidence",
        "ref": "evidence.backup.receipt"
      },
      {
        "name": "restore-drill",
        "type": "runbook-evidence",
        "ref": "evidence.backup.restore"
      }
    ]
  },
  "distribution": {
    "deploymentProfiles": [
      "provider-managed",
      "dedicated-cell"
    ],
    "channels": [
      "service-store",
      "enterprise-marketplace"
    ],
    "infrastructureTargets": [
      "kubernetes",
      "private-cloud",
      "edge"
    ],
    "updatePolicyRef": "updates.backup.compatibility-reviewed"
  },
  "federation": {
    "applicability": "supported",
    "modes": [
      "standalone",
      "connected",
      "federated"
    ],
    "messageBusRef": "federation.bus.backup.events",
    "crossProviderScenarios": [
      "backup-replication",
      "restore-handoff",
      "support-handoff"
    ],
    "portabilityPolicyRef": "policy.backup.ocs-portable-backup-restore"
  },
  "commercial": {
    "applicability": "supported",
    "roles": [
      "vendor",
      "provider",
      "reseller"
    ],
    "revenueModel": "metered-protected-capacity-and-job-events",
    "licenseRef": "license.backup.marketplace-module",
    "expiryBehavior": "service-keeps-running-updates-stop-except-critical-fixes",
    "supportRef": "support.backup.provider-handoff",
    "serviceProvenance": "module-owned-service-surface",
    "responsibilityMatrixRef": "responsibility.backup.module-provider-and-target-adapter",
    "continuityPlanRef": "continuity.backup.restore-export"
  }
}
