{
  "apiVersion": "ocsv3.cloudring.io/v1alpha1",
  "kind": "ConnectorPackage",
  "metadata": {
    "name": "scheduler-module-package",
    "displayName": "Scheduler Module Package",
    "owner": "scheduler-module-team",
    "version": "v0.1.0"
  },
  "service": {
    "apiVersion": "ocsv3.cloudring.io/v1alpha1",
    "kind": "ServiceConnector",
    "metadata": {
      "name": "scheduler-module",
      "displayName": "Scheduler Module",
      "owner": "scheduler-module-team",
      "version": "v0.1.0"
    },
    "spec": {
      "executionProfile": "local",
      "productAPI": {
        "ref": "service.api.scheduler.v1alpha1",
        "version": "v1alpha1",
        "protocol": "https-json"
      },
      "capabilities": [
        {
          "class": "scheduler",
          "name": "kueue-fair-share",
          "description": "Optional Kueue and scheduler admission contract exposed through OCSv3 metadata."
        }
      ],
      "dependencies": [
        {
          "id": "kubernetes-1-35-window",
          "capabilityClass": "kubernetes",
          "role": "upstream Kubernetes API target",
          "portability": "ocs-portable-kubernetes-1.35-patch-window",
          "productAPIRef": "service.api.kubernetes.v1",
          "versionRange": ">=1.0.0,<2.0.0",
          "compatibilityPolicyRef": "policy.compatibility.kubernetes"
        },
        {
          "id": "kueue-compatible-window",
          "capabilityClass": "kueue",
          "role": "primary Kubernetes-native scheduler admission",
          "portability": "ocs-portable-kueue-scheduler-window",
          "productAPIRef": "service.api.kueue.v1",
          "versionRange": ">=1.0.0,<2.0.0",
          "compatibilityPolicyRef": "policy.compatibility.kueue"
        },
        {
          "id": "volcano-optional-window",
          "capabilityClass": "volcano",
          "role": "optional batch scheduling backend",
          "portability": "ocs-portable-volcano-optional-window",
          "productAPIRef": "service.api.volcano.v1",
          "versionRange": ">=1.0.0,<2.0.0",
          "compatibilityPolicyRef": "policy.compatibility.volcano"
        },
        {
          "id": "cilium-1-19-window",
          "capabilityClass": "network-policy",
          "role": "portable dataplane policy contract",
          "portability": "ocs-portable-cilium-1.19-compatible",
          "productAPIRef": "service.api.network-policy.v1",
          "versionRange": ">=1.0.0,<2.0.0",
          "compatibilityPolicyRef": "policy.compatibility.network-policy"
        },
        {
          "id": "flux-2-window",
          "capabilityClass": "gitops",
          "role": "module delivery contract",
          "portability": "ocs-portable-flux-2-compatible",
          "productAPIRef": "service.api.gitops.v1",
          "versionRange": ">=1.0.0,<2.0.0",
          "compatibilityPolicyRef": "policy.compatibility.gitops"
        },
        {
          "id": "policy-engine-window",
          "capabilityClass": "policy",
          "role": "queue and quota admission policy",
          "portability": "ocs-portable-policy-engine-contract",
          "productAPIRef": "service.api.policy.v1",
          "versionRange": ">=1.0.0,<2.0.0",
          "compatibilityPolicyRef": "policy.compatibility.policy"
        },
        {
          "id": "secret-manager-window",
          "capabilityClass": "secret-manager",
          "role": "referenced credentials only",
          "portability": "ocs-portable-secret-reference-contract",
          "productAPIRef": "service.api.secret-manager.v1",
          "versionRange": ">=1.0.0,<2.0.0",
          "compatibilityPolicyRef": "policy.compatibility.secret-manager"
        }
      ],
      "lifecycle": [
        {
          "name": "provision",
          "applicability": "supported",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "metadata.uid"
        },
        {
          "name": "resume",
          "applicability": "supported",
          "verb": "Enable",
          "idempotent": true,
          "idempotencyKey": "module.request.id"
        },
        {
          "name": "suspend",
          "applicability": "supported",
          "verb": "Disable",
          "idempotent": true,
          "idempotencyKey": "module.request.id"
        },
        {
          "name": "resize",
          "applicability": "not_applicable",
          "reason": "scheduler capacity is governed by queue policy rather than a service resize action"
        },
        {
          "name": "export",
          "applicability": "supported",
          "verb": "Export",
          "idempotent": true,
          "idempotencyKey": "export.request.id"
        },
        {
          "name": "deprovision",
          "applicability": "supported",
          "verb": "Delete",
          "idempotent": true,
          "idempotencyKey": "delete.request.id",
          "rollbackRef": "lifecycle.rollback"
        },
        {
          "name": "backup",
          "applicability": "supported",
          "verb": "Backup",
          "idempotent": true,
          "idempotencyKey": "backup.request.id"
        },
        {
          "name": "restore",
          "applicability": "supported",
          "verb": "Restore",
          "idempotent": true,
          "idempotencyKey": "restore.request.id"
        },
        {
          "name": "retry",
          "applicability": "supported",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "retry.request.id",
          "rollbackRef": "lifecycle.rollback"
        },
        {
          "name": "rollback",
          "applicability": "supported",
          "verb": "Rollback",
          "idempotent": true,
          "idempotencyKey": "rollback.request.id"
        }
      ],
      "automation": [
        {
          "name": "publish-scheduler-queue-contract",
          "description": "Publish scheduler queue metadata after compatibility and rollback review.",
          "actionRef": "lifecycle.resume"
        },
        {
          "name": "disable-scheduler-module",
          "description": "Return scheduler module to disabled or not-installed state without foundation impact.",
          "actionRef": "lifecycle.suspend"
        }
      ],
      "usageMeters": [
        {
          "name": "queue_admission_count",
          "unit": "admission",
          "aggregation": "sum"
        }
      ],
      "billing": {
        "applicability": "supported",
        "connectorRef": "scheduler-module-billing",
        "meters": [
          {
            "name": "queue_admission_count",
            "unit": "admission",
            "aggregation": "sum"
          }
        ]
      },
      "portalModules": [
        {
          "name": "scheduler-overview",
          "slot": "service.detail",
          "route": "/services/scheduler",
          "apiRef": "service.api.scheduler.queues",
          "hostRef": "ui.scheduler.host",
          "mountRef": "mount.scheduler.overview",
          "permissions": [
            "scheduler.read",
            "scheduler.write"
          ]
        }
      ],
      "ui": {
        "embedRef": "ui.scheduler.bundle",
        "contextSchemaRef": "schemas/scheduler-ui-context.v1alpha1.json",
        "hostAuthority": [
          "navigation",
          "identity",
          "policy",
          "support"
        ],
        "extensionActions": [
          "scheduler.module.enable",
          "scheduler.module.disable"
        ],
        "moduleHost": {
          "host": "cloudring-provider-portal",
          "runtime": "module-federation",
          "mountRef": "mount.scheduler.overview",
          "versionRange": ">=0.1.0 <1.0.0",
          "signatureRef": "evidence.scheduler.ui.signature",
          "integrityRef": "evidence.scheduler.ui.integrity",
          "sandbox": "tenant-iam-context",
          "allowedEvents": [
            "scheduler.module.enable.requested",
            "scheduler.module.disable.requested"
          ],
          "requiredContext": [
            "tenant",
            "project",
            "iam.subject",
            "entitlements"
          ]
        },
        "evidence": [
          {
            "name": "ui-integrity",
            "type": "integrity-evidence",
            "ref": "evidence.scheduler.ui.integrity"
          }
        ]
      },
      "analyticsEvents": [
        {
          "name": "scheduler.module.state.changed",
          "trigger": "portal-module-action",
          "subject": "tenant.project.scheduler-module",
          "properties": [
            "tenantId",
            "projectId",
            "state",
            "result"
          ],
          "evidenceRef": "evidence.scheduler.analytics.state"
        }
      ],
      "kubernetesBindings": [
        {
          "group": "scheduler.cloudring.io",
          "version": "v1alpha1",
          "kind": "QueueClass",
          "plural": "queueclasses",
          "scope": "Namespaced",
          "crdRef": "crd.queueclasses.scheduler.cloudring",
          "statusPath": "status.conditions",
          "condition": "Ready"
        }
      ],
      "gatewayRoutes": [
        {
          "name": "scheduler-api",
          "parentRef": "gateway-api.parent.platform-services",
          "hostnames": [
            "scheduler.service-api.contract"
          ],
          "rules": [
            "tenant-scheduler-api"
          ],
          "evidenceRef": "evidence.scheduler.gateway-route"
        }
      ],
      "secrets": {
        "workloadIdentityRef": "workloadidentity.scheduler-controller",
        "secretRefs": [
          {
            "name": "scheduler-controller-secret-reference",
            "ref": "secretref.scheduler.controller",
            "purpose": "scheduler controller access by reference",
            "rotation": "operator-initiated"
          }
        ]
      },
      "policies": [
        {
          "name": "scheduler-entitlement",
          "class": "authorization",
          "decisionRef": "policy.scheduler.entitlement",
          "evidenceRef": "evidence.scheduler.policy.entitlement"
        }
      ],
      "dataLifecycle": {
        "export": {
          "actionRef": "lifecycle.export",
          "format": "ocs-scheduler-module-receipts",
          "evidenceRef": "evidence.scheduler.export"
        },
        "delete": {
          "actionRef": "lifecycle.deprovision",
          "format": "ocs-scheduler-delete-receipt",
          "evidenceRef": "evidence.scheduler.delete"
        }
      },
      "states": [
        {
          "name": "not-installed",
          "reason": "Scheduler module is optional and absent from foundation-only deployments",
          "userVisible": true,
          "evidenceRef": "evidence.scheduler.not-installed",
          "remediation": "install only after foundation, queue, policy, and rollback evidence pass"
        },
        {
          "name": "disabled",
          "reason": "Scheduler module is installed but disabled by provider policy",
          "userVisible": true,
          "evidenceRef": "evidence.scheduler.disabled",
          "remediation": "enable through OCS lifecycle after compatibility review"
        },
        {
          "name": "degraded",
          "reason": "Kueue, optional batch backend, or quota dependency is unavailable",
          "userVisible": true,
          "evidenceRef": "evidence.scheduler.degraded",
          "remediation": "keep queue admission closed until dependency evidence recovers"
        },
        {
          "name": "blocked",
          "reason": "compatibility, entitlement, backup, or rollback evidence is missing",
          "userVisible": true,
          "evidenceRef": "evidence.scheduler.blocked",
          "remediation": "clear the missing gate before publishing scheduler queues"
        },
        {
          "name": "ready",
          "reason": "controller ready",
          "userVisible": true,
          "evidenceRef": "evidence.scheduler.ready",
          "remediation": "continue normal operation"
        },
        {
          "name": "retryable",
          "reason": "transient dependency failure",
          "userVisible": true,
          "evidenceRef": "evidence.scheduler.retryable",
          "remediation": "retry with the same idempotency key"
        },
        {
          "name": "denied",
          "reason": "policy denied",
          "userVisible": true,
          "evidenceRef": "evidence.scheduler.denied",
          "remediation": "request entitlement or policy change"
        }
      ],
      "support": {
        "owner": "scheduler-module-team",
        "escalation": "platform-support",
        "diagnostics": [
          "queue-class-status",
          "fair-share-summary",
          "admission-policy-summary"
        ],
        "docsRef": "modules/scheduler/README.md",
        "evidence": [
          {
            "name": "support-diagnostics",
            "type": "support-evidence",
            "ref": "evidence.scheduler.support-diagnostics"
          }
        ]
      },
      "evidenceBundles": [
        {
          "name": "scheduler-module-evidence",
          "owner": "scheduler-module-team",
          "claim": "Scheduler ownership, compatibility windows, disabled state, not-installed state, and OCS module surfaces are declared as metadata",
          "freshness": "review-before-publication",
          "redaction": "tenant-safe-receipts-only",
          "evidence": [
            {
              "name": "compatibility-bom",
              "type": "bom-window",
              "ref": "xCloudRING.compatibilityBOM"
            }
          ],
          "nonClaims": [
            "does not claim live scheduler installation",
            "does not make Kueue, Volcano, or scheduler ownership a foundation prerequisite"
          ],
          "reviewPath": "reviews.scheduler.module"
        }
      ]
    }
  },
  "billing": {
    "apiVersion": "ocsv3.cloudring.io/v1alpha1",
    "kind": "BillingConnector",
    "metadata": {
      "name": "scheduler-module-billing",
      "displayName": "Scheduler Module Billing",
      "owner": "scheduler-module-team",
      "version": "v0.1.0"
    },
    "meters": [
      {
        "name": "queue_admission_count",
        "unit": "admission",
        "aggregation": "sum"
      }
    ],
    "costMeters": [
      {
        "name": "queue_admission_count_cost",
        "currency": "USD",
        "unitPrice": "0.00-example",
        "meterRef": "queue_admission_count",
        "evidenceRef": "evidence.scheduler.cost-meter"
      }
    ],
    "events": [
      {
        "name": "queue-admission-recorded",
        "meter": "queue_admission_count",
        "idempotent": true,
        "idempotencyKey": "usageEvent.id",
        "entitlementRef": "catalog.plan.optional",
        "attribution": "tenant.project.subscription",
        "replayPolicy": "dedupe-by-idempotency-key"
      }
    ]
  },
  "catalog": {
    "serviceClass": "scheduler",
    "visibility": "tenant",
    "portability": "ocs-portable-scheduler-module-contract",
    "plans": [
      {
        "name": "optional",
        "displayName": "Optional Scheduler",
        "billingMode": "metered",
        "quotaRef": "quota.scheduler.optional"
      }
    ]
  },
  "configuration": {
    "schemaRef": "schemas/scheduler.v1alpha1.json",
    "version": "v1alpha1"
  },
  "readiness": [
    {
      "name": "scheduler-not-installed-ready",
      "type": "module-state",
      "target": "states.not-installed",
      "condition": "OptionalNotInstalled",
      "evidenceRef": "evidence.scheduler.not-installed"
    },
    {
      "name": "scheduler-disabled-until-foundation",
      "type": "foundation-gate",
      "target": "xCloudRING.foundationPrerequisite",
      "condition": "False",
      "evidenceRef": "evidence.scheduler.disabled"
    }
  ],
  "tenantAccess": {
    "scope": "project",
    "entitlementRef": "catalog.plan.optional",
    "entitlements": [
      {
        "name": "optional-plan",
        "ref": "catalog.plan.optional",
        "scope": "project"
      }
    ],
    "permissions": [
      "scheduler.read",
      "scheduler.write",
      "scheduler.support"
    ]
  },
  "durability": {
    "stateClass": "control-plane-metadata",
    "dataClasses": [
      "queue-intent",
      "admission-receipts",
      "usage-events"
    ],
    "backupPolicyRef": "backup.module.optional",
    "recoveryObjective": "restore-test-required-before-production",
    "recoveryEvidence": [
      {
        "name": "state-export",
        "type": "runbook-evidence",
        "ref": "evidence.scheduler.export"
      }
    ]
  },
  "distribution": {
    "deploymentProfiles": [
      "optional-module",
      "provider-managed"
    ],
    "channels": [
      "service-store",
      "enterprise-marketplace"
    ],
    "infrastructureTargets": [
      "upstream-kubernetes"
    ],
    "updatePolicyRef": "updates.scheduler.compatibility-reviewed"
  },
  "federation": {
    "applicability": "supported",
    "modes": [
      "standalone",
      "connected"
    ],
    "messageBusRef": "federation.bus.scheduler.events",
    "crossProviderScenarios": [
      "queue-policy-handoff",
      "support-handoff"
    ],
    "portabilityPolicyRef": "policy.scheduler.ocs-portable-scheduler-module"
  },
  "commercial": {
    "applicability": "supported",
    "roles": [
      "vendor",
      "provider",
      "reseller"
    ],
    "revenueModel": "metered-queue-admission-usage",
    "licenseRef": "license.scheduler.optional-module",
    "expiryBehavior": "service-stays-not-installed-or-disabled-until-provider-enables",
    "supportRef": "support.scheduler.provider-handoff",
    "serviceProvenance": "module-owned-service-surface",
    "responsibilityMatrixRef": "responsibility.scheduler.module-provider-and-runtime-dependency",
    "continuityPlanRef": "continuity.scheduler.disable-export"
  },
  "xCloudRING": {
    "ownership": "optional-ocs-module",
    "foundationPrerequisite": false,
    "defaultState": "not-installed",
    "disabledStates": [
      "not-installed",
      "disabled",
      "blocked"
    ],
    "compatibilityBOM": [
      {
        "component": "Kubernetes",
        "window": "1.35.x",
        "required": true
      },
      {
        "component": "Kueue scheduler",
        "window": "Kubernetes 1.35 compatible fair-sharing profile",
        "required": false
      },
      {
        "component": "Volcano scheduler",
        "window": "optional compatibility window only when selected",
        "required": false
      },
      {
        "component": "Cilium",
        "window": "1.19.x",
        "required": true
      },
      {
        "component": "Flux",
        "window": "2.x compatible with Kubernetes 1.35",
        "required": true
      },
      {
        "component": "policy engine",
        "window": "fail-closed queue and quota policy compatible with OCS lifecycle gates",
        "required": true
      },
      {
        "component": "secret manager",
        "window": "secret-reference-only integration compatible with workload identity",
        "required": true
      }
    ],
    "nonClaims": [
      "no live scheduler installation readiness",
      "no foundation-only dependency"
    ]
  }
}
