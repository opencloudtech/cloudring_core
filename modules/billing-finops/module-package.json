{
  "apiVersion": "ocsv3.cloudring.io/v1alpha1",
  "kind": "ConnectorPackage",
  "metadata": {
    "name": "billing-finops-module-package",
    "displayName": "Billing FinOps Module Package",
    "owner": "billing-finops-module-team",
    "version": "v0.1.0"
  },
  "service": {
    "apiVersion": "ocsv3.cloudring.io/v1alpha1",
    "kind": "ServiceConnector",
    "metadata": {
      "name": "billing-finops-module",
      "displayName": "Billing FinOps Module",
      "owner": "billing-finops-module-team",
      "version": "v0.1.0"
    },
    "spec": {
      "executionProfile": "local",
      "productAPI": {
        "ref": "service.api.billing-finops.v1alpha1",
        "version": "v1alpha1",
        "protocol": "https-json"
      },
      "capabilities": [
        {
          "class": "billing-finops",
          "name": "tenant-usage-ledger",
          "description": "Tenant-scoped usage ledger, allocation, invoice preview, settlement, export, and delete contract."
        }
      ],
      "dependencies": [
        {
          "id": "commercial-ledger-adapter-contract",
          "capabilityClass": "commercial-ledger",
          "role": "portable commercial ledger adapter",
          "portability": "ocs-portable-commercial-ledger-contract",
          "productAPIRef": "service.api.commercial-ledger.v1",
          "versionRange": ">=1.0.0,<2.0.0",
          "compatibilityPolicyRef": "policy.compatibility.commercial-ledger"
        }
      ],
      "lifecycle": [
        {
          "name": "provision",
          "applicability": "supported",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "metadata.uid"
        },
        {
          "name": "hold",
          "applicability": "not_applicable",
          "reason": "usage ledger processing remains available until deprovisioned"
        },
        {
          "name": "resume",
          "applicability": "not_applicable",
          "reason": "hold is not supported for the usage ledger"
        },
        {
          "name": "resize",
          "applicability": "not_applicable",
          "reason": "ledger capacity is managed by the selected service plan"
        },
        {
          "name": "ingest",
          "applicability": "supported",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "usageEvent.id"
        },
        {
          "name": "allocate",
          "applicability": "supported",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "allocation.run.id"
        },
        {
          "name": "preview",
          "applicability": "supported",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "preview.request.id"
        },
        {
          "name": "export",
          "applicability": "supported",
          "verb": "Export",
          "idempotent": true,
          "idempotencyKey": "export.request.id"
        },
        {
          "name": "deprovision",
          "applicability": "supported",
          "verb": "Delete",
          "idempotent": true,
          "idempotencyKey": "delete.request.id",
          "rollbackRef": "lifecycle.rollback"
        },
        {
          "name": "backup",
          "applicability": "supported",
          "verb": "Backup",
          "idempotent": true,
          "idempotencyKey": "backup.request.id"
        },
        {
          "name": "restore",
          "applicability": "supported",
          "verb": "Restore",
          "idempotent": true,
          "idempotencyKey": "restore.request.id"
        },
        {
          "name": "retry",
          "applicability": "supported",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "retry.request.id",
          "rollbackRef": "lifecycle.rollback"
        },
        {
          "name": "rollback",
          "applicability": "supported",
          "verb": "Rollback",
          "idempotent": true,
          "idempotencyKey": "rollback.request.id"
        }
      ],
      "automation": [
        {
          "name": "ingest-usage-event",
          "description": "Ingest usage through an idempotent OCSv3 usage event.",
          "actionRef": "lifecycle.ingest"
        },
        {
          "name": "allocate-cost",
          "description": "Allocate aggregate cost records without payment processor coupling.",
          "actionRef": "lifecycle.allocate"
        },
        {
          "name": "preview-invoice",
          "description": "Produce tenant-visible invoice preview evidence from reviewed usage.",
          "actionRef": "lifecycle.preview"
        }
      ],
      "usageMeters": [
        {
          "name": "usage_events",
          "unit": "event",
          "aggregation": "sum"
        },
        {
          "name": "cost_allocation_records",
          "unit": "record",
          "aggregation": "sum"
        }
      ],
      "billing": {
        "applicability": "supported",
        "connectorRef": "billing-finops-module-billing",
        "meters": [
          {
            "name": "usage_events",
            "unit": "event",
            "aggregation": "sum"
          },
          {
            "name": "cost_allocation_records",
            "unit": "record",
            "aggregation": "sum"
          }
        ]
      },
      "portalModules": [
        {
          "name": "billing-finops-overview",
          "slot": "service.detail",
          "route": "/services/billing-finops",
          "apiRef": "service.api.billing-finops.ledger",
          "hostRef": "ui.billing-finops.host",
          "mountRef": "mount.billing-finops.overview",
          "permissions": [
            "billing-finops.read",
            "billing-finops.write"
          ]
        }
      ],
      "ui": {
        "embedRef": "ui.billing-finops.bundle",
        "contextSchemaRef": "schemas/billing-finops-ui-context.v1alpha1.json",
        "hostAuthority": [
          "navigation",
          "identity",
          "policy",
          "billing",
          "support"
        ],
        "extensionActions": [
          "billing.usage.ingest",
          "billing.cost.allocate",
          "billing.invoice.preview",
          "billing.export",
          "billing.delete"
        ],
        "moduleHost": {
          "host": "cloudring-provider-portal",
          "runtime": "module-federation",
          "mountRef": "mount.billing-finops.overview",
          "versionRange": ">=0.1.0 <1.0.0",
          "signatureRef": "evidence.billing-finops.ui.signature",
          "integrityRef": "evidence.billing-finops.ui.integrity",
          "sandbox": "tenant-iam-context",
          "allowedEvents": [
            "billing.usage.ingest.requested",
            "billing.cost.allocate.requested",
            "billing.invoice.preview.requested",
            "billing.export.requested",
            "billing.delete.requested"
          ],
          "requiredContext": [
            "tenant",
            "project",
            "iam.subject",
            "entitlements"
          ]
        },
        "evidence": [
          {
            "name": "ui-integrity",
            "type": "integrity-evidence",
            "ref": "evidence.billing-finops.ui.integrity"
          }
        ]
      },
      "analyticsEvents": [
        {
          "name": "billing-finops.ledger.action.submitted",
          "trigger": "portal-module-action",
          "subject": "tenant.project.usage-ledger",
          "properties": [
            "tenantId",
            "projectId",
            "operation",
            "result"
          ],
          "evidenceRef": "evidence.billing-finops.analytics.ledger"
        }
      ],
      "kubernetesBindings": [
        {
          "group": "billing.cloudring.io",
          "version": "v1alpha1",
          "kind": "UsageLedger",
          "plural": "usageledgers",
          "scope": "Namespaced",
          "crdRef": "crd.usageledgers.billing.cloudring",
          "statusPath": "status.conditions",
          "condition": "Ready"
        }
      ],
      "gatewayRoutes": [
        {
          "name": "billing-finops-api",
          "parentRef": "gateway-api.parent.platform-services",
          "hostnames": [
            "billing-finops.service-api.contract"
          ],
          "rules": [
            "tenant-billing-finops-api"
          ],
          "evidenceRef": "evidence.billing-finops.gateway-route"
        }
      ],
      "secrets": {
        "workloadIdentityRef": "workloadidentity.billing-finops-controller",
        "secretRefs": [
          {
            "name": "commercial-ledger-reference",
            "ref": "secretref.billing-finops.ledger-account",
            "purpose": "commercial ledger access by reference",
            "rotation": "operator-initiated"
          }
        ]
      },
      "policies": [
        {
          "name": "tenant-billing-entitlement",
          "class": "authorization",
          "decisionRef": "policy.billing-finops.entitlement",
          "evidenceRef": "evidence.billing-finops.policy.entitlement"
        }
      ],
      "dataLifecycle": {
        "export": {
          "actionRef": "lifecycle.export",
          "format": "ocs-billing-finops-ledger-export",
          "evidenceRef": "evidence.billing-finops.export"
        },
        "delete": {
          "actionRef": "lifecycle.deprovision",
          "format": "tenant-billing-finops-delete-receipt",
          "evidenceRef": "evidence.billing-finops.delete"
        }
      },
      "states": [
        {
          "name": "degraded",
          "reason": "commercial ledger adapter is unavailable",
          "userVisible": true,
          "evidenceRef": "evidence.billing-finops.degraded",
          "remediation": "continue collecting local usage receipts and retry ledger allocation after recovery"
        },
        {
          "name": "blocked",
          "reason": "billing entitlement, cost evidence, or ledger reference is missing",
          "userVisible": true,
          "evidenceRef": "evidence.billing-finops.blocked",
          "remediation": "link reviewed cost evidence and ledger reference before publishing commercial results"
        },
        {
          "name": "ready",
          "reason": "controller ready",
          "userVisible": true,
          "evidenceRef": "evidence.billing-finops.ready",
          "remediation": "continue normal operation"
        },
        {
          "name": "retryable",
          "reason": "transient dependency failure",
          "userVisible": true,
          "evidenceRef": "evidence.billing-finops.retryable",
          "remediation": "retry with the same idempotency key"
        },
        {
          "name": "denied",
          "reason": "policy denied",
          "userVisible": true,
          "evidenceRef": "evidence.billing-finops.denied",
          "remediation": "request entitlement or policy change"
        }
      ],
      "support": {
        "owner": "billing-finops-module-team",
        "escalation": "platform-support",
        "diagnostics": [
          "usage-ledger-status",
          "allocation-run-summary",
          "invoice-preview-replay"
        ],
        "docsRef": "modules/billing-finops/README.md",
        "evidence": [
          {
            "name": "support-diagnostics",
            "type": "support-evidence",
            "ref": "evidence.billing-finops.support-diagnostics"
          }
        ]
      },
      "evidenceBundles": [
        {
          "name": "billing-finops-module-evidence",
          "owner": "billing-finops-module-team",
          "claim": "usage ledger, allocation, invoice preview, support diagnostics, and cost meter evidence are declared as OCSv3 contract metadata",
          "freshness": "review-before-publication",
          "redaction": "aggregate-usage-only",
          "evidence": [
            {
              "name": "cost-meter-review",
              "type": "billing-evidence",
              "ref": "evidence.billing-finops.cost-meter-review"
            }
          ],
          "nonClaims": [
            "does not set real prices",
            "does not include payment processor credentials"
          ],
          "reviewPath": "reviews.billing-finops.module"
        }
      ]
    }
  },
  "billing": {
    "apiVersion": "ocsv3.cloudring.io/v1alpha1",
    "kind": "BillingConnector",
    "metadata": {
      "name": "billing-finops-module-billing",
      "displayName": "Billing FinOps Module Billing",
      "owner": "billing-finops-module-team",
      "version": "v0.1.0"
    },
    "meters": [
      {
        "name": "usage_events",
        "unit": "event",
        "aggregation": "sum"
      },
      {
        "name": "cost_allocation_records",
        "unit": "record",
        "aggregation": "sum"
      }
    ],
    "costMeters": [
      {
        "name": "usage_event_processing",
        "currency": "USD",
        "unitPrice": "0.00-example",
        "meterRef": "usage_events",
        "evidenceRef": "evidence.billing-finops.cost-meter.usage-event"
      },
      {
        "name": "cost_allocation_record",
        "currency": "USD",
        "unitPrice": "0.00-example",
        "meterRef": "cost_allocation_records",
        "evidenceRef": "evidence.billing-finops.cost-meter.allocation"
      }
    ],
    "events": [
      {
        "name": "usage-event-recorded",
        "meter": "usage_events",
        "idempotent": true,
        "idempotencyKey": "usageEvent.id",
        "entitlementRef": "catalog.plan.standard",
        "attribution": "tenant.project.subscription",
        "replayPolicy": "dedupe-by-idempotency-key"
      },
      {
        "name": "cost-allocation-recorded",
        "meter": "cost_allocation_records",
        "idempotent": true,
        "idempotencyKey": "usageEvent.id",
        "entitlementRef": "catalog.plan.standard",
        "attribution": "tenant.project.subscription",
        "replayPolicy": "dedupe-by-idempotency-key"
      }
    ]
  },
  "catalog": {
    "serviceClass": "billing-finops",
    "visibility": "tenant",
    "portability": "ocs-portable-commercial-ledger-contract",
    "plans": [
      {
        "name": "standard",
        "displayName": "Standard Billing FinOps",
        "billingMode": "metered",
        "quotaRef": "quota.billing-finops.standard"
      }
    ]
  },
  "configuration": {
    "schemaRef": "schemas/billing-finops.v1alpha1.json",
    "version": "v1alpha1"
  },
  "readiness": [
    {
      "name": "usage-ledger-ready",
      "type": "kubernetes-condition",
      "target": "UsageLedger.status.conditions",
      "condition": "Ready",
      "evidenceRef": "support.diagnostics.usage-ledger-status"
    },
    {
      "name": "billing-replay-ready",
      "type": "usage-meter-replay",
      "target": "BillingConnector.events",
      "condition": "IdempotentReplayReady",
      "evidenceRef": "evidence.billing-finops.billing-replay"
    }
  ],
  "tenantAccess": {
    "scope": "project",
    "entitlementRef": "catalog.plan.standard",
    "entitlements": [
      {
        "name": "standard-plan",
        "ref": "catalog.plan.standard",
        "scope": "project"
      }
    ],
    "permissions": [
      "billing-finops.read",
      "billing-finops.write",
      "billing-finops.support"
    ]
  },
  "durability": {
    "stateClass": "event-sourced",
    "dataClasses": [
      "usage-ledger-events",
      "cost-allocation-records",
      "invoice-preview-receipts"
    ],
    "backupPolicyRef": "backup.billing-finops.ledger",
    "recoveryObjective": "ledger-replay-required-before-production",
    "recoveryEvidence": [
      {
        "name": "ledger-replay",
        "type": "runbook-evidence",
        "ref": "evidence.billing-finops.ledger-replay"
      }
    ]
  },
  "distribution": {
    "deploymentProfiles": [
      "provider-managed",
      "dedicated-cell"
    ],
    "channels": [
      "service-store",
      "enterprise-marketplace"
    ],
    "infrastructureTargets": [
      "kubernetes",
      "private-cloud",
      "edge"
    ],
    "updatePolicyRef": "updates.billing-finops.compatibility-reviewed"
  },
  "federation": {
    "applicability": "supported",
    "modes": [
      "standalone",
      "connected",
      "federated"
    ],
    "messageBusRef": "federation.bus.billing-finops.events",
    "crossProviderScenarios": [
      "billing-replay",
      "support-handoff",
      "marketplace-settlement"
    ],
    "portabilityPolicyRef": "policy.billing-finops.ocs-portable-commercial-ledger"
  },
  "commercial": {
    "applicability": "supported",
    "roles": [
      "vendor",
      "provider",
      "reseller"
    ],
    "revenueModel": "metered-usage-ledger-and-cost-allocation",
    "licenseRef": "license.billing-finops.marketplace-module",
    "expiryBehavior": "service-keeps-running-updates-stop-except-critical-fixes",
    "supportRef": "support.billing-finops.provider-handoff",
    "serviceProvenance": "module-owned-service-surface",
    "responsibilityMatrixRef": "responsibility.billing-finops.module-provider-and-ledger-adapter",
    "continuityPlanRef": "continuity.billing-finops.ledger-replay-export"
  }
}
