{
  "apiVersion": "ocsv3.cloudring.io/v1alpha1",
  "kind": "ConnectorPackage",
  "metadata": {
    "name": "support-module-package",
    "displayName": "Support Module Package",
    "owner": "support-module-team",
    "version": "v0.1.0"
  },
  "service": {
    "apiVersion": "ocsv3.cloudring.io/v1alpha1",
    "kind": "ServiceConnector",
    "metadata": {
      "name": "support-module",
      "displayName": "Support Module",
      "owner": "support-module-team",
      "version": "v0.1.0"
    },
    "spec": {
      "executionProfile": "local",
      "productAPI": {
        "ref": "service.api.support.v1alpha1",
        "version": "v1alpha1",
        "protocol": "https-json"
      },
      "capabilities": [
        {
          "class": "support",
          "name": "tenant-support-case",
          "description": "Tenant-scoped case intake, diagnostic bundle, escalation, export, and delete workflow contract."
        }
      ],
      "dependencies": [
        {
          "id": "support-system-adapter-contract",
          "capabilityClass": "support-system",
          "role": "portable case management adapter",
          "portability": "ocs-portable-support-system-contract",
          "productAPIRef": "service.api.support-system.v1",
          "versionRange": ">=1.0.0,<2.0.0",
          "compatibilityPolicyRef": "policy.compatibility.support-system"
        }
      ],
      "lifecycle": [
        {
          "name": "provision",
          "applicability": "supported",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "metadata.uid"
        },
        {
          "name": "hold",
          "applicability": "not_applicable",
          "reason": "support cases remain active until explicitly deprovisioned"
        },
        {
          "name": "resume",
          "applicability": "not_applicable",
          "reason": "hold is not supported by the support case lifecycle"
        },
        {
          "name": "resize",
          "applicability": "not_applicable",
          "reason": "support cases do not expose a capacity resize operation"
        },
        {
          "name": "open",
          "applicability": "supported",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "case.request.id"
        },
        {
          "name": "attachDiagnostic",
          "applicability": "supported",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "diagnostic.bundle.id"
        },
        {
          "name": "escalate",
          "applicability": "supported",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "escalation.request.id"
        },
        {
          "name": "export",
          "applicability": "supported",
          "verb": "Export",
          "idempotent": true,
          "idempotencyKey": "export.request.id"
        },
        {
          "name": "deprovision",
          "applicability": "supported",
          "verb": "Delete",
          "idempotent": true,
          "idempotencyKey": "delete.request.id",
          "rollbackRef": "lifecycle.rollback"
        },
        {
          "name": "backup",
          "applicability": "supported",
          "verb": "Backup",
          "idempotent": true,
          "idempotencyKey": "backup.request.id"
        },
        {
          "name": "restore",
          "applicability": "supported",
          "verb": "Restore",
          "idempotent": true,
          "idempotencyKey": "restore.request.id"
        },
        {
          "name": "retry",
          "applicability": "supported",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "retry.request.id",
          "rollbackRef": "lifecycle.rollback"
        },
        {
          "name": "rollback",
          "applicability": "supported",
          "verb": "Rollback",
          "idempotent": true,
          "idempotencyKey": "rollback.request.id"
        }
      ],
      "automation": [
        {
          "name": "open-support-case",
          "description": "Open a tenant-scoped case with sanitized diagnostic references.",
          "actionRef": "lifecycle.open"
        },
        {
          "name": "attach-support-diagnostic",
          "description": "Attach support-safe evidence without tenant secret material.",
          "actionRef": "lifecycle.attachDiagnostic"
        },
        {
          "name": "escalate-support-case",
          "description": "Escalate through a portable owner and responsibility handoff.",
          "actionRef": "lifecycle.escalate"
        }
      ],
      "usageMeters": [
        {
          "name": "support_case_events",
          "unit": "case-event",
          "aggregation": "sum"
        },
        {
          "name": "diagnostic_bundle_events",
          "unit": "bundle-event",
          "aggregation": "sum"
        }
      ],
      "billing": {
        "applicability": "supported",
        "connectorRef": "support-module-billing",
        "meters": [
          {
            "name": "support_case_events",
            "unit": "case-event",
            "aggregation": "sum"
          },
          {
            "name": "diagnostic_bundle_events",
            "unit": "bundle-event",
            "aggregation": "sum"
          }
        ]
      },
      "portalModules": [
        {
          "name": "support-overview",
          "slot": "service.detail",
          "route": "/services/support",
          "apiRef": "service.api.support.cases",
          "hostRef": "ui.support.host",
          "mountRef": "mount.support.overview",
          "permissions": [
            "support.read",
            "support.write"
          ]
        }
      ],
      "ui": {
        "embedRef": "ui.support.bundle",
        "contextSchemaRef": "schemas/support-ui-context.v1alpha1.json",
        "hostAuthority": [
          "navigation",
          "identity",
          "policy",
          "support"
        ],
        "extensionActions": [
          "support.case.open",
          "support.diagnostic.attach",
          "support.case.escalate",
          "support.case.delete"
        ],
        "moduleHost": {
          "host": "cloudring-provider-portal",
          "runtime": "module-federation",
          "mountRef": "mount.support.overview",
          "versionRange": ">=0.1.0 <1.0.0",
          "signatureRef": "evidence.support.ui.signature",
          "integrityRef": "evidence.support.ui.integrity",
          "sandbox": "tenant-iam-context",
          "allowedEvents": [
            "support.case.open.requested",
            "support.diagnostic.attach.requested",
            "support.case.escalate.requested",
            "support.case.delete.requested"
          ],
          "requiredContext": [
            "tenant",
            "project",
            "iam.subject",
            "entitlements"
          ]
        },
        "evidence": [
          {
            "name": "ui-integrity",
            "type": "integrity-evidence",
            "ref": "evidence.support.ui.integrity"
          }
        ]
      },
      "analyticsEvents": [
        {
          "name": "support.case.submitted",
          "trigger": "portal-module-action",
          "subject": "tenant.project.support-case",
          "properties": [
            "tenantId",
            "projectId",
            "operation",
            "result"
          ],
          "evidenceRef": "evidence.support.analytics.case"
        }
      ],
      "kubernetesBindings": [
        {
          "group": "support.cloudring.io",
          "version": "v1alpha1",
          "kind": "SupportCase",
          "plural": "supportcases",
          "scope": "Namespaced",
          "crdRef": "crd.supportcases.support.cloudring",
          "statusPath": "status.conditions",
          "condition": "Ready"
        }
      ],
      "gatewayRoutes": [
        {
          "name": "support-api",
          "parentRef": "gateway-api.parent.platform-services",
          "hostnames": [
            "support.service-api.contract"
          ],
          "rules": [
            "tenant-support-api"
          ],
          "evidenceRef": "evidence.support.gateway-route"
        }
      ],
      "secrets": {
        "workloadIdentityRef": "workloadidentity.support-controller",
        "secretRefs": [
          {
            "name": "support-system-reference",
            "ref": "secretref.support.system-account",
            "purpose": "support system access by reference",
            "rotation": "operator-initiated"
          }
        ]
      },
      "policies": [
        {
          "name": "tenant-support-entitlement",
          "class": "authorization",
          "decisionRef": "policy.support.entitlement",
          "evidenceRef": "evidence.support.policy.entitlement"
        }
      ],
      "dataLifecycle": {
        "export": {
          "actionRef": "lifecycle.export",
          "format": "ocs-support-case-export",
          "evidenceRef": "evidence.support.export"
        },
        "delete": {
          "actionRef": "lifecycle.deprovision",
          "format": "tenant-support-delete-receipt",
          "evidenceRef": "evidence.support.delete"
        }
      },
      "states": [
        {
          "name": "degraded",
          "reason": "support system adapter is unavailable",
          "userVisible": true,
          "evidenceRef": "evidence.support.degraded",
          "remediation": "retry after adapter recovery or export local case receipt"
        },
        {
          "name": "blocked",
          "reason": "case entitlement, diagnostic policy, or adapter reference is missing",
          "userVisible": true,
          "evidenceRef": "evidence.support.blocked",
          "remediation": "resolve entitlement or adapter blockers before case mutation resumes"
        },
        {
          "name": "ready",
          "reason": "controller ready",
          "userVisible": true,
          "evidenceRef": "evidence.support.ready",
          "remediation": "continue normal operation"
        },
        {
          "name": "retryable",
          "reason": "transient dependency failure",
          "userVisible": true,
          "evidenceRef": "evidence.support.retryable",
          "remediation": "retry with the same idempotency key"
        },
        {
          "name": "denied",
          "reason": "policy denied",
          "userVisible": true,
          "evidenceRef": "evidence.support.denied",
          "remediation": "request entitlement or policy change"
        }
      ],
      "support": {
        "owner": "support-module-team",
        "escalation": "platform-support",
        "diagnostics": [
          "support-case-status",
          "diagnostic-bundle-summary",
          "escalation-handoff-summary"
        ],
        "docsRef": "modules/support/README.md",
        "evidence": [
          {
            "name": "support-diagnostics",
            "type": "support-evidence",
            "ref": "evidence.support.support-diagnostics"
          }
        ]
      },
      "evidenceBundles": [
        {
          "name": "support-module-evidence",
          "owner": "support-module-team",
          "claim": "case intake, diagnostics, escalation, support ownership, and billing meters are declared as OCSv3 contract metadata",
          "freshness": "review-before-publication",
          "redaction": "support-safe-summary-only",
          "evidence": [
            {
              "name": "support-diagnostic-review",
              "type": "support-evidence",
              "ref": "evidence.support.diagnostics"
            }
          ],
          "nonClaims": [
            "does not include raw case private data",
            "does not include external support system credentials"
          ],
          "reviewPath": "reviews.support.module"
        }
      ]
    }
  },
  "billing": {
    "apiVersion": "ocsv3.cloudring.io/v1alpha1",
    "kind": "BillingConnector",
    "metadata": {
      "name": "support-module-billing",
      "displayName": "Support Module Billing",
      "owner": "support-module-team",
      "version": "v0.1.0"
    },
    "meters": [
      {
        "name": "support_case_events",
        "unit": "case-event",
        "aggregation": "sum"
      },
      {
        "name": "diagnostic_bundle_events",
        "unit": "bundle-event",
        "aggregation": "sum"
      }
    ],
    "costMeters": [
      {
        "name": "support_case_event",
        "currency": "USD",
        "unitPrice": "0.00-example",
        "meterRef": "support_case_events",
        "evidenceRef": "evidence.support.cost-meter.case-event"
      },
      {
        "name": "diagnostic_bundle_event",
        "currency": "USD",
        "unitPrice": "0.00-example",
        "meterRef": "diagnostic_bundle_events",
        "evidenceRef": "evidence.support.cost-meter.diagnostic"
      }
    ],
    "events": [
      {
        "name": "support-case-event-recorded",
        "meter": "support_case_events",
        "idempotent": true,
        "idempotencyKey": "usageEvent.id",
        "entitlementRef": "catalog.plan.standard",
        "attribution": "tenant.project.subscription",
        "replayPolicy": "dedupe-by-idempotency-key"
      },
      {
        "name": "diagnostic-bundle-event-recorded",
        "meter": "diagnostic_bundle_events",
        "idempotent": true,
        "idempotencyKey": "usageEvent.id",
        "entitlementRef": "catalog.plan.standard",
        "attribution": "tenant.project.subscription",
        "replayPolicy": "dedupe-by-idempotency-key"
      }
    ]
  },
  "catalog": {
    "serviceClass": "support",
    "visibility": "tenant",
    "portability": "ocs-portable-support-case-contract",
    "plans": [
      {
        "name": "standard",
        "displayName": "Standard Support",
        "billingMode": "metered",
        "quotaRef": "quota.support.standard"
      }
    ]
  },
  "configuration": {
    "schemaRef": "schemas/support.v1alpha1.json",
    "version": "v1alpha1"
  },
  "readiness": [
    {
      "name": "support-case-ready",
      "type": "kubernetes-condition",
      "target": "SupportCase.status.conditions",
      "condition": "Ready",
      "evidenceRef": "support.diagnostics.support-case-status"
    },
    {
      "name": "diagnostic-redaction-ready",
      "type": "support-evidence",
      "target": "support.evidence",
      "condition": "SupportSafeEvidenceLinked",
      "evidenceRef": "evidence.support.diagnostics"
    }
  ],
  "tenantAccess": {
    "scope": "project",
    "entitlementRef": "catalog.plan.standard",
    "entitlements": [
      {
        "name": "standard-plan",
        "ref": "catalog.plan.standard",
        "scope": "project"
      }
    ],
    "permissions": [
      "support.read",
      "support.write",
      "support.escalate"
    ]
  },
  "durability": {
    "stateClass": "event-sourced",
    "dataClasses": [
      "support-case-intent",
      "diagnostic-bundle-references",
      "escalation-receipts",
      "usage-events"
    ],
    "backupPolicyRef": "backup.support.receipts",
    "recoveryObjective": "case-receipt-replay-required-before-production",
    "recoveryEvidence": [
      {
        "name": "support-case-replay",
        "type": "runbook-evidence",
        "ref": "evidence.support.case-replay"
      }
    ]
  },
  "distribution": {
    "deploymentProfiles": [
      "provider-managed",
      "dedicated-cell"
    ],
    "channels": [
      "service-store",
      "enterprise-marketplace"
    ],
    "infrastructureTargets": [
      "kubernetes",
      "private-cloud",
      "edge"
    ],
    "updatePolicyRef": "updates.support.compatibility-reviewed"
  },
  "federation": {
    "applicability": "supported",
    "modes": [
      "standalone",
      "connected",
      "federated"
    ],
    "messageBusRef": "federation.bus.support.events",
    "crossProviderScenarios": [
      "support-handoff",
      "case-export",
      "diagnostic-redaction-review"
    ],
    "portabilityPolicyRef": "policy.support.ocs-portable-case-handoff"
  },
  "commercial": {
    "applicability": "supported",
    "roles": [
      "vendor",
      "provider",
      "reseller"
    ],
    "revenueModel": "metered-case-and-diagnostic-events",
    "licenseRef": "license.support.marketplace-module",
    "expiryBehavior": "service-keeps-running-updates-stop-except-critical-fixes",
    "supportRef": "support.support.provider-handoff",
    "serviceProvenance": "module-owned-service-surface",
    "responsibilityMatrixRef": "responsibility.support.module-provider-and-adapter",
    "continuityPlanRef": "continuity.support.case-export-replay"
  }
}
