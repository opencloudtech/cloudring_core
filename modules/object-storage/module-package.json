{
  "apiVersion": "ocsv3.cloudring.io/v1alpha1",
  "kind": "ConnectorPackage",
  "metadata": {
    "name": "object-storage-module-package",
    "displayName": "Object Storage Module Package",
    "owner": "object-storage-module-team",
    "version": "v0.1.0"
  },
  "service": {
    "apiVersion": "ocsv3.cloudring.io/v1alpha1",
    "kind": "ServiceConnector",
    "metadata": {
      "name": "object-storage-module",
      "displayName": "Object Storage Module",
      "owner": "object-storage-module-team",
      "version": "v0.1.0"
    },
    "spec": {
      "capabilities": [
        {
          "class": "object-storage",
          "name": "bucket",
          "description": "Tenant-scoped S3-compatible bucket lifecycle"
        },
        {
          "class": "s3-compatible-api",
          "name": "portable-object-api",
          "description": "Generic S3-compatible object API contract without provider endpoint or credential values"
        }
      ],
      "dependencies": [
        {
          "id": "s3-compatible-backend",
          "capabilityClass": "s3-compatible-api",
          "role": "data-plane",
          "portability": "s3-compatible-api-contract"
        }
      ],
      "lifecycle": [
        {
          "name": "provision",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "metadata.uid"
        },
        {
          "name": "rotateAccessGrant",
          "verb": "Rotate",
          "idempotent": true,
          "idempotencyKey": "rotation.request.id",
          "rollbackRef": "support.restorePreviousGrant"
        },
        {
          "name": "export",
          "verb": "Export",
          "idempotent": true,
          "idempotencyKey": "export.request.id"
        },
        {
          "name": "delete",
          "verb": "Delete",
          "idempotent": true,
          "idempotencyKey": "delete.request.id",
          "rollbackRef": "lifecycle.rollback"
        },
        {
          "name": "backup",
          "verb": "Backup",
          "idempotent": true,
          "idempotencyKey": "backup.request.id"
        },
        {
          "name": "restore",
          "verb": "Restore",
          "idempotent": true,
          "idempotencyKey": "restore.request.id"
        },
        {
          "name": "retry",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "retry.request.id",
          "rollbackRef": "lifecycle.rollback"
        },
        {
          "name": "rollback",
          "verb": "Rollback",
          "idempotent": true,
          "idempotencyKey": "rollback.request.id"
        }
      ],
      "automation": [
        {
          "name": "apply-bucket",
          "description": "Apply tenant bucket intent through the object storage connector",
          "actionRef": "lifecycle.provision"
        },
        {
          "name": "rotate-access-grant",
          "description": "Rotate tenant access references through the connector without raw credential material",
          "actionRef": "lifecycle.rotateAccessGrant"
        }
      ],
      "usageMeters": [
        {
          "name": "stored_bytes",
          "unit": "byte-hour",
          "aggregation": "sum"
        },
        {
          "name": "request_units",
          "unit": "request",
          "aggregation": "sum"
        }
      ],
      "billing": {
        "connectorRef": "object-storage-module-billing",
        "meters": [
          {
            "name": "stored_bytes",
            "unit": "byte-hour",
            "aggregation": "sum"
          },
          {
            "name": "request_units",
            "unit": "request",
            "aggregation": "sum"
          }
        ]
      },
      "portalModules": [
        {
          "name": "bucket-overview",
          "slot": "service.detail",
          "route": "/services/object-storage/buckets",
          "apiRef": "service.api.object-storage.buckets",
          "hostRef": "ui.object-storage.host",
          "mountRef": "mount.object-storage.bucket-overview",
          "permissions": [
            "object-storage.read",
            "object-storage.write"
          ]
        }
      ],
      "ui": {
        "embedRef": "ui.object-storage.bundle",
        "contextSchemaRef": "schemas/object-storage-ui-context.v1alpha1.json",
        "hostAuthority": [
          "navigation",
          "identity",
          "policy"
        ],
        "extensionActions": [
          "bucket.create",
          "bucket.grant.rotate",
          "bucket.delete"
        ],
        "moduleHost": {
          "host": "cloudring-provider-portal",
          "runtime": "module-federation",
          "mountRef": "mount.object-storage.bucket-overview",
          "versionRange": ">=0.1.0 <1.0.0",
          "integrityRef": "evidence.object-storage.ui.integrity",
          "sandbox": "tenant-iam-context",
          "allowedEvents": [
            "bucket.create.requested",
            "bucket.grant.rotate.requested",
            "bucket.delete.requested"
          ],
          "requiredContext": [
            "tenant",
            "project",
            "iam.subject",
            "locale",
            "theme"
          ]
        },
        "evidence": [
          {
            "name": "ui-host-shell-certification",
            "type": "certification-evidence",
            "ref": "evidence.object-storage.ui.host-shell"
          }
        ]
      },
      "analyticsEvents": [
        {
          "name": "object-storage.bucket.apply.submitted",
          "trigger": "portal-module-action",
          "subject": "tenant.project.bucket-order",
          "properties": [
            "tenantId",
            "projectId",
            "plan",
            "storageClass",
            "result"
          ],
          "evidenceRef": "evidence.object-storage.analytics"
        }
      ],
      "kubernetesBindings": [
        {
          "group": "storage.cloudring.io",
          "version": "v1alpha1",
          "kind": "ObjectBucket",
          "plural": "objectbuckets",
          "scope": "Namespaced",
          "crdRef": "crd.objectbuckets.storage.cloudring.io",
          "statusPath": "status.conditions",
          "condition": "Ready"
        }
      ],
      "gatewayRoutes": [
        {
          "name": "object-storage-api",
          "parentRef": "gateway-api.parent.platform-services",
          "hostnames": [
            "object-storage.services.example"
          ],
          "rules": [
            "tenant-bucket-api"
          ],
          "evidenceRef": "evidence.object-storage.gateway-route"
        }
      ],
      "secrets": {
        "workloadIdentityRef": "workloadidentity.object-storage-controller",
        "secretRefs": [
          {
            "name": "s3-credential-reference",
            "ref": "credentialref.object-storage.access-grant",
            "purpose": "tenant data-plane access by reference",
            "rotation": "operator-initiated"
          }
        ]
      },
      "policies": [
        {
          "name": "tenant-data-residency",
          "class": "data-residency",
          "decisionRef": "policy.object-storage.residency",
          "evidenceRef": "evidence.object-storage.policy"
        }
      ],
      "dataLifecycle": {
        "export": {
          "actionRef": "lifecycle.export",
          "format": "s3-compatible-object-archive",
          "evidenceRef": "evidence.object-storage.export"
        },
        "delete": {
          "actionRef": "lifecycle.delete",
          "format": "tenant-object-delete-receipt",
          "evidenceRef": "evidence.object-storage.delete"
        }
      },
      "states": [
        {
          "name": "degraded",
          "reason": "S3-compatible backend capability is unavailable",
          "userVisible": true,
          "evidenceRef": "evidence.object-storage.degraded",
          "remediation": "retry after capability recovery or export affected bucket data"
        },
        {
          "name": "denied",
          "reason": "IAM, quota, or data-residency policy denies the requested bucket operation",
          "userVisible": true,
          "evidenceRef": "evidence.object-storage.denied",
          "remediation": "resolve entitlement, quota, or policy before retry"
        },
        {
          "name": "blocked",
          "reason": "policy denial or missing entitlement blocks reconciliation",
          "userVisible": true,
          "evidenceRef": "evidence.object-storage.blocked",
          "remediation": "resolve policy or entitlement before retry"
        },
        {
          "name": "ready",
          "reason": "controller ready",
          "userVisible": true,
          "evidenceRef": "evidence.object-storage.ready",
          "remediation": "continue normal operation"
        },
        {
          "name": "retryable",
          "reason": "transient dependency failure",
          "userVisible": true,
          "evidenceRef": "evidence.object-storage.retryable",
          "remediation": "retry with the same idempotency key"
        }
      ],
      "support": {
        "owner": "object-storage-module-team",
        "escalation": "provider-support",
        "diagnostics": [
          "bucket-status",
          "usage-ingestion-status",
          "access-grant-status"
        ],
        "docsRef": "docs/modules/object-storage.md",
        "evidence": [
          {
            "name": "support-diagnostics",
            "type": "support-evidence",
            "ref": "evidence.object-storage.support-diagnostics"
          }
        ]
      },
      "evidenceBundles": [
        {
          "name": "object-storage-module-evidence",
          "owner": "object-storage-module-team",
          "claim": "object storage UI, billing, support, readiness, durability, degraded, and denied states are declared through OCSv3 metadata",
          "freshness": "review-before-publication",
          "redaction": "support-safe-summary-only",
          "evidence": [
            {
              "name": "support-diagnostics",
              "type": "support-evidence",
              "ref": "evidence.object-storage.support-diagnostics"
            }
          ],
          "nonClaims": [
            "does not claim live deployment readiness",
            "does not include provider endpoints or raw credentials"
          ],
          "reviewPath": "support.owner.review"
        }
      ]
    }
  },
  "billing": {
    "apiVersion": "ocsv3.cloudring.io/v1alpha1",
    "kind": "BillingConnector",
    "metadata": {
      "name": "object-storage-module-billing",
      "displayName": "Object Storage Module Billing",
      "owner": "object-storage-module-team",
      "version": "v0.1.0"
    },
    "meters": [
      {
        "name": "stored_bytes",
        "unit": "byte-hour",
        "aggregation": "sum"
      },
      {
        "name": "request_units",
        "unit": "request",
        "aggregation": "sum"
      }
    ],
    "costMeters": [
      {
        "name": "storage_gib_month",
        "currency": "USD",
        "unitPrice": "0.00-example",
        "meterRef": "stored_bytes",
        "evidenceRef": "evidence.object-storage.storage-cost-meter"
      },
      {
        "name": "request_unit_month",
        "currency": "USD",
        "unitPrice": "0.00-example",
        "meterRef": "request_units",
        "evidenceRef": "evidence.object-storage.request-cost-meter"
      }
    ],
    "events": [
      {
        "name": "storage-usage-recorded",
        "meter": "stored_bytes",
        "idempotent": true,
        "idempotencyKey": "usageEvent.id",
        "entitlementRef": "catalog.plan.standard",
        "attribution": "tenant.project.subscription",
        "replayPolicy": "dedupe-by-idempotency-key"
      },
      {
        "name": "request-usage-recorded",
        "meter": "request_units",
        "idempotent": true,
        "idempotencyKey": "usageEvent.id",
        "entitlementRef": "catalog.plan.standard",
        "attribution": "tenant.project.subscription",
        "replayPolicy": "dedupe-by-idempotency-key"
      }
    ]
  },
  "catalog": {
    "serviceClass": "object-storage",
    "visibility": "tenant",
    "portability": "s3-compatible-api-contract",
    "plans": [
      {
        "name": "standard",
        "displayName": "Standard Object Storage",
        "billingMode": "metered",
        "quotaRef": "quota.object-storage.standard"
      }
    ]
  },
  "configuration": {
    "schemaRef": "schemas/object-storage.v1alpha1.json",
    "version": "v1alpha1"
  },
  "readiness": [
    {
      "name": "bucket-controller-ready",
      "type": "kubernetes-condition",
      "target": "ObjectBucket.status.conditions",
      "condition": "Ready",
      "evidenceRef": "support.diagnostics.bucket-status"
    },
    {
      "name": "access-grant-ready",
      "type": "connector-condition",
      "target": "ObjectBucket.status.accessGrant",
      "condition": "Granted",
      "evidenceRef": "support.diagnostics.access-grant-status"
    }
  ],
  "tenantAccess": {
    "scope": "project",
    "entitlementRef": "catalog.plan.standard",
    "entitlements": [
      {
        "name": "standard-plan",
        "ref": "catalog.plan.standard",
        "scope": "project"
      }
    ],
    "permissions": [
      "object-storage.read",
      "object-storage.write"
    ]
  },
  "durability": {
    "stateClass": "stateful",
    "dataClasses": [
      "tenant-object-data",
      "bucket-metadata",
      "usage-events"
    ],
    "backupPolicyRef": "backup.object-storage.standard",
    "recoveryObjective": "restore-test-required-before-production",
    "recoveryEvidence": [
      {
        "name": "object-storage-restore-drill",
        "type": "runbook-evidence",
        "ref": "evidence.object-storage.restore"
      }
    ]
  },
  "distribution": {
    "deploymentProfiles": [
      "self-hosted",
      "provider-managed",
      "edge-zone"
    ],
    "channels": [
      "open-source",
      "enterprise-marketplace"
    ],
    "infrastructureTargets": [
      "kubernetes",
      "private-cloud",
      "public-cloud",
      "edge"
    ],
    "updatePolicyRef": "updates.object-storage.compatibility-reviewed"
  },
  "federation": {
    "modes": [
      "standalone",
      "connected",
      "federated"
    ],
    "messageBusRef": "federation.bus.ocsv3.events",
    "crossProviderScenarios": [
      "replication",
      "migration",
      "support-handoff"
    ],
    "portabilityPolicyRef": "policy.object-storage.no-provider-lock-in"
  },
  "commercial": {
    "roles": [
      "vendor",
      "provider",
      "reseller"
    ],
    "revenueModel": "metered-usage-with-revenue-share",
    "licenseRef": "license.object-storage.enterprise-marketplace",
    "expiryBehavior": "service-keeps-running-updates-stop-except-critical-fixes",
    "supportRef": "support.object-storage.provider-handoff",
    "serviceProvenance": "first-party-provider-managed",
    "responsibilityMatrixRef": "responsibility.object-storage.provider-and-partner",
    "continuityPlanRef": "continuity.object-storage.dr-restorable"
  }
}
