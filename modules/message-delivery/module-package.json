{
  "apiVersion": "ocsv3.cloudring.io/v1alpha1",
  "kind": "ConnectorPackage",
  "metadata": {
    "name": "message-delivery-module-package",
    "displayName": "Message Delivery Module Package",
    "owner": "message-delivery-module-team",
    "version": "v0.1.0"
  },
  "service": {
    "apiVersion": "ocsv3.cloudring.io/v1alpha1",
    "kind": "ServiceConnector",
    "metadata": {
      "name": "message-delivery-module",
      "displayName": "Message Delivery Module",
      "owner": "message-delivery-module-team",
      "version": "v0.1.0"
    },
    "spec": {
      "capabilities": [
        {
          "class": "message-delivery",
          "name": "tenant-notification",
          "description": "Tenant-scoped message template, dispatch, retry, and receipt contract."
        }
      ],
      "dependencies": [
        {
          "id": "message-transport-contract",
          "capabilityClass": "message-transport",
          "role": "portable delivery transport",
          "portability": "ocs-portable-message-transport-contract"
        }
      ],
      "lifecycle": [
        {
          "name": "provision",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "metadata.uid"
        },
        {
          "name": "configure",
          "verb": "Apply",
          "idempotent": true,
          "idempotencyKey": "metadata.uid"
        },
        {
          "name": "send",
          "verb": "Send",
          "idempotent": true,
          "idempotencyKey": "message.request.id"
        },
        {
          "name": "retry",
          "verb": "Retry",
          "idempotent": true,
          "idempotencyKey": "message.request.id",
          "rollbackRef": "lifecycle.rollback"
        },
        {
          "name": "export",
          "verb": "Export",
          "idempotent": true,
          "idempotencyKey": "export.request.id"
        },
        {
          "name": "delete",
          "verb": "Delete",
          "idempotent": true,
          "idempotencyKey": "delete.request.id",
          "rollbackRef": "lifecycle.rollback"
        },
        {
          "name": "backup",
          "verb": "Backup",
          "idempotent": true,
          "idempotencyKey": "backup.request.id"
        },
        {
          "name": "restore",
          "verb": "Restore",
          "idempotent": true,
          "idempotencyKey": "restore.request.id"
        },
        {
          "name": "rollback",
          "verb": "Rollback",
          "idempotent": true,
          "idempotencyKey": "rollback.request.id"
        }
      ],
      "automation": [
        {
          "name": "apply-message-policy",
          "description": "Apply tenant message delivery policy and template references.",
          "actionRef": "lifecycle.configure"
        },
        {
          "name": "dispatch-message",
          "description": "Submit delivery intent through the transport contract and record receipt state.",
          "actionRef": "lifecycle.send"
        },
        {
          "name": "retry-message",
          "description": "Replay a retryable message with the original idempotency key.",
          "actionRef": "lifecycle.retry"
        }
      ],
      "usageMeters": [
        {
          "name": "message_attempts",
          "unit": "attempt",
          "aggregation": "sum"
        },
        {
          "name": "message_deliveries",
          "unit": "delivery",
          "aggregation": "sum"
        }
      ],
      "billing": {
        "connectorRef": "message-delivery-module-billing",
        "meters": [
          {
            "name": "message_attempts",
            "unit": "attempt",
            "aggregation": "sum"
          },
          {
            "name": "message_deliveries",
            "unit": "delivery",
            "aggregation": "sum"
          }
        ]
      },
      "portalModules": [
        {
          "name": "message-delivery-overview",
          "slot": "service.detail",
          "route": "/services/message-delivery",
          "apiRef": "service.api.message-delivery.messages",
          "hostRef": "ui.message-delivery.host",
          "mountRef": "mount.message-delivery.overview",
          "permissions": [
            "message-delivery.read",
            "message-delivery.write"
          ]
        }
      ],
      "ui": {
        "embedRef": "ui.message-delivery.bundle",
        "contextSchemaRef": "schemas/message-delivery-ui-context.v1alpha1.json",
        "hostAuthority": [
          "navigation",
          "identity",
          "policy",
          "support"
        ],
        "extensionActions": [
          "message.configure",
          "message.send",
          "message.retry",
          "message.delete"
        ],
        "moduleHost": {
          "host": "cloudring-provider-portal",
          "runtime": "module-federation",
          "mountRef": "mount.message-delivery.overview",
          "versionRange": ">=0.1.0 <1.0.0",
          "integrityRef": "evidence.message-delivery.ui.integrity",
          "sandbox": "tenant-iam-context",
          "allowedEvents": [
            "message.configure.requested",
            "message.send.requested",
            "message.retry.requested",
            "message.delete.requested"
          ],
          "requiredContext": [
            "tenant",
            "project",
            "iam.subject",
            "entitlements"
          ]
        },
        "evidence": [
          {
            "name": "ui-integrity",
            "type": "integrity-evidence",
            "ref": "evidence.message-delivery.ui.integrity"
          }
        ]
      },
      "analyticsEvents": [
        {
          "name": "message-delivery.dispatch.submitted",
          "trigger": "portal-module-action",
          "subject": "tenant.project.message-request",
          "properties": [
            "tenantId",
            "projectId",
            "operation",
            "result"
          ],
          "evidenceRef": "evidence.message-delivery.analytics.dispatch"
        }
      ],
      "kubernetesBindings": [
        {
          "group": "messaging.cloudring.io",
          "version": "v1alpha1",
          "kind": "MessageDeliveryPolicy",
          "plural": "messagedeliverypolicies",
          "scope": "Namespaced",
          "crdRef": "crd.messagedeliverypolicies.messaging.cloudring",
          "statusPath": "status.conditions",
          "condition": "Ready"
        }
      ],
      "gatewayRoutes": [
        {
          "name": "message-delivery-api",
          "parentRef": "gateway-api.parent.platform-services",
          "hostnames": [
            "message-delivery.service-api.contract"
          ],
          "rules": [
            "tenant-message-delivery-api"
          ],
          "evidenceRef": "evidence.message-delivery.gateway-route"
        }
      ],
      "secrets": {
        "workloadIdentityRef": "workloadidentity.message-delivery-controller",
        "secretRefs": [
          {
            "name": "transport-account-reference",
            "ref": "secretref.message-delivery.transport-account",
            "purpose": "delivery transport account by reference",
            "rotation": "operator-initiated"
          }
        ]
      },
      "policies": [
        {
          "name": "tenant-message-entitlement",
          "class": "authorization",
          "decisionRef": "policy.message-delivery.entitlement",
          "evidenceRef": "evidence.message-delivery.policy.entitlement"
        }
      ],
      "dataLifecycle": {
        "export": {
          "actionRef": "lifecycle.export",
          "format": "ocs-message-delivery-receipt-archive",
          "evidenceRef": "evidence.message-delivery.export"
        },
        "delete": {
          "actionRef": "lifecycle.delete",
          "format": "tenant-message-delete-receipt",
          "evidenceRef": "evidence.message-delivery.delete"
        }
      },
      "states": [
        {
          "name": "degraded",
          "reason": "delivery transport capability is unavailable",
          "userVisible": true,
          "evidenceRef": "evidence.message-delivery.degraded",
          "remediation": "retry after transport capability recovery"
        },
        {
          "name": "blocked",
          "reason": "delivery policy, entitlement, or transport reference is missing",
          "userVisible": true,
          "evidenceRef": "evidence.message-delivery.blocked",
          "remediation": "clear policy and reference blockers before dispatch resumes"
        },
        {
          "name": "ready",
          "reason": "controller ready",
          "userVisible": true,
          "evidenceRef": "evidence.message-delivery.ready",
          "remediation": "continue normal operation"
        },
        {
          "name": "retryable",
          "reason": "transient dependency failure",
          "userVisible": true,
          "evidenceRef": "evidence.message-delivery.retryable",
          "remediation": "retry with the same idempotency key"
        },
        {
          "name": "denied",
          "reason": "policy denied",
          "userVisible": true,
          "evidenceRef": "evidence.message-delivery.denied",
          "remediation": "request entitlement or policy change"
        }
      ],
      "support": {
        "owner": "message-delivery-module-team",
        "escalation": "platform-support",
        "diagnostics": [
          "message-policy-status",
          "delivery-receipt-summary",
          "retry-replay-summary"
        ],
        "docsRef": "modules/message-delivery/README.md",
        "evidence": [
          {
            "name": "support-diagnostics",
            "type": "support-evidence",
            "ref": "evidence.message-delivery.support-diagnostics"
          }
        ]
      },
      "evidenceBundles": [
        {
          "name": "message-delivery-module-evidence",
          "owner": "message-delivery-module-team",
          "claim": "message policy, delivery receipts, retry behavior, support diagnostics, and billing meters are declared as OCSv3 contract metadata",
          "freshness": "review-before-publication",
          "redaction": "message-metadata-only",
          "evidence": [
            {
              "name": "delivery-receipt-review",
              "type": "contract-evidence",
              "ref": "evidence.message-delivery.receipts"
            }
          ],
          "nonClaims": [
            "does not include message body content",
            "does not include transport account secrets"
          ],
          "reviewPath": "reviews.message-delivery.module"
        }
      ]
    }
  },
  "billing": {
    "apiVersion": "ocsv3.cloudring.io/v1alpha1",
    "kind": "BillingConnector",
    "metadata": {
      "name": "message-delivery-module-billing",
      "displayName": "Message Delivery Module Billing",
      "owner": "message-delivery-module-team",
      "version": "v0.1.0"
    },
    "meters": [
      {
        "name": "message_attempts",
        "unit": "attempt",
        "aggregation": "sum"
      },
      {
        "name": "message_deliveries",
        "unit": "delivery",
        "aggregation": "sum"
      }
    ],
    "costMeters": [
      {
        "name": "message_attempt",
        "currency": "USD",
        "unitPrice": "0.00-example",
        "meterRef": "message_attempts",
        "evidenceRef": "evidence.message-delivery.cost-meter.attempt"
      },
      {
        "name": "message_delivery",
        "currency": "USD",
        "unitPrice": "0.00-example",
        "meterRef": "message_deliveries",
        "evidenceRef": "evidence.message-delivery.cost-meter.delivery"
      }
    ],
    "events": [
      {
        "name": "message-attempt-recorded",
        "meter": "message_attempts",
        "idempotent": true,
        "idempotencyKey": "usageEvent.id",
        "entitlementRef": "catalog.plan.standard",
        "attribution": "tenant.project.subscription",
        "replayPolicy": "dedupe-by-idempotency-key"
      },
      {
        "name": "message-delivery-recorded",
        "meter": "message_deliveries",
        "idempotent": true,
        "idempotencyKey": "usageEvent.id",
        "entitlementRef": "catalog.plan.standard",
        "attribution": "tenant.project.subscription",
        "replayPolicy": "dedupe-by-idempotency-key"
      }
    ]
  },
  "catalog": {
    "serviceClass": "message-delivery",
    "visibility": "tenant",
    "portability": "ocs-portable-message-delivery-contract",
    "plans": [
      {
        "name": "standard",
        "displayName": "Standard Message Delivery",
        "billingMode": "metered",
        "quotaRef": "quota.message-delivery.standard"
      }
    ]
  },
  "configuration": {
    "schemaRef": "schemas/message-delivery.v1alpha1.json",
    "version": "v1alpha1"
  },
  "readiness": [
    {
      "name": "message-policy-ready",
      "type": "kubernetes-condition",
      "target": "MessageDeliveryPolicy.status.conditions",
      "condition": "Ready",
      "evidenceRef": "support.diagnostics.message-policy-status"
    },
    {
      "name": "delivery-replay-ready",
      "type": "usage-meter-replay",
      "target": "BillingConnector.events",
      "condition": "IdempotentReplayReady",
      "evidenceRef": "evidence.message-delivery.billing-replay"
    }
  ],
  "tenantAccess": {
    "scope": "project",
    "entitlementRef": "catalog.plan.standard",
    "entitlements": [
      {
        "name": "standard-plan",
        "ref": "catalog.plan.standard",
        "scope": "project"
      }
    ],
    "permissions": [
      "message-delivery.read",
      "message-delivery.write",
      "message-delivery.support"
    ]
  },
  "durability": {
    "stateClass": "event-sourced",
    "dataClasses": [
      "message-policy-intent",
      "delivery-receipts",
      "usage-events"
    ],
    "backupPolicyRef": "backup.message-delivery.receipts",
    "recoveryObjective": "receipt-replay-required-before-production",
    "recoveryEvidence": [
      {
        "name": "delivery-receipt-replay",
        "type": "runbook-evidence",
        "ref": "evidence.message-delivery.receipt-replay"
      }
    ]
  },
  "distribution": {
    "deploymentProfiles": [
      "provider-managed",
      "dedicated-cell"
    ],
    "channels": [
      "service-store",
      "enterprise-marketplace"
    ],
    "infrastructureTargets": [
      "kubernetes",
      "private-cloud",
      "edge"
    ],
    "updatePolicyRef": "updates.message-delivery.compatibility-reviewed"
  },
  "federation": {
    "modes": [
      "standalone",
      "connected",
      "federated"
    ],
    "messageBusRef": "federation.bus.message-delivery.events",
    "crossProviderScenarios": [
      "delivery-replay",
      "policy-portability",
      "support-handoff"
    ],
    "portabilityPolicyRef": "policy.message-delivery.ocs-portable-transport"
  },
  "commercial": {
    "roles": [
      "vendor",
      "provider",
      "reseller"
    ],
    "revenueModel": "metered-message-attempts-and-deliveries",
    "licenseRef": "license.message-delivery.marketplace-module",
    "expiryBehavior": "service-keeps-running-updates-stop-except-critical-fixes",
    "supportRef": "support.message-delivery.provider-handoff",
    "serviceProvenance": "module-owned-service-surface",
    "responsibilityMatrixRef": "responsibility.message-delivery.module-provider-and-transport-adapter",
    "continuityPlanRef": "continuity.message-delivery.receipt-replay-export"
  }
}
