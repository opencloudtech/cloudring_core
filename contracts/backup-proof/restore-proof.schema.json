{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloudring.org/contracts/backup-proof/restore-proof.schema.json",
  "title": "CloudRING Velero 1.18.2 CSI data-mover volume restore proof",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "proofScope",
    "veleroVersion",
    "veleroRuntime",
    "collectedAt",
    "context",
    "lineage",
    "dataUpload",
    "dataUploadResult",
    "receiptSha256"
  ],
  "properties": {
    "schemaVersion": { "const": "cloudring.restore-proof.csi-data-mover/v1" },
    "proofScope": { "const": "single-volume-data-path-only" },
    "veleroVersion": { "const": "v1.18.2" },
    "veleroRuntime": { "$ref": "#/$defs/veleroRuntime" },
    "collectedAt": { "$ref": "#/$defs/timestamp" },
    "context": { "$ref": "#/$defs/context" },
    "lineage": { "$ref": "#/$defs/lineage" },
    "dataUpload": { "$ref": "#/$defs/dataUpload" },
    "dataUploadResult": { "$ref": "#/$defs/dataUploadResult" },
    "receiptSha256": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "timestamp": { "type": "string", "format": "date-time" },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 253,
      "pattern": "^[a-z0-9](?:[a-z0-9.-]*[a-z0-9])?$"
    },
    "runtimeId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:+/-]*$"
    },
    "versionId": {
      "type": "string",
      "minLength": 2,
      "maxLength": 255,
      "pattern": "^v[A-Za-z0-9._:+/-]+$"
    },
    "gvr": {
      "type": "object",
      "additionalProperties": false,
      "required": ["group", "version", "resource"],
      "properties": {
        "group": { "type": "string" },
        "version": { "type": "string", "minLength": 1 },
        "resource": { "type": "string", "minLength": 1 }
      }
    },
    "targetResource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resource", "namespace", "name", "uidSha256", "resourceVersionSha256", "validatedStateSha256"],
      "properties": {
        "resource": { "type": "string", "minLength": 1 },
        "namespace": { "type": "string" },
        "name": { "$ref": "#/$defs/name" },
        "uidSha256": { "$ref": "#/$defs/digest" },
        "resourceVersionSha256": { "$ref": "#/$defs/digest" },
        "validatedStateSha256": { "$ref": "#/$defs/digest" }
      }
    },
    "sourceResource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resource",
        "namespace",
        "name",
        "uidSha256",
        "resourceVersionBeforeSha256",
        "resourceVersionAfterSha256",
        "stateBeforeSha256",
        "stateAfterSha256"
      ],
      "properties": {
        "resource": { "const": "persistentvolumeclaims" },
        "namespace": { "$ref": "#/$defs/name" },
        "name": { "$ref": "#/$defs/name" },
        "uidSha256": { "$ref": "#/$defs/digest" },
        "resourceVersionBeforeSha256": { "$ref": "#/$defs/digest" },
        "resourceVersionAfterSha256": { "$ref": "#/$defs/digest" },
        "stateBeforeSha256": { "$ref": "#/$defs/digest" },
        "stateAfterSha256": { "$ref": "#/$defs/digest" }
      }
    },
    "sourcePersistentVolume": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resource",
        "namespace",
        "name",
        "uidSha256",
        "resourceVersionBeforeSha256",
        "resourceVersionAfterSha256",
        "stateBeforeSha256",
        "stateAfterSha256"
      ],
      "properties": {
        "resource": { "const": "persistentvolumes" },
        "namespace": { "const": "" },
        "name": { "$ref": "#/$defs/name" },
        "uidSha256": { "$ref": "#/$defs/digest" },
        "resourceVersionBeforeSha256": { "$ref": "#/$defs/digest" },
        "resourceVersionAfterSha256": { "$ref": "#/$defs/digest" },
        "stateBeforeSha256": { "$ref": "#/$defs/digest" },
        "stateAfterSha256": { "$ref": "#/$defs/digest" }
      }
    },
    "sourceBaseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "capturedAt", "source", "evidenceRef", "evidenceSha256"],
      "properties": {
        "schemaVersion": { "const": "cloudring.restore-proof.source-baseline/v1" },
        "capturedAt": { "$ref": "#/$defs/timestamp" },
        "source": { "$ref": "#/$defs/sourceResource" },
        "evidenceRef": { "$ref": "#/$defs/runtimeId" },
        "evidenceSha256": { "$ref": "#/$defs/digest" }
      }
    },
    "veleroRuntime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gvr", "object", "serverVersion", "phase", "processedAt", "observedAt", "evidenceRef", "evidenceSha256"],
      "properties": {
        "gvr": { "$ref": "#/$defs/gvr" },
        "object": { "$ref": "#/$defs/targetResource" },
        "serverVersion": { "const": "v1.18.2" },
        "phase": { "const": "Processed" },
        "processedAt": { "$ref": "#/$defs/timestamp" },
        "observedAt": { "$ref": "#/$defs/timestamp" },
        "evidenceRef": { "$ref": "#/$defs/runtimeId" },
        "evidenceSha256": { "$ref": "#/$defs/digest" }
      }
    },
    "cleanup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validationCompletedAt", "cleanupStartedAt", "cleanupCompletedAt", "verifiedAt", "targetResources", "sourceResources"],
      "properties": {
        "validationCompletedAt": { "$ref": "#/$defs/timestamp" },
        "cleanupStartedAt": { "$ref": "#/$defs/timestamp" },
        "cleanupCompletedAt": { "$ref": "#/$defs/timestamp" },
        "verifiedAt": { "$ref": "#/$defs/timestamp" },
        "targetResources": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/targetResource" }
        },
        "sourceResources": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/sourceResource" },
              { "$ref": "#/$defs/sourcePersistentVolume" }
            ]
          }
        }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "veleroNamespace",
        "restoreId",
        "restoreUidSha256",
        "restoreResourceVersionSha256",
        "backupId",
        "backupUidSha256",
        "backupResourceVersionSha256",
        "backupStorageLocation",
        "backupCompletedAt",
        "namespaceMapping",
        "restoreStartedAt",
        "completedAt",
        "csiSnapshotTimeout",
        "sourceBaseline",
        "cleanup"
      ],
      "properties": {
        "veleroNamespace": { "$ref": "#/$defs/name" },
        "restoreId": { "$ref": "#/$defs/name" },
        "restoreUidSha256": { "$ref": "#/$defs/digest" },
        "restoreResourceVersionSha256": { "$ref": "#/$defs/digest" },
        "backupId": { "$ref": "#/$defs/name" },
        "backupUidSha256": { "$ref": "#/$defs/digest" },
        "backupResourceVersionSha256": { "$ref": "#/$defs/digest" },
        "backupStorageLocation": { "$ref": "#/$defs/name" },
        "backupCompletedAt": { "$ref": "#/$defs/timestamp" },
        "namespaceMapping": {
          "type": "object",
          "minProperties": 1,
          "maxProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/name" }
        },
        "restoreStartedAt": { "$ref": "#/$defs/timestamp" },
        "completedAt": { "$ref": "#/$defs/timestamp" },
        "csiSnapshotTimeout": { "type": "string", "minLength": 1 },
        "backupUploaderConfigSha256": { "$ref": "#/$defs/digest" },
        "restoreUploaderConfigSha256": { "$ref": "#/$defs/digest" },
        "dataMoverConfigSha256": { "$ref": "#/$defs/digest" },
        "sourceBaseline": { "$ref": "#/$defs/sourceBaseline" },
        "cleanup": { "$ref": "#/$defs/cleanup" }
      }
    },
    "probe": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "implementation",
        "version",
        "requestSha256",
        "adapterExecutableSha256",
        "sourceGvr",
        "source",
        "targetGvr",
        "target",
        "targetPv",
        "sourcePvcVolumeName",
        "targetPvcVolumeName",
        "hashAlgorithm",
        "sourceDataSha256",
        "restoredDataSha256",
        "validatedBytes",
        "startedAt",
        "completedAt",
        "observedDurationMilliseconds",
        "evidenceRef",
        "evidenceSha256"
      ],
      "properties": {
        "status": { "const": "verified" },
        "implementation": { "$ref": "#/$defs/runtimeId" },
        "version": { "$ref": "#/$defs/versionId" },
        "requestSha256": { "$ref": "#/$defs/digest" },
        "adapterExecutableSha256": { "$ref": "#/$defs/digest" },
        "sourceGvr": { "$ref": "#/$defs/gvr" },
        "source": { "$ref": "#/$defs/sourceResource" },
        "targetGvr": { "$ref": "#/$defs/gvr" },
        "target": { "$ref": "#/$defs/targetResource" },
        "targetPv": { "$ref": "#/$defs/targetResource" },
        "sourcePvcVolumeName": { "$ref": "#/$defs/name" },
        "targetPvcVolumeName": { "$ref": "#/$defs/name" },
        "hashAlgorithm": { "const": "sha256" },
        "sourceDataSha256": { "$ref": "#/$defs/digest" },
        "restoredDataSha256": { "$ref": "#/$defs/digest" },
        "validatedBytes": { "type": "integer", "minimum": 1 },
        "startedAt": { "$ref": "#/$defs/timestamp" },
        "completedAt": { "$ref": "#/$defs/timestamp" },
        "observedDurationMilliseconds": { "type": "integer", "minimum": 1 },
        "evidenceRef": { "$ref": "#/$defs/runtimeId" },
        "evidenceSha256": { "$ref": "#/$defs/digest" }
      }
    },
    "dataDownload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "targetVolumePvc",
        "targetVolumePv",
        "targetVolumeNamespace",
        "targetPv",
        "backupStorageLocation",
        "dataMover",
        "snapshotIdSha256",
        "sourceNamespace",
        "cancel",
        "operationTimeout",
        "nodeOs",
        "snapshotSize",
        "asyncOperationIdLabelSha256",
        "dataUploadResultObject",
        "dataUploadUidSha256",
        "archivedDataUploadSha256",
        "dataUploadResultPayloadSha256"
      ],
      "properties": {
        "targetVolumePvc": { "$ref": "#/$defs/name" },
        "targetVolumePv": { "const": "" },
        "targetVolumeNamespace": { "$ref": "#/$defs/name" },
        "targetPv": { "$ref": "#/$defs/targetResource" },
        "backupStorageLocation": { "$ref": "#/$defs/name" },
        "dataMover": { "enum": ["", "velero"] },
        "snapshotIdSha256": { "$ref": "#/$defs/digest" },
        "sourceNamespace": { "$ref": "#/$defs/name" },
        "dataMoverConfigSha256": { "$ref": "#/$defs/digest" },
        "cancel": { "const": false },
        "operationTimeout": { "type": "string", "minLength": 1 },
        "nodeOs": { "const": "linux" },
        "snapshotSize": { "type": "integer", "minimum": 1 },
        "asyncOperationIdLabelSha256": { "$ref": "#/$defs/digest" },
        "dataUploadResultObject": { "$ref": "#/$defs/targetResource" },
        "dataUploadUidSha256": { "$ref": "#/$defs/digest" },
        "archivedDataUploadSha256": { "$ref": "#/$defs/digest" },
        "dataUploadResultPayloadSha256": { "$ref": "#/$defs/digest" }
      }
    },
    "helper": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gvr",
        "object",
        "restoreUidSha256",
        "ownerRestoreUidSha256",
        "restoreNameLabel",
        "restoreUidLabelSha256",
        "terminalStatus",
        "startedAt",
        "completedAt",
        "bytesDone",
        "totalBytes",
        "operationIdSha256",
        "targetPvc",
        "sourcePvc",
        "dataDownload",
        "evidenceRef",
        "evidenceSha256"
      ],
      "properties": {
        "gvr": { "$ref": "#/$defs/gvr" },
        "object": { "$ref": "#/$defs/targetResource" },
        "restoreUidSha256": { "$ref": "#/$defs/digest" },
        "ownerRestoreUidSha256": { "$ref": "#/$defs/digest" },
        "restoreNameLabel": { "type": "string", "minLength": 1 },
        "restoreUidLabelSha256": { "$ref": "#/$defs/digest" },
        "terminalStatus": { "const": "Completed" },
        "startedAt": { "$ref": "#/$defs/timestamp" },
        "completedAt": { "$ref": "#/$defs/timestamp" },
        "bytesDone": { "type": "integer", "minimum": 1 },
        "totalBytes": { "type": "integer", "minimum": 1 },
        "operationIdSha256": { "$ref": "#/$defs/digest" },
        "targetPvc": { "$ref": "#/$defs/targetResource" },
        "sourcePvc": { "$ref": "#/$defs/sourceResource" },
        "dataDownload": { "$ref": "#/$defs/dataDownload" },
        "evidenceRef": { "$ref": "#/$defs/runtimeId" },
        "evidenceSha256": { "$ref": "#/$defs/digest" }
      }
    },
    "providerObservation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "artifactHandleSha256", "observedAt", "requestSha256", "adapterExecutableSha256", "querySha256", "observationSha256", "evidenceRef", "evidenceSha256"],
      "properties": {
        "status": { "enum": ["present", "absent"] },
        "artifactHandleSha256": { "$ref": "#/$defs/digest" },
        "observedAt": { "$ref": "#/$defs/timestamp" },
        "requestSha256": { "$ref": "#/$defs/digest" },
        "adapterExecutableSha256": { "$ref": "#/$defs/digest" },
        "querySha256": { "$ref": "#/$defs/digest" },
        "observationSha256": { "$ref": "#/$defs/digest" },
        "evidenceRef": { "$ref": "#/$defs/runtimeId" },
        "evidenceSha256": { "$ref": "#/$defs/digest" }
      }
    },
    "backend": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "providerImplementation",
        "providerVersion",
        "artifactHandleSha256",
        "sourceKind",
        "derivedFrom",
        "targetPvc",
        "targetPv",
        "sourcePv",
        "sourceArtifactHandleSha256",
        "lineageSha256",
        "deletedAt",
        "presenceObservation",
        "absenceObservations",
        "sourcePresenceObservation",
        "evidenceRef",
        "evidenceSha256"
      ],
      "properties": {
        "status": { "const": "deleted-and-absent" },
        "providerImplementation": { "$ref": "#/$defs/runtimeId" },
        "providerVersion": { "$ref": "#/$defs/versionId" },
        "artifactHandleSha256": { "$ref": "#/$defs/digest" },
        "sourceKind": { "const": "persistent-volume" },
        "derivedFrom": { "$ref": "#/$defs/targetResource" },
        "targetPvc": { "$ref": "#/$defs/targetResource" },
        "targetPv": { "$ref": "#/$defs/targetResource" },
        "sourcePv": { "$ref": "#/$defs/sourcePersistentVolume" },
        "sourceArtifactHandleSha256": { "$ref": "#/$defs/digest" },
        "lineageSha256": { "$ref": "#/$defs/digest" },
        "deletedAt": { "$ref": "#/$defs/timestamp" },
        "presenceObservation": { "$ref": "#/$defs/providerObservation" },
        "absenceObservations": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "$ref": "#/$defs/providerObservation" }
        },
        "sourcePresenceObservation": { "$ref": "#/$defs/providerObservation" },
        "evidenceRef": { "$ref": "#/$defs/runtimeId" },
        "evidenceSha256": { "$ref": "#/$defs/digest" }
      }
    },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "method",
        "probes",
        "probeSetSha256",
        "aggregateDataSha256",
        "validatedBytes",
        "helpers",
        "backendArtifacts",
        "providerAbsenceSetSha256",
        "evidenceRef",
        "evidenceSha256"
      ],
      "properties": {
        "status": { "const": "verified" },
        "method": { "const": "csi-data-mover" },
        "probes": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/probe" } },
        "probeSetSha256": { "$ref": "#/$defs/digest" },
        "aggregateDataSha256": { "$ref": "#/$defs/digest" },
        "validatedBytes": { "type": "integer", "minimum": 1 },
        "helpers": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/helper" } },
        "backendArtifacts": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/backend" } },
        "providerAbsenceSetSha256": { "$ref": "#/$defs/digest" },
        "evidenceRef": { "$ref": "#/$defs/runtimeId" },
        "evidenceSha256": { "$ref": "#/$defs/digest" }
      }
    },
    "dataUpload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gvr",
        "namespace",
        "name",
        "uidSha256",
        "resourceVersionSha256",
        "ownerBackupUidSha256",
        "backupNameLabel",
        "backupUidLabelSha256",
        "sourcePvcUidLabelSha256",
        "sourcePvcGvr",
        "sourcePvc",
        "snapshotType",
        "volumeSnapshotSha256",
        "storageClassSha256",
        "driver",
        "backupStorageLocation",
        "dataMover",
        "operationIdSha256",
        "operationTimeout",
        "phase",
        "message",
        "startedAt",
        "completedAt",
        "snapshotIdSha256",
        "nodeOs",
        "bytesDone",
        "totalBytes",
        "archivedObjectSha256",
        "retainedAfterRestoreCleanupAt",
        "evidenceRef",
        "evidenceSha256"
      ],
      "properties": {
        "gvr": { "$ref": "#/$defs/gvr" },
        "namespace": { "$ref": "#/$defs/name" },
        "name": { "$ref": "#/$defs/name" },
        "uidSha256": { "$ref": "#/$defs/digest" },
        "resourceVersionSha256": { "$ref": "#/$defs/digest" },
        "ownerBackupUidSha256": { "$ref": "#/$defs/digest" },
        "backupNameLabel": { "type": "string", "minLength": 1 },
        "backupUidLabelSha256": { "$ref": "#/$defs/digest" },
        "sourcePvcUidLabelSha256": { "$ref": "#/$defs/digest" },
        "sourcePvcGvr": { "$ref": "#/$defs/gvr" },
        "sourcePvc": { "$ref": "#/$defs/sourceResource" },
        "snapshotType": { "const": "CSI" },
        "volumeSnapshotSha256": { "$ref": "#/$defs/digest" },
        "storageClassSha256": { "$ref": "#/$defs/digest" },
        "snapshotClassSha256": { "$ref": "#/$defs/digest" },
        "driver": { "$ref": "#/$defs/runtimeId" },
        "backupStorageLocation": { "$ref": "#/$defs/name" },
        "dataMover": { "enum": ["", "velero"] },
        "dataMoverConfigSha256": { "$ref": "#/$defs/digest" },
        "operationIdSha256": { "$ref": "#/$defs/digest" },
        "operationTimeout": { "type": "string", "minLength": 1 },
        "phase": { "const": "Completed" },
        "message": { "const": "" },
        "startedAt": { "$ref": "#/$defs/timestamp" },
        "completedAt": { "$ref": "#/$defs/timestamp" },
        "snapshotIdSha256": { "$ref": "#/$defs/digest" },
        "nodeOs": { "const": "linux" },
        "dataMoverResultSha256": { "$ref": "#/$defs/digest" },
        "bytesDone": { "type": "integer", "minimum": 1 },
        "totalBytes": { "type": "integer", "minimum": 1 },
        "archivedObjectSha256": { "$ref": "#/$defs/digest" },
        "retainedAfterRestoreCleanupAt": { "$ref": "#/$defs/timestamp" },
        "evidenceRef": { "$ref": "#/$defs/runtimeId" },
        "evidenceSha256": { "$ref": "#/$defs/digest" }
      }
    },
    "dataUploadResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "gvr",
        "object",
        "dataUploadUidSha256",
        "dataUploadName",
        "archivedDataUploadSha256",
        "restoreUidSha256",
        "restoreUidLabelSha256",
        "restoreUidDataKeySha256",
        "pvcNamespaceNameLabel",
        "resourceUsage",
        "sourcePvc",
        "backupStorageLocation",
        "dataMover",
        "snapshotIdSha256",
        "sourceNamespace",
        "snapshotSize",
        "nodeOs",
        "resultPayloadSha256",
        "evidenceRef",
        "evidenceSha256"
      ],
      "properties": {
        "status": { "const": "generated-consumed-cleaned" },
        "gvr": { "$ref": "#/$defs/gvr" },
        "object": { "$ref": "#/$defs/targetResource" },
        "dataUploadUidSha256": { "$ref": "#/$defs/digest" },
        "dataUploadName": { "$ref": "#/$defs/name" },
        "archivedDataUploadSha256": { "$ref": "#/$defs/digest" },
        "restoreUidSha256": { "$ref": "#/$defs/digest" },
        "restoreUidLabelSha256": { "$ref": "#/$defs/digest" },
        "restoreUidDataKeySha256": { "$ref": "#/$defs/digest" },
        "pvcNamespaceNameLabel": { "type": "string", "minLength": 1 },
        "resourceUsage": { "const": "DataUpload" },
        "sourcePvc": { "$ref": "#/$defs/sourceResource" },
        "backupStorageLocation": { "$ref": "#/$defs/name" },
        "dataMover": { "enum": ["", "velero"] },
        "snapshotIdSha256": { "$ref": "#/$defs/digest" },
        "sourceNamespace": { "$ref": "#/$defs/name" },
        "snapshotSize": { "type": "integer", "minimum": 1 },
        "nodeOs": { "const": "linux" },
        "dataMoverResultSha256": { "$ref": "#/$defs/digest" },
        "resultPayloadSha256": { "$ref": "#/$defs/digest" },
        "evidenceRef": { "$ref": "#/$defs/runtimeId" },
        "evidenceSha256": { "$ref": "#/$defs/digest" }
      }
    }
  }
}
