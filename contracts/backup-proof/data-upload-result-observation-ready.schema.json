{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloudring.org/contracts/backup-proof/data-upload-result-observation-ready.schema.json",
  "title": "CloudRING Velero DataUploadResult watch readiness barrier",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "status", "watchStartedAt", "requestSha256"],
  "properties": {
    "schemaVersion": { "const": "cloudring.restore-proof.data-upload-result-observation-ready/v1" },
    "status": { "const": "ready-for-restore" },
    "watchStartedAt": { "$ref": "#/$defs/timestamp" },
    "requestSha256": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](\\.[0-9]+)?Z$"
    },
    "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
