{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloudring.org/contracts/backup-proof/data-upload-result-observation.schema.json",
  "title": "CloudRING private Velero DataUploadResult observation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "watchStartedAt",
    "observedAt",
    "capturedAt",
    "requestSha256",
    "eventType",
    "object",
    "objectSha256",
    "evidenceRef",
    "evidenceSha256"
  ],
  "properties": {
    "schemaVersion": { "const": "cloudring.restore-proof.data-upload-result-observation/v1" },
    "watchStartedAt": { "$ref": "#/$defs/timestamp" },
    "observedAt": { "$ref": "#/$defs/timestamp" },
    "capturedAt": { "$ref": "#/$defs/timestamp" },
    "requestSha256": { "$ref": "#/$defs/digest" },
    "eventType": { "const": "ADDED" },
    "object": {
      "type": "object",
      "required": ["apiVersion", "kind", "metadata", "data"],
      "properties": {
        "apiVersion": { "const": "v1" },
        "kind": { "const": "ConfigMap" },
        "metadata": {
          "type": "object",
          "required": ["name", "namespace", "uid", "resourceVersion", "creationTimestamp", "labels"],
          "properties": {
            "name": { "$ref": "#/$defs/name" },
            "namespace": { "$ref": "#/$defs/name" },
            "uid": { "type": "string", "minLength": 1 },
            "resourceVersion": { "type": "string", "minLength": 1 },
            "creationTimestamp": { "$ref": "#/$defs/timestamp" },
            "labels": {
              "type": "object",
              "required": ["velero.io/restore-uid", "velero.io/pvc-namespace-name", "velero.io/resource-usage"],
              "properties": {
                "velero.io/restore-uid": { "type": "string", "minLength": 1 },
                "velero.io/pvc-namespace-name": { "type": "string", "minLength": 1 },
                "velero.io/resource-usage": { "const": "DataUpload" }
              },
              "additionalProperties": { "type": "string" }
            }
          },
          "additionalProperties": true
        },
        "data": {
          "type": "object",
          "minProperties": 1,
          "maxProperties": 1,
          "additionalProperties": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": true
    },
    "objectSha256": { "$ref": "#/$defs/digest" },
    "evidenceRef": { "$ref": "#/$defs/runtimeId" },
    "evidenceSha256": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 253,
      "pattern": "^[a-z0-9](?:[a-z0-9.-]*[a-z0-9])?$"
    },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](\\.[0-9]+)?Z$"
    },
    "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "runtimeId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9._/+:-]*[A-Za-z0-9])?$",
      "not": { "pattern": "\\.\\." }
    }
  }
}
