{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CloudRING isolated etcd recovery input Secret projection v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "namespace", "secretName", "secretKey", "mountPath", "defaultMode", "optional", "readOnly"],
  "properties": {
    "schemaVersion": {"const": "cloudring.etcd-recovery.input-secret-projection/v1"},
    "namespace": {"type": "string", "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$"},
    "secretName":
    {
      "type": "string",
      "maxLength": 253,
      "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?)*$",
      "not": {
        "anyOf": [
          {"pattern": "\\.\\."},
          {"pattern": "(^|\\.)[a-z0-9-]{64,}(\\.|$)"}
        ]
      }
    },
    "secretKey": {"const": "request.json"},
    "mountPath": {"const": "/run/cloudring/request/request.json"},
    "defaultMode": {"const": 288},
    "optional": {"const": false},
    "readOnly": {"const": true}
  }
}
