{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CloudRING Goal01 backup drill plan v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "operationId", "proofId", "installationId", "acceptedPublicSha", "acceptedDownstreamSha", "clusterIdentitySha256", "backupStorageLocation", "objectStore", "sourceBaselines", "tool", "adapter", "backup", "restores", "isolatedNamespaces", "etcdSandbox", "cleanupTargets", "aggregateProofPathToken", "issuedAt", "expiresAt", "runNonceSha256"],
  "properties": {
    "schemaVersion": {"const": "cloudring.backup-drill.plan/v1"},
    "operationId": {"$ref": "#/$defs/id"}, "proofId": {"$ref": "#/$defs/id"}, "installationId": {"$ref": "#/$defs/id"},
    "acceptedPublicSha": {"$ref": "#/$defs/gitSha"}, "acceptedDownstreamSha": {"$ref": "#/$defs/gitSha"}, "clusterIdentitySha256": {"$ref": "#/$defs/sha"},
    "backupStorageLocation": {"type": "object", "additionalProperties": false, "required": ["name", "uidSha256", "generation", "configSha256"], "properties": {"name": {"$ref": "#/$defs/name"}, "uidSha256": {"$ref": "#/$defs/sha"}, "generation": {"type": "integer", "minimum": 1}, "configSha256": {"$ref": "#/$defs/sha"}}},
    "objectStore": {"type": "object", "additionalProperties": false, "required": ["prefix", "minimumRetentionDays", "objectLockMode"], "properties": {"prefix": {"$ref": "#/$defs/pathValue"}, "minimumRetentionDays": {"type": "integer", "minimum": 30, "maximum": 36500}, "objectLockMode": {"enum": ["governance", "compliance"]}}},
    "sourceBaselines": {"type": "array", "minItems": 5, "maxItems": 5, "prefixItems": [{"$ref": "#/$defs/baselineEtcd"}, {"$ref": "#/$defs/baselineVMC"}, {"$ref": "#/$defs/baselineVolume"}, {"$ref": "#/$defs/baselineNamespace"}, {"$ref": "#/$defs/baselineKCC"}], "items": false},
    "tool": {"$ref": "#/$defs/executable"}, "adapter": {"$ref": "#/$defs/executable"},
    "backup": {"allOf": [{"$ref": "#/$defs/object"}, {"properties": {"kind": {"const": "Backup"}}}]},
    "restores": {"type": "array", "minItems": 4, "maxItems": 4, "prefixItems": [{"$ref": "#/$defs/restoreVMC"}, {"$ref": "#/$defs/restoreVolume"}, {"$ref": "#/$defs/restoreNamespace"}, {"$ref": "#/$defs/restoreKCC"}], "items": false},
    "isolatedNamespaces": {"type": "array", "minItems": 5, "maxItems": 5, "prefixItems": [{"$ref": "#/$defs/mappingVMC"}, {"$ref": "#/$defs/mappingVolume"}, {"$ref": "#/$defs/mappingPlatform"}, {"$ref": "#/$defs/mappingFlux"}, {"$ref": "#/$defs/mappingKCC"}], "items": false},
    "etcdSandbox": {"allOf": [{"$ref": "#/$defs/object"}, {"properties": {"kind": {"const": "EtcdSandbox"}}}]},
    "cleanupTargets": {"type": "array", "minItems": 6, "maxItems": 6, "prefixItems": [{"$ref": "#/$defs/cleanupNamespace"}, {"$ref": "#/$defs/cleanupNamespace"}, {"$ref": "#/$defs/cleanupNamespace"}, {"$ref": "#/$defs/cleanupNamespace"}, {"$ref": "#/$defs/cleanupNamespace"}, {"$ref": "#/$defs/cleanupEtcdSandbox"}], "items": false},
    "aggregateProofPathToken": {"$ref": "#/$defs/pathValue"}, "issuedAt": {"type": "string", "format": "date-time"}, "expiresAt": {"type": "string", "format": "date-time"}, "runNonceSha256": {"$ref": "#/$defs/sha"}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "gitSha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._:-]{0,127}$"}, "name": {"type": "string", "pattern": "^[a-z0-9](?:[a-z0-9.-]{0,61}[a-z0-9])?$"},
    "pathValue": {"type": "string", "pattern": "^[a-z0-9](?:[a-z0-9._/-]{0,227}[a-z0-9_])?$", "not": {"pattern": "\\.\\."}},
    "executable": {"type": "object", "additionalProperties": false, "required": ["name", "executableSha256"], "properties": {"name": {"$ref": "#/$defs/id"}, "executableSha256": {"$ref": "#/$defs/sha"}}},
    "object": {"type": "object", "additionalProperties": false, "required": ["kind", "name", "scopeSha256"], "properties": {"kind": {"type": "string", "minLength": 1, "maxLength": 64}, "namespace": {"$ref": "#/$defs/name"}, "name": {"$ref": "#/$defs/name"}, "scopeSha256": {"$ref": "#/$defs/sha"}}},
    "namespaceDestination": {"type": "object", "additionalProperties": false, "required": ["kind", "name", "scopeSha256"], "properties": {"kind": {"const": "Namespace"}, "namespace": {"const": ""}, "name": {"$ref": "#/$defs/name"}, "scopeSha256": {"$ref": "#/$defs/sha"}}},
    "isolationMapping": {"type": "object", "additionalProperties": false, "required": ["restoreIndex", "restoreName", "restoreScopeSha256", "sourceNamespace", "destination"], "properties": {"restoreIndex": {"type": "integer", "minimum": 0, "maximum": 3}, "restoreName": {"$ref": "#/$defs/name"}, "restoreScopeSha256": {"$ref": "#/$defs/sha"}, "sourceNamespace": {"$ref": "#/$defs/name"}, "destination": {"$ref": "#/$defs/namespaceDestination"}}},
    "cleanup": {"type": "object", "additionalProperties": false, "required": ["kind", "name", "preconditionIdentitySha256"], "properties": {"kind": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9.]{0,63}$"}, "namespace": {"const": ""}, "name": {"$ref": "#/$defs/name"}, "preconditionIdentitySha256": {"$ref": "#/$defs/sha"}}},
    "cleanupNamespace": {"allOf": [{"$ref": "#/$defs/cleanup"}, {"properties": {"kind": {"const": "Namespace"}}}]},
    "cleanupEtcdSandbox": {"allOf": [{"$ref": "#/$defs/cleanup"}, {"properties": {"kind": {"const": "EtcdSandbox"}}}]},
    "baseline": {"type": "object", "additionalProperties": false, "required": ["kind", "identitySha256", "stateSha256", "dataSha256"], "properties": {"kind": {"type": "string"}, "identitySha256": {"$ref": "#/$defs/sha"}, "stateSha256": {"$ref": "#/$defs/sha"}, "dataSha256": {"$ref": "#/$defs/sha"}}},
    "baselineEtcd": {"allOf": [{"$ref": "#/$defs/baseline"}, {"properties": {"kind": {"const": "Etcd"}}}]},
    "baselineVMC": {"allOf": [{"$ref": "#/$defs/baseline"}, {"properties": {"kind": {"const": "VirtualMachineClaim"}}}]},
    "baselineVolume": {"allOf": [{"$ref": "#/$defs/baseline"}, {"properties": {"kind": {"const": "Volume"}}}]},
    "baselineNamespace": {"allOf": [{"$ref": "#/$defs/baseline"}, {"properties": {"kind": {"const": "Namespace"}}}]},
    "baselineKCC": {"allOf": [{"$ref": "#/$defs/baseline"}, {"properties": {"kind": {"const": "KubernetesClusterClaim"}}}]},
    "restoreVMC": {"allOf": [{"$ref": "#/$defs/object"}, {"properties": {"kind": {"const": "VirtualMachineClaim"}}}]},
    "restoreVolume": {"allOf": [{"$ref": "#/$defs/object"}, {"properties": {"kind": {"const": "Volume"}}}]},
    "restoreNamespace": {"allOf": [{"$ref": "#/$defs/object"}, {"properties": {"kind": {"const": "Namespace"}}}]},
    "restoreKCC": {"allOf": [{"$ref": "#/$defs/object"}, {"properties": {"kind": {"const": "KubernetesClusterClaim"}}}]},
    "mappingVMC": {"allOf": [{"$ref": "#/$defs/isolationMapping"}, {"properties": {"restoreIndex": {"const": 0}}}]},
    "mappingVolume": {"allOf": [{"$ref": "#/$defs/isolationMapping"}, {"properties": {"restoreIndex": {"const": 1}}}]},
    "mappingPlatform": {"allOf": [{"$ref": "#/$defs/isolationMapping"}, {"properties": {"restoreIndex": {"const": 2}, "sourceNamespace": {"const": "platform-system"}}}]},
    "mappingFlux": {"allOf": [{"$ref": "#/$defs/isolationMapping"}, {"properties": {"restoreIndex": {"const": 2}, "sourceNamespace": {"const": "flux-system"}}}]},
    "mappingKCC": {"allOf": [{"$ref": "#/$defs/isolationMapping"}, {"properties": {"restoreIndex": {"const": 3}}}]}
  }
}
