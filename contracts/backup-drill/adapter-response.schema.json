{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object", "additionalProperties": false,
  "required": ["schemaVersion", "protocolVersion", "operationId", "step", "requestSha256", "adapterExecutableSha256", "status", "mutated", "evidence", "responseSha256"],
  "properties": {
    "schemaVersion": {"const": "cloudring.backup-drill.adapter-response/v1"}, "protocolVersion": {"const": "cloudring.backup-drill.adapter/v1"}, "operationId": {"type": "string"}, "step": {"enum": ["preflight", "etcd-offcell-complete", "velero-backup-complete", "restore-watch-create-observe-complete", "etcd-sandbox-restored", "restore-validation-complete", "cleanup-ready", "isolated-targets-deleted", "residual-sweep-1", "residual-sweep-2", "proof-assembled", "rollback-safe-stop", "rollback-cleanup-requested"]},
    "requestSha256": {"$ref": "#/$defs/sha"}, "adapterExecutableSha256": {"$ref": "#/$defs/sha"}, "status": {"enum": ["ready", "completed", "partial", "failed", "safe-stopped"]}, "mutated": {"type": "boolean"}, "evidence": {"$ref": "#/$defs/evidence"}, "restoreObservations": {"type": "array", "minItems": 5, "maxItems": 5, "items": {"$ref": "#/$defs/restoreObservation"}},
    "targets": {"type": "array", "maxItems": 5, "items": {"$ref": "#/$defs/target"}}, "isolationEvidence": {"$ref": "#/$defs/evidence"}, "cleanupEvidence": {"$ref": "#/$defs/evidence"},
    "objectLockDeleteDenialReceiptSha256": {"$ref": "#/$defs/sha"}, "aggregateProofArtifactSha256": {"$ref": "#/$defs/sha"}, "aggregateProofPathToken": {"$ref": "#/$defs/pathValue"}, "responseSha256": {"$ref": "#/$defs/sha"}
  }, "$defs": {
    "sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "name": {"type": "string", "pattern": "^[a-z0-9](?:[a-z0-9.-]{0,61}[a-z0-9])?$"}, "pathValue": {"type": "string", "pattern": "^[a-z0-9](?:[a-z0-9._/-]{0,227}[a-z0-9_])?$", "not": {"pattern": "\\.\\."}},
    "evidence": {"type": "object", "additionalProperties": false, "required": ["ref", "sha256"], "properties": {"ref": {"$ref": "#/$defs/pathValue"}, "sha256": {"$ref": "#/$defs/sha"}}},
    "target": {"type": "object", "additionalProperties": false, "required": ["kind", "sourceChecksumSha256", "restoredChecksumSha256", "evidenceRef", "evidenceSha256"], "properties": {"kind": {"type": "string"}, "sourceChecksumSha256": {"$ref": "#/$defs/sha"}, "restoredChecksumSha256": {"$ref": "#/$defs/sha"}, "evidenceRef": {"$ref": "#/$defs/pathValue"}, "evidenceSha256": {"$ref": "#/$defs/sha"}}},
    "restoreObservation": {"type": "object", "additionalProperties": false, "required": ["restoreName", "restoreScopeSha256", "sourceNamespace", "destinationNamespace", "destinationScopeSha256", "evidenceRef", "evidenceSha256"], "properties": {"restoreName": {"$ref": "#/$defs/name"}, "restoreScopeSha256": {"$ref": "#/$defs/sha"}, "sourceNamespace": {"$ref": "#/$defs/name"}, "destinationNamespace": {"$ref": "#/$defs/name"}, "destinationScopeSha256": {"$ref": "#/$defs/sha"}, "evidenceRef": {"$ref": "#/$defs/pathValue"}, "evidenceSha256": {"$ref": "#/$defs/sha"}}}
  }
}
