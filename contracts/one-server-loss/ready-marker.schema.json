{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloudring.org/contracts/one-server-loss/ready-marker.schema.json",
  "title": "CloudRING one-server-loss ready-for-fault marker",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "status", "requestSha256", "runNonceSha256", "targetNodeUidSha256",
    "kubectlExecutableSha256", "probeAdapterSha256", "baselineControlPlaneNodes",
    "baselineEtcdMembers", "baselineApiServerMembers", "readyAt", "markerSha256"
  ],
  "properties": {
    "schemaVersion": { "const": "cloudring.one-server-loss.ready-marker/v1" },
    "status": { "const": "ready-for-fault" },
    "requestSha256": { "$ref": "#/$defs/digest" },
    "runNonceSha256": { "$ref": "#/$defs/digest" },
    "targetNodeUidSha256": { "$ref": "#/$defs/digest" },
    "kubectlExecutableSha256": { "$ref": "#/$defs/digest" },
    "probeAdapterSha256": { "$ref": "#/$defs/digest" },
    "baselineControlPlaneNodes": { "type": "integer", "minimum": 3 },
    "baselineEtcdMembers": { "type": "integer", "minimum": 3 },
    "baselineApiServerMembers": { "type": "integer", "minimum": 3 },
    "readyAt": { "$ref": "#/$defs/timestamp" },
    "markerSha256": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](\\.[0-9]+)?Z$"
    }
  }
}
